const SchoolManagementNew: React.FC = () => {
  const [form] = Form.useForm();
  const [activeTab, setActiveTab] = useState('overview');
  const [selectedRowKeys, setSelectedRowKeys] = useState<React.Key[]>([]);
  const [showDetail, setShowDetail] = useState(false);
  const [showAddContent, setShowAddContent] = useState(false);
  const [showScriptPractice, setShowScriptPractice] = useState(false);
  const [currentContent, setCurrentContent] = useState<any>(null);
  const [currentScript, setCurrentScript] = useState<any>(null);
  const [searchParams, setSearchParams] = useState<any>({});
  
  // API数据状态
  const [loading, setLoading] = useState({
    overall: false,
    videos: false,
    books: false,
    scripts: false,
    upload: false,
    statistics: false
  });
  
  const [schoolStats, setSchoolStats] = useState(mockSchoolStats);
  const [videoList, setVideoList] = useState<any[]>([]);
  const [scriptList, setScriptList] = useState<any[]>([]);
  const [bookList, setBookList] = useState<any[]>([]);
  const [aiPracticeMode, setAiPracticeMode] = useState(false);
  const [showEbookUpload, setShowEbookUpload] = useState(false);
  
  // 数据统计
  const [overallStats, setOverallStats] = useState<any>(null);
  const [recentActivities, setRecentActivities] = useState<any[]>([]);
  const [popularContent, setPopularContent] = useState<any[]>([]);

  // 数据获取函数
  const fetchInitialData = async () => {
    try {
      setLoading(prev => ({ ...prev, overall: true, statistics: true }));
      
      // 获取总览数据
      const initialData = await GlobalDataService.getInitialSchoolData();
      setOverallStats(initialData.overallStats);
      setRecentActivities(initialData.recentActivities);
      setPopularContent(initialData.popularContent);
      
      // 获取各模块数据
      const [videos, books, scripts] = await Promise.all([
        VideoDataService.getVideos({ pageSize: 10 }),
        BookDataService.getBooks({ pageSize: 10 }),
        ScriptDataService.getScripts({ pageSize: 10 }),
      ]);
      
      setVideoList(videos?.list || videos || []);
      setBookList(books?.list || books || []);
      setScriptList(scripts?.list || scripts || []);
      
      // 缓存数据
      GlobalDataService.setCachedData('school_initial_data', {
        overallStats: initialData.overallStats,
        recentActivities: initialData.recentActivities,
        popularContent: initialData.popularContent,
        videos: videos?.list || videos || [],
        books: books?.list || books || [],
        scripts: scripts?.list || scripts || [],
      });
      
    } catch (error) {
      console.error('获取初始数据失败:', error);
      message.error('数据加载失败，请重试');
      
      // 使用模拟数据作为后备
      setVideoList(mockVideoData);
      setBookList(mockBookData);
      setScriptList(mockScriptData);
    } finally {
      setLoading(prev => ({ ...prev, overall: false, statistics: false }));
    }
  };

  // 刷新视频数据
  const refreshVideos = async () => {
    try {
      setLoading(prev => ({ ...prev, videos: true }));
      const videos = await VideoDataService.getVideos(searchParams);
      setVideoList(videos?.list || videos || []);
      GlobalDataService.setCachedData('video_list', videos?.list || videos || []);
      message.success('视频数据刷新成功');
    } catch (error) {
      console.error('刷新视频数据失败:', error);
      setVideoList(mockVideoData);
    } finally {
      setLoading(prev => ({ ...prev, videos: false }));
    }
  };

  // 刷新书籍数据
  const refreshBooks = async () => {
    try {
      setLoading(prev => ({ ...prev, books: true }));
      const books = await BookDataService.getBooks(searchParams);
      setBookList(books?.list || books || []);
      GlobalDataService.setCachedData('book_list', books?.list || books || []);
      message.success('书籍数据刷新成功');
    } catch (error) {
      console.error('刷新书籍数据失败:', error);
      setBookList(mockBookData);
    } finally {
      setLoading(prev => ({ ...prev, books: false }));
    }
  };

  // 刷新话术数据
  const refreshScripts = async () => {
    try {
      setLoading(prev => ({ ...prev, scripts: true }));
      const scripts = await ScriptDataService.getScripts(searchParams);
      setScriptList(scripts?.list || scripts || []);
      GlobalDataService.setCachedData('script_list', scripts?.list || scripts || []);
      message.success('话术数据刷新成功');
    } catch (error) {
      console.error('刷新话术数据失败:', error);
      setScriptList(mockScriptData);
    } finally {
      setLoading(prev => ({ ...prev, scripts: false }));
    }
  };

  // 处理电子书上传
  const handleEbookUpload = async (file: File, metadata: any) => {
    try {
      setLoading(prev => ({ ...prev, upload: true }));
      await BookDataService.uploadEbook(file, metadata);
      await refreshBooks(); // 上传成功后刷新书籍列表
      setShowEbookUpload(false);
      return true;
    } catch (error) {
      console.error('电子书上传失败:', error);
      return false;
    } finally {
      setLoading(prev => ({ ...prev, upload: false }));
    }
  };

  // 处理删除电子书
  const handleDeleteBook = async (id: string) => {
    try {
      await BookDataService.deleteBook(id);
      setBookList(prev => prev.filter(book => book.id !== id));
      message.success('电子书删除成功');
    } catch (error) {
      console.error('删除电子书失败:', error);
      message.error('删除失败，请重试');
    }
  };

  // 处理下载电子书
  const handleDownloadBook = async (record: any) => {
    try {
      await BookDataService.downloadEbook(record.id);
    } catch (error) {
      console.error('下载电子书失败:', error);
    }
  };

  // 组件挂载时获取数据
  useEffect(() => {
    fetchInitialData();
  }, []);

  // 根据活动标签切换数据加载
  useEffect(() => {
    if (activeTab === 'videos' && videoList.length === 0) {
      refreshVideos();
    } else if (activeTab === 'books' && bookList.length === 0) {
      refreshBooks();
    } else if (activeTab === 'scripts' && scriptList.length === 0) {
      refreshScripts();
    }
  }, [activeTab]);

  // 搜索参数变化时刷新数据
  useEffect(() => {
    if (activeTab === 'videos') {
      refreshVideos();
    } else if (activeTab === 'books') {
      refreshBooks();
    } else if (activeTab === 'scripts') {
      refreshScripts();
    }
  }, [searchParams]);

  // 获取分类标签
    const config = categoryConfig[category];
    return (
      <Tag color={config.color} icon={config.icon} style={{ borderRadius: '4px', border: 'none' }}>
        {config.name}
      </Tag>
    );
  };

  // 获取难度标签
  const getDifficultyTag = (difficulty: DifficultyLevel) => {
    const config = difficultyConfig[difficulty];
    return (
      <Tag color={config.color} icon={config.icon} style={{ borderRadius: '4px', border: 'none' }}>
        {config.name}
      </Tag>
    );
  };

  // 获取状态标签
  const getStatusTag = (status: ContentStatus) => {
    const config = statusConfig[status];
    return (
      <Tag color={config.color} style={{ borderRadius: '4px', border: 'none' }}>
        {config.name}
      </Tag>
    );
  };

  // 格式化时长
  const formatDuration = (seconds: number): string => {
    const minutes = Math.floor(seconds / 60);
    const remainingSeconds = seconds % 60;
    return `${minutes}:${remainingSeconds.toString().padStart(2, '0')}`;
  };

  // 视频操作菜单
  const videoActionMenu = (record: any) => (
    <Menu
      items={[
        {
          key: 'view',
          label: '查看详情',
          icon: <EyeOutlined />,
          onClick: () => handleViewVideoDetail(record)
        },
        {
          key: 'edit',
          label: '编辑内容',
          icon: <EditOutlined />,
          onClick: () => handleEditVideo(record)
        },
        {
          key: 'publish',
          label: record.status === ContentStatus.PUBLISHED ? '取消发布' : '发布',
          icon: record.status === ContentStatus.PUBLISHED ? <CloseCircleOutlined /> : <CheckCircleOutlined />,
          onClick: () => handleTogglePublish(record)
        },
        {
          type: 'divider'
        },
        {
          key: 'delete',
          label: '删除视频',
          icon: <DeleteOutlined />,
          danger: true,
          onClick: () => handleDeleteVideo(record)
        }
      ]}
    />
  );

  // 话术操作菜单
  const scriptActionMenu = (record: any) => (
