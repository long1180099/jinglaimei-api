  // 内容详情模态框
  const renderContentDetail = () => {
    if (!currentContent && !currentScript) return null;

    const content = currentContent || currentScript;
    const isVideo = !!currentContent;

    return (
      <Modal
        title={
          <Space>
            {isVideo ? <VideoCameraOutlined /> : <MessageOutlined />}
            <span>{isVideo ? '视频详情' : '话术详情'} - {content.title}</span>
          </Space>
        }
        open={showDetail}
        onCancel={() => {
          setShowDetail(false);
          setCurrentContent(null);
          setCurrentScript(null);
        }}
        width={700}
        footer={[
          <Button key="close" onClick={() => setShowDetail(false)}>
            关闭
          </Button>,
          <Button key="practice" type="primary" icon={isVideo ? <PlayCircleOutlined /> : <RobotOutlined />}>
            {isVideo ? '观看视频' : 'AI话术练习'}
          </Button>
        ]}
      >
        <div className="content-detail-container">
          {/* 基本信息 */}
          <Card title="基本信息" size="small">
            <Row gutter={16}>
              <Col span={8}>
                <Descriptions.Item label="标题">{content.title}</Descriptions.Item>
              </Col>
              <Col span={8}>
                <Descriptions.Item label="分类">
                  {getCategoryTag(content.category)}
                </Descriptions.Item>
              </Col>
              <Col span={8}>
                <Descriptions.Item label="难度">
                  {getDifficultyTag(content.difficulty)}
                </Descriptions.Item>
              </Col>
            </Row>
            {isVideo && (
              <Row gutter={16} style={{ marginTop: 8 }}>
                <Col span={8}>
                  <Descriptions.Item label="讲师">{content.instructor}</Descriptions.Item>
                </Col>
                <Col span={8}>
                  <Descriptions.Item label="时长">{formatDuration(content.duration)}</Descriptions.Item>
                </Col>
                <Col span={8}>
                  <Descriptions.Item label="评分">
                    <Rate disabled defaultValue={content.rating} />
                  </Descriptions.Item>
                </Col>
              </Row>
            )}
          </Card>

          {/* 内容描述 */}
          <Card title="内容描述" size="small" style={{ marginTop: 16 }}>
            <Paragraph>{content.description}</Paragraph>
            <div className="tags-container">
              {content.tags.map((tag: string, index: number) => (
                <Tag key={index} color="blue">{tag}</Tag>
              ))}
            </div>
          </Card>

          {/* 统计数据 */}
          <Card title="统计数据" size="small" style={{ marginTop: 16 }}>
            <Row gutter={16}>
              {isVideo ? (
                <>
                  <Col span={6}>
                    <Statistic title="观看次数" value={content.views} />
                  </Col>
                  <Col span={6}>
                    <Statistic title="点赞数" value={content.likes} />
                  </Col>
                  <Col span={6}>
                    <Statistic title="评论数" value={content.comments} />
                  </Col>
                  <Col span={6}>
                    <Statistic title="评分" value={content.rating} suffix="/5" />
                  </Col>
                </>
              ) : (
                <>
                  <Col span={6}>
                    <Statistic title="使用次数" value={content.usageCount} />
                  </Col>
                  <Col span={6}>
                    <Statistic title="成功率" value={content.successRate} suffix="%" />
                  </Col>
                  <Col span={6}>
                    <Statistic title="练习次数" value={content.practiceCount} />
                  </Col>
                  <Col span={6}>
                    <div className="status-container">
                      {getStatusTag(content.status)}
                    </div>
                  </Col>
                </>
              )}
            </Row>
          </Card>

          {/* 话术内容预览 */}
          {!isVideo && (
            <Card title="话术内容预览" size="small" style={{ marginTop: 16 }}>
              <div className="script-preview">
                <Paragraph>{content.content}</Paragraph>
              </div>
            </Card>
          )}
        </div>
      </Modal>
    );
  };

  // AI话术练习模态框
  const renderScriptPractice = () => {
    if (!currentScript) return null;

    return (
      <Modal
        title={
          <Space>
            <RobotOutlined />
            <span>AI话术练习 - {currentScript.title}</span>
          </Space>
        }
        open={showScriptPractice}
        onCancel={() => {
          setShowScriptPractice(false);
          setCurrentScript(null);
          setAiPracticeMode(false);
        }}
        width={800}
        footer={null}
      >
        <div className="ai-practice-container">
          <Alert
            message="AI话术练习系统"
            description="系统将模拟真实客户场景，帮助您练习话术表达和应对能力。支持语音输入和智能评分。"
            type="info"
            showIcon
            style={{ marginBottom: 20 }}
          />
          
          <Row gutter={16}>
            <Col span={12}>
              <Card title="练习设置" size="small">
                <Form layout="vertical">
                  <Form.Item label="练习模式">
                    <Select defaultValue="scenario" style={{ width: '100%' }}>
                      <Option value="scenario">场景模拟</Option>
                      <Option value="qa">问答练习</Option>
                      <Option value="roleplay">角色扮演</Option>
                    </Select>
                  </Form.Item>
                  <Form.Item label="难度级别">
                    <Select defaultValue={currentScript.difficulty} style={{ width: '100%' }}>
                      <Option value="beginner">初级</Option>
                      <Option value="intermediate">中级</Option>
                      <Option value="advanced">高级</Option>
                    </Select>
                  </Form.Item>
                  <Form.Item label="语音输入">
                    <Switch checked={aiPracticeMode} onChange={setAiPracticeMode} />
                  </Form.Item>
                  <Form.Item>
                    <Button type="primary" block icon={<PlayCircleOutlined />}>
                      开始练习
                    </Button>
                  </Form.Item>
                </Form>
              </Card>
            </Col>
            <Col span={12}>
              <Card title="当前话术" size="small">
                <div className="current-script">
                  <div className="script-content">{currentScript.content}</div>
                  <div className="script-stats">
                    <Space>
                      <Tag color="green">成功率: {currentScript.successRate}%</Tag>
                      <Tag color="blue">使用: {currentScript.usageCount}次</Tag>
                      <Tag color="orange">练习: {currentScript.practiceCount}次</Tag>
                    </Space>
                  </div>
                </div>
              </Card>
            </Col>
          </Row>

          <Card title="练习场景示例" size="small" style={{ marginTop: 16 }}>
            <List
              dataSource={[
                '客户提出价格异议时',
                '客户对产品效果有疑问时',
                '客户需要产品推荐时',
                '客户犹豫不决时',
                '客户想要更多优惠时'
              ]}
              renderItem={(item, index) => (
                <List.Item>
                  <Text>{item}</Text>
                  <Button size="small" type="link" onClick={() => message.info(`开始练习场景: ${item}`)}>
                    开始练习
                  </Button>
                </List.Item>
              )}
            />
          </Card>
        </div>
      </Modal>
    );
  };

  // 添加内容模态框 - 简化版本
  const renderAddContent = () => {
    return (
      <Modal
        title="添加学习内容"
        open={showAddContent}
        onCancel={() => setShowAddContent(false)}
        width={600}
        footer={null}
      >
        <div style={{ padding: '20px 0', textAlign: 'center' }}>
          <p>添加内容功能已就绪</p>
          <p>待编译问题解决后恢复完整功能</p>
        </div>
      </Modal>
    );
  };

  return (
    <div className="school-management-page">
      {/* 页面头部 */}
      <div className="page-header">
        <div className="header-left">
          <BookOutlined className="header-icon" />
          <Title level={2} className="page-title">静莱美商学院</Title>
          <Text type="secondary" className="page-subtitle">
            代理商学习和培训平台，提升销售能力和业务水平
          </Text>
        </div>
        <div className="header-actions">
          <Button
            type="primary"
            icon={<PlusOutlined />}
            onClick={handleAddContent}
            className="primary-action-btn"
          >
            添加内容
          </Button>
          <Button icon={<DownloadOutlined />}>
            导出数据
          </Button>
          <Button icon={<ShareAltOutlined />}>
            分享
          </Button>
        </div>
      </div>

      {/* KPI统计卡片 */}
      <div className="kpi-cards-container">
        <Row gutter={16}>
          <Col xs={24} sm={12} md={6}>
            <Card className="kpi-card">
              <Statistic
                title="学习内容总数"
                value={schoolStats.contentStats.totalVideos + schoolStats.contentStats.totalBooks + schoolStats.contentStats.totalScripts}
                prefix={<BookOutlined />}
                valueStyle={{ color: 'var(--primary-color)' }}
              />
              <div className="kpi-trend">
                <Text type="secondary">
                  视频: {schoolStats.contentStats.totalVideos} | 书籍: {schoolStats.contentStats.totalBooks} | 话术: {schoolStats.contentStats.totalScripts}
                </Text>
              </div>
            </Card>
          </Col>
          <Col xs={24} sm={12} md={6}>
            <Card className="kpi-card">
              <Statistic
                title="学习用户数"
                value={schoolStats.userStats.learningUsers}
                suffix={`/${schoolStats.userStats.totalUsers}`}
                prefix={<TeamOutlined />}
                valueStyle={{ color: 'var(--success-color)' }}
              />
              <div className="kpi-trend">
                <Text type="secondary">
                  活跃用户: {schoolStats.userStats.activeUsers} | 练习用户: {schoolStats.userStats.practiceUsers}
                </Text>
              </div>
            </Card>
          </Col>
          <Col xs={24} sm={12} md={6}>
            <Card className="kpi-card">
              <Statistic
                title="总学习时长"
                value={schoolStats.learningStats.totalLearningTime}
                suffix="小时"
                prefix={<ClockCircleOutlined />}
                valueStyle={{ color: 'var(--warning-color)' }}
              />
              <div className="kpi-trend">
                <Text type="secondary">
                  平均: {schoolStats.learningStats.averageLearningTime}小时/人
                </Text>
              </div>
            </Card>
          </Col>
          <Col xs={24} sm={12} md={6}>
            <Card className="kpi-card">
              <Statistic
                title="总积分奖励"
                value={schoolStats.learningStats.totalPointsAwarded}
                prefix={<TrophyOutlined />}
                valueStyle={{ color: 'var(--processing-color)' }}
              />
              <div className="kpi-trend">
                <Text type="secondary">
                  平均积分: {schoolStats.learningStats.averageUserPoints}
                </Text>
              </div>
            </Card>
          </Col>
        </Row>
      </div>

      {/* 主内容标签页 */}
      <Card className="main-content-card">
        <Tabs activeKey={activeTab} onChange={setActiveTab} className="school-tabs">
          {/* 总览标签页 */}
          <TabPane tab="总览" key="overview" icon={<BarChartOutlined />}>
            <div className="overview-content">
              <Row gutter={16}>
                {/* 学习进度 */}
                <Col xs={24} lg={12}>
                  <Card className="overview-card" title="分类学习进度">
                    {schoolStats.learningProgress.map((item) => (
                      <div key={item.category} className="progress-item">
                        <div className="progress-header">
                          <Space>
                            {getCategoryTag(item.category)}
                            <Text strong>{item.progress}%</Text>
                          </Space>
                          <Text type="secondary">
                            {item.completed}/{item.total} 完成
                          </Text>
                        </div>
                        <Progress 
                          percent={item.progress} 
                          strokeColor={item.color}
                          className="progress-bar"
                        />
                      </div>
                    ))}
                  </Card>
                </Col>

                {/* 热门内容 */}
                <Col xs={24} lg={12}>
                  <Card className="overview-card" title="热门学习内容" extra={<Button type="link">更多</Button>}>
                    <List
                      dataSource={schoolStats.popularContent}
                      renderItem={(item, index) => (
                        <List.Item className="popular-content-item">
                          <div className="popular-content-rank">
                            {index <= 2 ? (
                              <CrownOutlined style={{ 
                                fontSize: 18, 
                                color: index === 0 ? '#ffd700' : index === 1 ? '#c0c0c0' : '#cd7f32' 
                              }} />
                            ) : (
                              <Text strong>{index + 1}</Text>
                            )}
                          </div>
                          <div className="popular-content-info">
                            <div className="content-title">
                              <Text strong>{item.title}</Text>
                            </div>
                            <div className="content-meta">
                              {getCategoryTag(item.category)}
                              <Space>
                                <span><EyeOutlined /> {item.views}</span>
                                <span><LikeOutlined /> {item.likes}</span>
                              </Space>
                            </div>
                          </div>
                          <div className="popular-content-rating">
                            <Rate disabled defaultValue={item.rating} size="small" />
                          </div>
                        </List.Item>
                      )}
                    />
                  </Card>
                </Col>
              </Row>

              <Row gutter={16} style={{ marginTop: 16 }}>
                {/* 积分排行榜 */}
                <Col xs={24} lg={12}>
                  <Card className="overview-card" title="积分排行榜" extra={<Button type="link">查看全部</Button>}>
                    <List
                      dataSource={schoolStats.pointsRanking}
                      renderItem={(item) => (
                        <List.Item className="ranking-item">
                          <div className="ranking-rank">
                            {item.rank <= 3 ? (
                              <Badge 
                                count={item.rank}
                                style={{ 
                                  backgroundColor: item.rank === 1 ? '#ffd700' : item.rank === 2 ? '#c0c0c0' : '#cd7f32',
                                  fontSize: '12px'
                                }}
                              />
                            ) : (
                              <Text strong>{item.rank}</Text>
                            )}
                          </div>
                          <div className="ranking-user">
                            <Avatar size="small" style={{ backgroundColor: 'var(--primary-color)' }}>
                              {item.avatar}
                            </Avatar>
                            <div className="user-info">
                              <div className="user-name">{item.name}</div>
                              <div className="user-level">{item.level}</div>
                            </div>
                          </div>
                          <div className="ranking-points">
                            <Text strong style={{ fontSize: 16 }}>
                              {item.points.toLocaleString()}
                            </Text>
                            <div className={`growth ${item.growth > 0 ? 'growth-up' : 'growth-down'}`}>
                              {item.growth > 0 ? '+' : ''}{item.growth}%
                            </div>
                          </div>
                        </List.Item>
                      )}
                    />
                  </Card>
                </Col>

                {/* 话术统计 */}
                <Col xs={24} lg={12}>
                  <Card className="overview-card" title="话术统计概览">
                    <Row gutter={16}>
                      <Col span={12}>
                        <Statistic
                          title="总话术数"
                          value={schoolStats.scriptStats.totalScripts}
                          valueStyle={{ color: 'var(--primary-color)' }}
                        />
                      </Col>
                      <Col span={12}>
                        <Statistic
                          title="练习次数"
                          value={schoolStats.scriptStats.practicedScripts}
                          valueStyle={{ color: 'var(--success-color)' }}
                        />
                      </Col>
                      <Col span={24}>
                        <div className="script-success-rate">
                          <div className="rate-header">
                            <Text>平均成功率</Text>
                            <Text strong style={{ color: 'var(--success-color)' }}>
                              {schoolStats.scriptStats.averageSuccessRate}%
                            </Text>
                          </div>
                          <Progress 
                            percent={schoolStats.scriptStats.averageSuccessRate} 
                            strokeColor="#52c41a"
                            size="small"
                          />
                        </div>
                      </Col>
                    </Row>
                    <Divider />
                    <div className="hot-scripts">
                      <Text strong>热门话术</Text>
                      {schoolStats.scriptStats.hotScripts.map((script, index) => (
                        <div key={index} className="hot-script-item">
                          <Text>{script.title}</Text>
                          <Space>
                            <Text type="secondary">{script.usage}次</Text>
                            <Tag color="success">{script.success}% 成功率</Tag>
                          </Space>
                        </div>
                      ))}
                    </div>
                  </Card>
                </Col>
              </Row>
            </div>
          </TabPane>

          {/* 学习视频标签页 */}
          <TabPane tab="学习视频" key="videos" icon={<VideoCameraOutlined />}>
            <div className="videos-content">
              {/* 筛选和搜索区域 */}
              <Card className="filter-card">
                <Row gutter={16} align="middle">
                  <Col flex="auto">
                    <Search
                      placeholder="搜索视频标题、讲师、描述..."
                      allowClear
                      enterButton={<SearchOutlined />}
                      size="large"
                      style={{ maxWidth: 400 }}
                    />
                  </Col>
                  <Col>
                    <Space>
                      <Select defaultValue="all" style={{ width: 120 }}>
                        <Option value="all">全部分类</Option>
                        {Object.values(ContentCategory).map(category => (
                          <Option key={category} value={category}>
                            {categoryConfig[category].name}
                          </Option>
                        ))}
                      </Select>
                      <Select defaultValue="published" style={{ width: 120 }}>
                        <Option value="published">已发布</Option>
                        <Option value="draft">草稿</Option>
                        <Option value="all">全部状态</Option>
                      </Select>
                      <Button icon={<FilterOutlined />}>
                        高级筛选
                      </Button>
                    </Space>
                  </Col>
                </Row>
              </Card>

              {/* 批量操作栏 */}
              {selectedRowKeys.length > 0 && (
                <div className="batch-action-bar">
                  <Space>
                    <Text>已选择 {selectedRowKeys.length} 个视频</Text>
                    <Button size="small" onClick={() => setSelectedRowKeys([])}>
                      取消选择
                    </Button>
                    <Button
                      size="small"
                      icon={<CheckCircleOutlined />}
                      onClick={() => handleBatchAction('publish')}
                    >
                      批量发布
                    </Button>
                    <Button
                      size="small"
                      icon={<DownloadOutlined />}
                      onClick={() => handleBatchAction('export')}
                    >
                      批量导出
                    </Button>
                    <Button
                      size="small"
                      icon={<DeleteOutlined />}
                      danger
                      onClick={() => handleBatchAction('delete')}
                    >
                      批量删除
                    </Button>
                  </Space>
                </div>
              )}

              {/* 视频列表表格 */}
              <Card className="videos-table-card">
                <div className="table-header">
                  <Title level={4}>学习视频管理</Title>
                  <Space>
                    <Text type="secondary">共 {videoList.length} 个视频</Text>
                    <Button icon={<SyncOutlined />} onClick={() => setVideoList([...mockVideoData])}>
                      刷新
                    </Button>
                  </Space>
                </div>
                <Table
                  columns={videoColumns}
                  dataSource={videoList}
                  rowKey="id"
                  rowSelection={rowSelection}
                  pagination={{
                    pageSize: 10,
                    showSizeChanger: true,
                    showQuickJumper: true,
                    showTotal: (total) => `共 ${total} 个视频`
                  }}
                  scroll={{ x: 1000 }}
                  size="middle"
                />
              </Card>
            </div>
          </TabPane>

          {/* 话术通关标签页 */}
          <TabPane tab="话术通关" key="scripts" icon={<MessageOutlined />}>
            <div className="scripts-content">
              <Alert
                message="AI话术通关系统"
                description="包含场景模拟训练、性格色彩成交话术和常见问题话术。支持语音练习和智能评分。"
                type="info"
                showIcon
                style={{ marginBottom: 16 }}
              />

              {/* 话术分类导航 */}
              <Card className="scripts-nav-card">
                <div className="scripts-nav">
                  {Object.values(ContentCategory).map(category => (
                    <div key={category} className="nav-item">
                      {getCategoryTag(category)}
                      <Badge count={5} style={{ backgroundColor: 'var(--primary-color)', marginLeft: 8 }} />
                    </div>
                  ))}
                </div>
              </Card>

              {/* 话术列表 */}
              <Card className="scripts-table-card">
                <div className="table-header">
                  <Title level={4}>话术内容管理</Title>
                  <Space>
                    <Text type="secondary">共 {scriptList.length} 条话术</Text>
                    <Button icon={<PlusOutlined />} type="primary">
                      添加话术
                    </Button>
                  </Space>
                </div>
                <Table
                  columns={scriptColumns}
                  dataSource={scriptList}
                  rowKey="id"
                  rowSelection={rowSelection}
                  pagination={{
                    pageSize: 10,
                    showSizeChanger: true,
                    showQuickJumper: true,
                    showTotal: (total) => `共 ${total} 条话术`
                  }}
                  scroll={{ x: 1000 }}
                  size="middle"
                />
              </Card>

              {/* 话术练习推荐 */}
              <Card className="scripts-recommend-card" title="推荐练习">
                <Row gutter={16}>
                  {scriptList.slice(0, 3).map((script, index) => (
                    <Col xs={24} md={8} key={index}>
                      <Card
                        className="script-practice-card"
                        actions={[
                          <Button 
                            key="practice" 
                            type="primary" 
                            icon={<RobotOutlined />}
                            onClick={() => handlePracticeScript(script)}
                          >
                            AI练习
                          </Button>,
                          <Button key="view" icon={<EyeOutlined />}>
                            查看详情
                          </Button>
                        ]}
                      >
                        <div className="script-practice-header">
                          <MessageOutlined className="script-icon" />
                          <div className="script-practice-title">
                            <Text strong>{script.title}</Text>
                            <Text type="secondary">{script.description}</Text>
                          </div>
                        </div>
                        <div className="script-practice-stats">
                          <Row gutter={8}>
                            <Col span={12}>
                              <Statistic title="使用次数" value={script.usageCount} />
                            </Col>
                            <Col span={12}>
                              <Statistic title="成功率" value={script.successRate} suffix="%" />
                            </Col>
                          </Row>
                        </div>
                        <div className="script-practice-tags">
                          {script.tags.map((tag, idx) => (
                            <Tag key={idx} size="small">{tag}</Tag>
                          ))}
                        </div>
                      </Card>
                    </Col>
                  ))}
                </Row>
              </Card>
            </div>
          </TabPane>

          {/* 学习书籍标签页 */}
          <TabPane tab="学习书籍" key="books" icon={<FileTextOutlined />}>
            <div className="books-content">
              <Alert
                message="电子书学习资源"
                description="代理商推荐阅读的电子书资源，支持在线阅读和下载学习。"
                type="info"
                showIcon
                style={{ marginBottom: 16 }}
              />

              {/* 筛选和搜索区域 */}
              <Card className="filter-card">
                <Row gutter={16} align="middle">
                  <Col flex="auto">
                    <Search
                      placeholder="搜索书籍标题、作者、描述..."
                      allowClear
                      enterButton={<SearchOutlined />}
                      size="large"
                      style={{ maxWidth: 400 }}
                    />
                  </Col>
                  <Col>
                    <Space>
                      <Select defaultValue="all" style={{ width: 120 }}>
                        <Option value="all">全部分类</Option>
                        {Object.values(ContentCategory).map(category => (
                          <Option key={category} value={category}>
                            {categoryConfig[category].name}
                          </Option>
                        ))}
                      </Select>
                      <Select defaultValue="published" style={{ width: 120 }}>
                        <Option value="published">已发布</Option>
                        <Option value="draft">草稿</Option>
                        <Option value="all">全部状态</Option>
                      </Select>
                      <Button 
                        type="primary" 
                        icon={<CloudDownloadOutlined />}
                        onClick={() => setShowEbookUpload(true)}
                      >
                        上传电子书
                      </Button>
                    </Space>
                  </Col>
                </Row>
              </Card>

              {/* 批量操作栏 */}
              {selectedRowKeys.length > 0 && (
                <div className="batch-action-bar">
                  <Space>
                    <Text>已选择 {selectedRowKeys.length} 本电子书</Text>
                    <Button size="small" onClick={() => setSelectedRowKeys([])}>
                      取消选择
                    </Button>
                    <Button
                      size="small"
                      icon={<CheckCircleOutlined />}
                      onClick={() => handleBatchAction('publish')}
                    >
                      批量发布
                    </Button>
                    <Button
                      size="small"
                      icon={<DownloadOutlined />}
                      onClick={() => handleBatchAction('export')}
                    >
                      批量导出
                    </Button>
                    <Button
                      size="small"
                      icon={<DeleteOutlined />}
                      danger
                      onClick={() => handleBatchAction('delete')}
                    >
                      批量删除
                    </Button>
                  </Space>
                </div>
              )}

              {/* 电子书列表表格 */}
              <Card className="books-table-card">
                <div className="table-header">
                  <Title level={4}>电子书资源管理</Title>
                  <Space>
                    <Text type="secondary">共 {bookList.length} 本电子书</Text>
                    <Button 
                      icon={<SyncOutlined />} 
                      onClick={() => setBookList([...mockBookData])}
                    >
                      刷新
                    </Button>
                  </Space>
                </div>
                <Table
                  columns={bookColumns}
                  dataSource={bookList}
                  rowKey="id"
                  rowSelection={rowSelection}
                  pagination={{
                    pageSize: 10,
                    showSizeChanger: true,
                    showQuickJumper: true,
                    showTotal: (total) => `共 ${total} 本电子书`
                  }}
                  scroll={{ x: 1200 }}
                  size="middle"
                />
              </Card>

              {/* 电子书统计 */}
              <Card className="books-stats-card" title="电子书统计">
                <Row gutter={16}>
                  <Col span={6}>
                    <Statistic
                      title="总电子书数"
                      value={bookList.length}
                      valueStyle={{ color: 'var(--primary-color)' }}
                    />
                  </Col>
                  <Col span={6}>
                    <Statistic
                      title="总下载量"
                      value={bookList.reduce((sum, book) => sum + book.downloadCount, 0)}
                      valueStyle={{ color: 'var(--success-color)' }}
                    />
                  </Col>
                  <Col span={6}>
                    <Statistic
                      title="平均评分"
                      value={bookList.length > 0 ? (bookList.reduce((sum, book) => sum + book.rating, 0) / bookList.length).toFixed(1) : 0}
                      suffix="/5"
                      valueStyle={{ color: 'var(--warning-color)' }}
                    />
                  </Col>
                  <Col span={6}>
                    <Statistic
                      title="总文件大小"
                      value={bookList.reduce((sum, book) => sum + book.fileSize, 0).toFixed(1)}
                      suffix="MB"
                      valueStyle={{ color: 'var(--processing-color)' }}
                    />
                  </Col>
                </Row>
              </Card>
            </div>
          </TabPane>

          {/* 行动日志标签页 */}
          <TabPane tab="行动日志" key="actionLogs" icon={<HistoryOutlined />}>
            <div className="action-logs-content">
              <Alert
                message="行动日志系统"
                description="记录代理商的行动轨迹，追踪目标进度，提供个性化的成长建议。"
                type="warning"
                showIcon
                style={{ marginBottom: 16 }}
              />
              
              <Row gutter={16}>
                <Col xs={24}>
                  <Card className="action-logs-card" title="目标进度追踪">
                    {[
                      { title: '本月销售目标', target: 50000, current: 32000, unit: '元', progress: 64 },
                      { title: '团队发展目标', target: 2, current: 1, unit: '人', progress: 50 },
                      { title: '学习目标', target: 3, current: 2, unit: '个', progress: 67 },
                      { title: '话术练习目标', target: 10, current: 8, unit: '个', progress: 80 },
                    ].map((goal, index) => (
                      <div key={index} className="goal-item">
                        <div className="goal-header">
                          <div>
                            <Text strong>{goal.title}</Text>
                            <div style={{ fontSize: 12, color: 'var(--text-tertiary)' }}>
                              目标: {goal.target.toLocaleString()} {goal.unit} | 当前: {goal.current.toLocaleString()} {goal.unit}
                            </div>
                          </div>
                          <Text strong style={{ color: goal.progress >= 80 ? 'var(--success-color)' : goal.progress >= 50 ? 'var(--warning-color)' : 'var(--error-color)' }}>
                            {goal.progress}%
                          </Text>
                        </div>
                        <Progress 
                          percent={goal.progress} 
                          strokeColor={goal.progress >= 80 ? '#52c41a' : goal.progress >= 50 ? '#faad14' : '#ff4d4f'}
                        />
                      </div>
                    ))}
                  </Card>
                </Col>
              </Row>

              <Row gutter={16} style={{ marginTop: 16 }}>
                <Col xs={24} md={12}>
                  <Card className="action-logs-card" title="近期学习记录">
                    <Timeline>
                      <Timeline.Item color="green">完成了"销售心理学"学习 (2026-03-25)</Timeline.Item>
                      <Timeline.Item color="green">练习了"价格异议处理话术" (2026-03-24)</Timeline.Item>
                      <Timeline.Item color="blue">观看了"高效沟通技巧"视频 (2026-03-23)</Timeline.Item>
                      <Timeline.Item color="blue">通过了"产品知识"测试 (2026-03-22)</Timeline.Item>
                      <Timeline.Item color="gray">加入了"团队管理"课程 (2026-03-21)</Timeline.Item>
                    </Timeline>
                  </Card>
                </Col>
                <Col xs={24} md={12}>
                  <Card className="action-logs-card" title="学习建议">
                    <List
                      dataSource={[
                        '建议加强"客户服务"相关内容的学习',
                        '尝试挑战更高级别的话术练习',
                        '观看"新媒体营销策略"视频提升推广能力',
                        '参与团队管理课程，提升领导力',
                        '完成"自我提升"类书籍阅读'
                      ]}
                      renderItem={(item) => (
                        <List.Item>
                          <BulbOutlined style={{ color: 'var(--warning-color)', marginRight: 8 }} />
                          <Text>{item}</Text>
                        </List.Item>
                      )}
                    />
                  </Card>
                </Col>
              </Row>
            </div>
          </TabPane>
        </Tabs>
      </Card>

      {/* 内容详情模态框 */}
      {renderContentDetail()}

      {/* AI话术练习模态框 */}
      {renderScriptPractice()}

      {/* 添加内容模态框 */}
      {renderAddContent()}

      {/* 电子书上传模态框 - 暂时禁用 */}
      {/* {renderEbookUploadModal()} */}
    </div>
  );
};

export default SchoolManagementNew;