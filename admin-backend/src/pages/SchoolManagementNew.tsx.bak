  // 处理编辑视频
  const handleEditVideo = (record: any) => {
    message.info(`编辑视频 ${record.title}`);
  };

  // 处理切换发布状态
  const handleTogglePublish = (record: any) => {
    const newStatus = record.status === ContentStatus.PUBLISHED ? ContentStatus.DRAFT : ContentStatus.PUBLISHED;
    message.success(`视频 ${record.title} 已${newStatus === ContentStatus.PUBLISHED ? '发布' : '取消发布'}`);
  };

  // 处理删除视频
  const handleDeleteVideo = (record: any) => {
    Modal.confirm({
      title: '删除视频',
