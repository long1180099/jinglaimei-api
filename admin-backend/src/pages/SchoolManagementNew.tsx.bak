            <Button type="text" icon={<MoreOutlined />} />
          </Dropdown>
        </Space>
      )
    }
  ];

  // 话术表格列定义
  const scriptColumns = [
    {
      title: '话术标题',
      key: 'title',
      width: 220,
      render: (record: any) => (
        <div className="script-info-cell">
          <div className="script-icon">
            <MessageOutlined />
          </div>
          <div className="script-details">
            <div className="script-title">{record.title}</div>
            <div className="script-description">{record.description}</div>
            <div className="script-tags">
