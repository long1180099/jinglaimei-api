// 学习内容类型枚举
enum ContentType {
  VIDEO = 'video',
  BOOK = 'book',
  SCRIPT = 'script',
  COURSE = 'course',
  QUIZ = 'quiz'
}

// 难度级别枚举
enum DifficultyLevel {
  BEGINNER = 'beginner',
  INTERMEDIATE = 'intermediate',
  ADVANCED = 'advanced'
}

// 内容状态枚举
enum ContentStatus {
  PUBLISHED = 'published',
  DRAFT = 'draft',
  DISABLED = 'disabled'
}

// 学习内容分类
enum ContentCategory {
  PRODUCT_KNOWLEDGE = 'product_knowledge',
  SALES_SKILLS = 'sales_skills',
  TEAM_MANAGEMENT = 'team_management',
  CUSTOMER_SERVICE = 'customer_service',
  BRAND_CULTURE = 'brand_culture',
  MARKETING = 'marketing',
  SELF_DEVELOPMENT = 'self_development'
}

