  // 处理下载电子书
  const handleDownloadBook = (record: any) => {
    message.success(`开始下载电子书: ${record.title}`);
    // 模拟下载操作
    setTimeout(() => {
      message.success(`电子书 "${record.title}" 下载完成`);
    }, 1000);
  };

  // 处理预览电子书
  const handlePreviewBook = (record: any) => {
