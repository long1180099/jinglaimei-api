#!/usr/bin/expect -f
set timeout 30
set pwd {@M3^w,uc2JFTHD}
spawn ssh -o StrictHostKeyChecking=no root@118.195.185.6 "echo '=== Error Log ===' && pm2 logs jinglaimei-api --err --lines 10 --nostream 2>&1 && echo '=== Public API Test ===' && curl -s 'http://localhost:4000/api/mp/socratic/academy/public/learning-paths'"
expect "password:"
send "$pwd\r"
expect eof
