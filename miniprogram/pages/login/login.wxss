/* 登录页 v2.0 */
.page {
  min-height: 100vh;
  background: #fff;
  position: relative;
  overflow: hidden;
}

/* ==================== 背景装饰 ==================== */
.login-bg {
  min-height: 100vh;
  background: linear-gradient(180deg, #fff 0%, #fef5f7 40%, #fff 100%);
  position: relative;
}

.deco-circle {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}

.deco-1 {
  width: 500rpx;
  height: 500rpx;
  background: radial-gradient(circle, rgba(233, 69, 96, 0.04) 0%, transparent 70%);
  top: -200rpx;
  right: -150rpx;
}

.deco-2 {
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(233, 69, 96, 0.03) 0%, transparent 70%);
  bottom: -100rpx;
  left: -100rpx;
}

.login-container {
  padding: 0 56rpx;
  position: relative;
  z-index: 1;
}

/* ==================== Logo ==================== */
.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0 70rpx;
}

.logo-ring {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(233, 69, 96, 0.08), rgba(233, 69, 96, 0.02));
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx;
}

.logo-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #e94560 0%, #d63851 50%, #b82e45 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 48rpx rgba(233, 69, 96, 0.25),
              inset 0 2rpx 4rpx rgba(255, 255, 255, 0.2);
}

.logo-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 6rpx;
}

.app-slogan {
  margin-top: var(--space-6);
  font-size: var(--font-sm);
  color: var(--gray-500);
  letter-spacing: 6rpx;
}

/* ==================== 表单 ==================== */
.form-title {
  font-size: var(--font-3xl);
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: var(--space-2);
}

.form-subtitle {
  font-size: var(--font-sm);
  color: var(--gray-500);
  margin-bottom: var(--space-10);
}

/* ==================== 手机号快捷登录 ==================== */
.btn-wechat {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100rpx;
  background: linear-gradient(135deg, #e94560, #c73e54);
  color: #fff;
  font-size: var(--font-md);
  font-weight: 600;
  border-radius: var(--radius-2xl);
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(233, 69, 96, 0.25);
  letter-spacing: 2rpx;
  margin-bottom: var(--space-8);
}

.btn-wechat::after {
  border: none;
}

.btn-wechat:active {
  transform: scale(0.98);
}

.phone-icon-wrap {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--space-4);
}

.phone-icon {
  font-size: 32rpx;
}

.btn-wechat-silent {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  background: transparent;
  color: var(--gray-500);
  font-size: var(--font-sm);
  font-weight: 400;
  border-radius: var(--radius-2xl);
  border: 2rpx solid var(--gray-200);
  margin-bottom: var(--space-6);
  letter-spacing: 1rpx;
}

.btn-wechat-silent::after {
  border: none;
}

.btn-wechat-silent:active {
  background: var(--gray-100);
}

/* ==================== 分割线 ==================== */
.divider-row {
  display: flex;
  align-items: center;
  margin: var(--space-8) 0;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, var(--gray-200), transparent);
}

.divider-bubble {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--gray-100);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-xs);
  color: var(--gray-500);
  margin: 0 var(--space-6);
  font-weight: 500;
}

/* ==================== 输入框 ==================== */
.input-group {
  display: flex;
  align-items: center;
  height: 104rpx;
  border-bottom: 2rpx solid var(--gray-200);
  margin-bottom: var(--space-4);
  transition: border-color var(--duration-fast);
}

.input-group:focus-within {
  border-bottom-color: var(--primary);
}

.input-icon {
  font-size: var(--font-base);
  color: var(--gray-400);
  margin-right: var(--space-4);
}

.input-group.labeled {
  height: auto;
  flex-direction: column;
  align-items: flex-start;
  padding-bottom: var(--space-4);
  border-bottom: 2rpx solid var(--gray-200);
}

.input-label {
  font-size: var(--font-sm);
  color: var(--gray-600);
  margin-bottom: var(--space-3);
  font-weight: 500;
}

.input-prefix {
  font-size: var(--font-md);
  color: var(--text-primary);
  margin-right: var(--space-5);
  padding-right: var(--space-5);
  border-right: 2rpx solid var(--gray-200);
  font-weight: 500;
}

.input-field {
  flex: 1;
  height: 100%;
  font-size: var(--font-md);
  color: var(--text-primary);
}

.input-group.labeled .input-field {
  height: 72rpx;
}

.btn-sms {
  font-size: var(--font-sm);
  color: var(--primary);
  padding: var(--space-3) var(--space-5);
  white-space: nowrap;
  background: var(--primary-bg);
  border-radius: var(--radius-xl);
  font-weight: 500;
  transition: all var(--duration-fast);
}

.btn-sms.disabled {
  color: var(--gray-400);
  background: var(--gray-100);
}

/* ==================== 登录按钮 ==================== */
.btn-login {
  margin-top: var(--space-10);
  height: 100rpx;
  background: linear-gradient(145deg, var(--primary) 0%, var(--primary-dark) 50%, var(--primary-darker) 100%);
  color: #fff;
  font-size: var(--font-md);
  font-weight: 600;
  border-radius: var(--radius-2xl);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-primary);
  letter-spacing: 2rpx;
}

.btn-login[disabled] {
  background: var(--gray-200);
  color: var(--gray-400);
  box-shadow: none;
}

.btn-login::after {
  border: none;
}

.btn-login:active:not([disabled]) {
  transform: scale(0.98);
}

/* ==================== 暂不登录按钮（满足微信审核要求） ==================== */
.skip-login {
  margin-top: var(--space-6);
  text-align: center;
  padding: 16rpx 0;
}

.skip-text {
  font-size: var(--font-base);
  color: var(--gray-400);
}

.skip-login:active .skip-text {
  color: var(--gray-500);
}

/* ==================== 选择器 ==================== */
.picker-text {
  flex: 1;
  font-size: var(--font-md);
  color: var(--text-primary);
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 72rpx;
}

.picker-arrow {
  font-size: 36rpx;
  color: var(--gray-400);
  font-weight: 300;
}

.link-text {
  display: block;
  text-align: center;
  margin-top: var(--space-8);
  font-size: var(--font-base);
  color: var(--gray-500);
}

/* ==================== 邀请码输入区域 ==================== */
.invite-code-section {
  margin-top: var(--space-6);
  padding: 24rpx;
  background: linear-gradient(135deg, #fff7e6 0%, #fffbe6 100%);
  border-radius: var(--radius-xl);
  border: 1px solid #ffe58f;
}

.invite-code-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-4);
}

.invite-code-label {
  display: flex;
  align-items: center;
  font-size: var(--font-sm);
  color: var(--text-primary);
  font-weight: 500;
}

.invite-icon {
  margin-right: 8rpx;
  font-size: 28rpx;
}

.optional-tag {
  display: inline-block;
  margin-left: 12rpx;
  padding: 2rpx 12rpx;
  background: rgba(250, 173, 20, 0.15);
  color: #d48806;
  font-size: 20rpx;
  border-radius: 8rpx;
  font-weight: normal;
}

.invite-hint {
  padding: 4rpx 0;
}

.hint-text {
  font-size: 22rpx;
  color: #d48806;
  text-decoration: underline;
}

.invite-code-section .input-group {
  border-bottom-color: #ffd591;
  margin-bottom: 0;
}

.invite-check-result {
  margin-top: 12rpx;
  padding: 10rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.invite-check-result.valid {
  background: #f6ffed;
  border: 1px solid #b7eb8f;
  color: #389e0d;
}

.invite-check-result.invalid {
  background: #fff2f0;
  border: 1px solid #ffccc7;
  color: #cf1322;
}
.agreement {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 80rpx;
  padding-bottom: 60rpx;
  flex-wrap: wrap;
}

.agreement-checkbox {
  width: 36rpx;
  height: 36rpx;
  border-radius: 8rpx;
  border: 2rpx solid var(--gray-300);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--space-2);
  font-size: 20rpx;
  color: #fff;
  transition: all var(--duration-fast);
  flex-shrink: 0;
}

.agreement-checkbox.checked {
  background: var(--primary);
  border-color: var(--primary);
}

.agreement-check-icon {
  width: 10rpx;
  height: 18rpx;
  border: 3rpx solid #fff;
  border-top: none;
  border-left: none;
  transform: rotate(45deg);
  margin-bottom: 4rpx;
}

.agreement-text {
  font-size: var(--font-xs);
  color: var(--gray-500);
}

.agreement-link {
  font-size: var(--font-xs);
  color: var(--primary);
}

/* 自定义隐私协议确认弹窗 */
.privacy-confirm-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.privacy-confirm-dialog {
  width: 560rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx 36rpx;
}

.privacy-confirm-title {
  font-size: 34rpx;
  font-weight: bold;
  text-align: center;
  color: #333;
  margin-bottom: 24rpx;
}

.privacy-confirm-content {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.privacy-confirm-links {
  text-align: center;
  margin-bottom: 36rpx;
  font-size: 26rpx;
}

.privacy-confirm-links text {
  margin: 0 8rpx;
}

.privacy-confirm-btns {
  display: flex;
  border-top: 1rpx solid #eee;
}

.privacy-confirm-cancel {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 30rpx;
  color: #999;
  border-right: 1rpx solid #eee;
}

.privacy-confirm-ok {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 30rpx;
  color: var(--primary);
  font-weight: bold;
}
