/* 学习积分页面样式 */
.page {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 40rpx;
}

/* 顶部信息卡 */
.points-header {
  padding: 30rpx;
}

.points-card {
  background: linear-gradient(135deg, #e94560, #c23a51);
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  color: #fff;
  box-shadow: 0 8rpx 32rpx rgba(233, 69, 96, 0.3);
}

.points-main {
  display: flex;
  flex-direction: column;
}

.points-num {
  font-size: 72rpx;
  font-weight: bold;
  line-height: 1.1;
}

.points-label {
  font-size: 26rpx;
  opacity: 0.85;
  margin-top: 4rpx;
}

.level-badge {
  text-align: right;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  padding: 16rpx 28rpx;
}

.level-text {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
}

.level-name {
  font-size: 22rpx;
  opacity: 0.85;
  margin-top: 2rpx;
  display: block;
}

.points-desc {
  text-align: center;
  color: #999;
  font-size: 24rpx;
  margin-top: 20rpx;
}

/* 区块 */
.section {
  margin: 0 30rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  position: relative;
  padding-left: 16rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 4rpx;
  bottom: 4rpx;
  width: 6rpx;
  background: #e94560;
  border-radius: 3rpx;
}

/* 规则列表 */
.rule-list {
  padding: 0;
}

.rule-item {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.rule-item:last-child {
  border-bottom: none;
}

.rule-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  width: 48rpx;
  text-align: center;
}

.rule-text {
  font-size: 27rpx;
  color: #555;
}

/* 等级进度 */
.level-progress {
  padding: 10rpx 0;
}

.progress-bar {
  height: 20rpx;
  background: #eee;
  border-radius: 10rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #e94560, #ff6b81);
  border-radius: 10rpx;
  transition: width 0.3s ease;
}

.progress-info {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}
