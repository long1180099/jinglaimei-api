<!-- 商学院 v4.1 精致简洁版 -->
<view class="page">
  <!-- 顶部Banner -->
  <view class="banner">
    <text class="banner-title">📚 静莱美商学院</text>
    <text class="banner-sub">学习成长，成就更好的自己</text>
    <view class="banner-stats">
      <view class="bs-item">
        <text class="bs-num">{{studyPoints}}</text>
        <text class="bs-label">学习积分</text>
      </view>
      <view class="bs-line"></view>
      <view class="bs-item">
        <text class="bs-num">{{studyDays}}</text>
        <text class="bs-label">学习天数</text>
      </view>
    </view>
  </view>

  <!-- 功能板块列表 -->
  <view class="mod-list">
    <view class="mod-card" wx:for="{{modules}}" wx:key="key"
          bindtap="goModule" data-module="{{item}}">
      <!-- 左侧彩色条 -->
      <view class="mod-bar" style="background:{{item.color}}"></view>
      <view class="mod-icon-box" style="background:{{item.bgColor}}">
        <text class="mod-icon">{{item.icon}}</text>
      </view>
      <view class="mod-body">
        <text class="mod-name">{{item.title}}</text>
        <text class="mod-desc">{{item.desc}}</text>
      </view>
      <text class="mod-arrow" style="color:{{item.color}}">›</text>
    </view>
  </view>

  <!-- 热门课程推荐 -->
  <view class="rec-area">
    <view class="rec-head">
      <text class="rec-tit">🎬 热门课程</text>
      <text class="rec-more" bindtap="goMyCourses">查看全部 ›</text>
    </view>
    <view class="rec-cards">
      <view class="rcard" bindtap="goMyCourses">
        <view class="rc-left" style="background: linear-gradient(135deg,#e94560,#ff6b81)"><text>🎬</text></view>
        <view class="rc-mid"><text class="rc-name">新手入门必看</text><text class="rc-info">7天掌握销售核心技巧</text></view>
        <text class="rc-arrow">›</text>
      </view>
      <view class="rcard" bindtap="goMyCourses">
        <view class="rc-left" style="background: linear-gradient(135deg,#1890ff,#36cfc9)"><text>📈</text></view>
        <view class="rc-mid"><text class="rc-name">朋友圈营销实战</text><text class="rc-info">打造个人品牌，轻松获客</text></view>
        <text class="rc-arrow">›</text>
      </view>
      <view class="rcard" bindtap="goMyCourses">
        <view class="rc-left" style="background: linear-gradient(135deg,#52c41a,#73d13d)"><text>👥</text></view>
        <view class="rc-mid"><text class="rc-name">团队管理与激励</text><text class="rc-info">从个人到团队领袖的蜕变</text></view>
        <text class="rc-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 学习小贴士 -->
  <view class="tips-area">
    <text class="tips-tit">💡 学习小贴士</text>
    <view class="tips-items">
      <view class="tip">
        <text class="tip-n tip-n--1">1</text>
        <text class="tip-txt">每天至少完成一节视频课程，积累学习积分</text>
      </view>
      <view class="tip">
        <text class="tip-n tip-n--2">2</text>
        <text class="tip-txt">坚持记录行动日志，养成每日复盘习惯</text>
      </view>
      <view class="tip">
        <text class="tip-n tip-n--3">3</text>
        <text class="tip-txt">掌握成交话术，提升沟通转化能力</text>
      </view>
    </view>
  </view>

  <!-- 安全底部 -->
  <view style="height: calc(env(safe-area-inset-bottom) + 30rpx);"></view>
</view>
