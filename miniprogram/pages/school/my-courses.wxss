/* 视频学习中心 v3.0 */
.page { display: flex; flex-direction: column; height: 100vh; background: #f5f5f8; }

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 30rpx;
  background: #fff;
  gap: 16rpx;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f5f5f8;
  border-radius: 36rpx;
  padding: 0 24rpx;
  height: 72rpx;
}

.search-input { flex: 1; font-size: 28rpx; height: 72rpx; }
.search-clear { font-size: 28rpx; color: #999; padding: 0 8rpx; }
.search-btn { font-size: 28rpx; color: #e94560; font-weight: 500; white-space: nowrap; }

/* 分类Tab */
.tabs-scroll {
  background: #fff;
  border-bottom: 1rpx solid #eee;
  white-space: nowrap;
}

.tabs {
  display: inline-flex;
  padding: 0 20rpx;
  gap: 8rpx;
}

.tab {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 18rpx 28rpx;
  font-size: 28rpx;
  color: #666;
  position: relative;
  transition: all 0.2s;
}

.tab.active {
  color: #e94560;
  font-weight: 600;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: #e94560;
  border-radius: 3rpx;
}

.tab-icon { font-size: 28rpx; }
.tab-name { font-size: 28rpx; }

/* 课程滚动区域 */
.course-scroll { flex: 1; padding: 20rpx 24rpx; }

.list-info { padding: 10rpx 0 20rpx; }
.list-count { font-size: 24rpx; color: #999; }

/* 课程卡片 */
.course-card {
  display: flex;
  flex-direction: column;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 封面 */
.card-cover {
  position: relative;
  width: 100%;
  height: 360rpx;
  overflow: hidden;
}

.cover-img {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #1a1a2e, #16213e);
}

.cover-badge {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  font-size: 22rpx;
  color: #fff;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.cover-duration {
  position: absolute;
  bottom: 20rpx;
  right: 20rpx;
  font-size: 22rpx;
  color: #fff;
  background: rgba(0, 0, 0, 0.6);
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
}

.play-overlay {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.15);
  opacity: 0;
  transition: opacity 0.2s;
}

.course-card:active .play-overlay { opacity: 1; }

.play-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(233, 69, 96, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  padding-left: 6rpx;
  box-shadow: 0 4rpx 20rpx rgba(233, 69, 96, 0.4);
}

/* 卡片信息 */
.card-body { padding: 24rpx; }

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  display: block;
  line-height: 1.5;
}

.card-subtitle {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 8rpx;
  line-height: 1.4;
}

.card-meta {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 16rpx;
  flex-wrap: wrap;
}

.meta-difficulty { font-size: 22rpx; font-weight: 600; }
.meta-lessons, .meta-views { font-size: 22rpx; color: #999; }
.meta-credits {
  font-size: 22rpx;
  color: #e94560;
  background: rgba(233, 69, 96, 0.08);
  padding: 2rpx 12rpx;
  border-radius: 10rpx;
  font-weight: 500;
}

/* 加载/空状态 */
.loading-more, .no-more { text-align: center; padding: 40rpx 0; }
.loading-text { font-size: 24rpx; color: #999; }
.no-more-text { font-size: 24rpx; color: #ccc; }

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon { font-size: 100rpx; opacity: 0.3; margin-bottom: 24rpx; }
.empty-text { font-size: 30rpx; color: #999; }
.empty-hint { font-size: 24rpx; color: #ccc; margin-top: 8rpx; }

.line-1 { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.line-2 { overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
.safe-bottom { height: env(safe-area-inset-bottom); }
