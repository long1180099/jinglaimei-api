/* 课程详情 - 视频播放 v3.0 */
.page { background: #f5f5f8; min-height: 100vh; padding-bottom: 140rpx; }

/* 视频播放器 */
.video-section { position: relative; }

.video-player {
  width: 100%;
  height: 440rpx;
  background: #000;
}

.current-chapter-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #1a1a2e;
}

.current-chapter-text { font-size: 26rpx; color: #fff; font-weight: 500; flex: 1; }
.current-chapter-arrow { font-size: 22rpx; color: #999; padding-left: 20rpx; }

/* 封面 */
.cover-section { position: relative; }

.course-cover {
  width: 100%;
  height: 400rpx;
  background: linear-gradient(135deg, #1a1a2e, #16213e);
}

.cover-overlay {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
}

.cover-done-badge {
  font-size: 32rpx;
  color: #fff;
  background: #52c41a;
  padding: 16rpx 48rpx;
  border-radius: 40rpx;
  font-weight: 600;
}

/* 章节浮层 */
.chapter-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
}

.chapter-popup {
  position: fixed;
  top: 0;
  right: 0;
  width: 75%;
  max-width: 600rpx;
  height: 100%;
  background: #fff;
  z-index: 201;
  display: flex;
  flex-direction: column;
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.popup-title { font-size: 32rpx; font-weight: 600; color: #1a1a2e; }
.popup-close { font-size: 36rpx; color: #999; padding: 10rpx; }

.popup-list { flex: 1; padding: 16rpx 0; }

.popup-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.popup-item.active { background: rgba(233, 69, 96, 0.05); }

.popup-item-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #f5f5f8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #999;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.popup-item.active .popup-item-icon {
  background: linear-gradient(135deg, #e94560, #b82e45);
  color: #fff;
}

.popup-item-info { flex: 1; }
.popup-item-title { font-size: 28rpx; color: #333; display: block; }
.popup-item-dur { font-size: 22rpx; color: #999; margin-top: 4rpx; display: block; }
.popup-item-status { font-size: 24rpx; color: #52c41a; font-weight: 500; flex-shrink: 0; }

/* 课程信息 */
.info-card {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 2rpx;
}

.info-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
  display: block;
  line-height: 1.5;
}

.info-subtitle {
  font-size: 28rpx;
  color: #999;
  display: block;
  margin-top: 12rpx;
  line-height: 1.5;
}

.info-tags {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 20rpx;
  flex-wrap: wrap;
}

.tag-type { font-size: 22rpx; color: #fff; padding: 6rpx 18rpx; border-radius: 8rpx; font-weight: 500; }
.tag-diff { font-size: 22rpx; color: #1890ff; background: #e6f7ff; padding: 6rpx 14rpx; border-radius: 8rpx; }
.tag-meta { font-size: 22rpx; color: #999; }
.tag-credits { font-size: 22rpx; color: #e94560; background: rgba(233, 69, 96, 0.08); padding: 6rpx 14rpx; border-radius: 8rpx; font-weight: 500; }

/* 进度卡片 */
.progress-card {
  background: #fff;
  padding: 24rpx 30rpx;
  margin-bottom: 2rpx;
}

.progress-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.progress-label { font-size: 28rpx; color: #333; font-weight: 500; }
.progress-percent { font-size: 28rpx; color: #e94560; font-weight: 700; }

.progress-bar-wrap { height: 12rpx; background: #f0f0f0; border-radius: 6rpx; overflow: hidden; }
.progress-bar-fill { height: 100%; border-radius: 6rpx; transition: width 0.3s; }

.progress-detail { font-size: 24rpx; color: #999; margin-top: 12rpx; display: block; }

/* Tab栏 */
.tab-bar {
  display: flex;
  background: #fff;
  margin-top: 2rpx;
  border-bottom: 1rpx solid #eee;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #999;
  position: relative;
}

.tab-item.active {
  color: #e94560;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background: #e94560;
  border-radius: 3rpx;
}

/* 内容区域 */
.section-card {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 2rpx;
}

.intro-content { font-size: 28rpx; color: #666; line-height: 2; }

/* 章节列表 */
.chapter-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.chapter-item:last-child { border-bottom: none; }
.chapter-left { display: flex; align-items: center; flex: 1; }

.chapter-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #f5f5f8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #999;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.chapter-icon.playing {
  background: linear-gradient(135deg, #e94560, #b82e45);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(233, 69, 96, 0.3);
}

.chapter-icon.completed {
  background: #f6ffed;
  color: #52c41a;
  border: 1rpx solid #b7eb8f;
}

.chapter-info { flex: 1; }
.chapter-name { font-size: 28rpx; color: #333; display: block; font-weight: 500; }
.chapter-duration { font-size: 24rpx; color: #999; margin-top: 6rpx; display: block; }

.chapter-status { font-size: 24rpx; font-weight: 500; flex-shrink: 0; margin-left: 16rpx; }
.chapter-status.done { color: #52c41a; }
.chapter-status.playing { color: #e94560; }

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
  gap: 20rpx;
}

.bar-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.collect-btn {
  flex: 0.6;
  background: #fff;
  color: #e94560;
  border: 2rpx solid #e94560;
}

.start-btn {
  background: #e94560;
  color: #fff;
}

.continue-btn {
  background: linear-gradient(135deg, #e94560, #b82e45);
  color: #fff;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
}

.loading-dots { display: flex; gap: 16rpx; margin-bottom: 20rpx; }

.dot {
  width: 16rpx;
  height: 16rpx;
  background: #e94560;
  border-radius: 50%;
  animation: dotPulse 1.2s infinite;
}

.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes dotPulse {
  0%, 80%, 100% { opacity: 0.3; transform: scale(0.8); }
  40% { opacity: 1; transform: scale(1.2); }
}

.loading-text { font-size: 28rpx; color: #999; }
