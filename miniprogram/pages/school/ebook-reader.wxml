<!-- 电子书阅读器 -->
<view class="reader-container">
  <!-- 加载中 -->
  <view class="loading-state" wx:if="{{loading}}">
    <text class="loading-icon">📖</text>
    <text class="loading-text">正在加载...</text>
  </view>

  <!-- 文本阅读 (TXT) -->
  <view class="text-reader" wx:elif="{{bookType == 'text'}}" style="background:{{theme == 'light' ? '#fff' : theme == 'sepia' ? '#f5e6ca' : '#1a1a2e'}}; color:{{theme == 'light' ? '#333' : theme == 'sepia' ? '#5b4636' : '#e0e0e0'}}">
    <!-- 品牌头部 -->
    <view class="reader-brand">
      <text class="brand-name">玫小可</text>
      <text class="brand-divider">|</text>
      <text class="brand-notice">内部学习资料，仅限授权查看</text>
    </view>
    <view class="reader-header">
      <text class="reader-title">{{bookTitle}}</text>
      <text class="reader-author">{{bookAuthor}}</text>
    </view>
    <scroll-view class="reader-scroll" scroll-y scroll-top="{{scrollTop}}" bindscroll="onPageScroll" enhanced show-scrollbar="{{false}}">
      <view class="reader-content" style="font-size:{{fontSize}}rpx; line-height:{{lineHeight}};">
        <text>{{content}}</text>
      </view>
      <view style="height: 200rpx;"></view>
    </scroll-view>

    <!-- 底部工具栏 -->
    <view class="reader-toolbar" style="background:{{theme == 'dark' ? '#16213e' : '#fff'}}; border-top-color:{{theme == 'dark' ? '#2a2a4a' : '#f0f0f0'}}">
      <view class="toolbar-progress">
        <text style="color:{{theme == 'dark' ? '#aaa' : '#999'}}">已读 {{progress}}%</text>
      </view>
      <view class="toolbar-actions">
        <!-- 收藏按钮 -->
        <view class="toolbar-btn" bindtap="toggleFavorite">
          <text>{{isFavorited ? '❤' : '♡'}}</text>
        </view>
        <view class="toolbar-btn" bindtap="toggleThemePicker">
          <text>{{theme == 'light' ? '☀️' : theme == 'sepia' ? '📖' : '🌙'}}</text>
        </view>
        <view class="toolbar-btn" bindtap="toggleSettings">
          <text>⚙</text>
        </view>
      </view>
    </view>

    <!-- 主题选择 -->
    <view class="theme-picker" wx:if="{{showThemePicker}}">
      <view class="theme-option" wx:for="{{themes}}" wx:key="key"
            bindtap="changeTheme" data-theme="{{item.key}}">
        <view class="theme-preview" style="background:{{item.bg}}; border: 2rpx solid {{item.key == theme ? '#e94560' : '#eee'}}">
          <text style="color:{{item.color}}; font-size: 20rpx;">Aa</text>
        </view>
        <text class="theme-label">{{item.label}}</text>
      </view>
    </view>

    <!-- 设置面板 -->
    <view class="settings-panel" wx:if="{{showSettings}}">
      <view class="setting-row">
        <text class="setting-label">字号</text>
        <view class="setting-controls">
          <view class="control-btn" bindtap="changeFontSize" data-delta="-2">A-</view>
          <text class="setting-value">{{fontSize}}</text>
          <view class="control-btn" bindtap="changeFontSize" data-delta="2">A+</view>
        </view>
      </view>
      <view class="setting-row">
        <text class="setting-label">行距</text>
        <view class="setting-controls">
          <view class="control-btn" bindtap="changeLineHeight" data-delta="-0.2">紧</view>
          <text class="setting-value">{{lineHeight}}</text>
          <view class="control-btn" bindtap="changeLineHeight" data-delta="0.2">松</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 文件类型 (PDF/EPUB等) - 自动在线预览 -->
  <view class="file-reader" wx:elif="{{bookType == 'file'}}">
    <!-- 品牌头部 -->
    <view class="file-brand">
      <text class="brand-name">玫小可</text>
      <text class="brand-divider">|</text>
      <text class="brand-notice">内部学习资料，仅限授权查看</text>
    </view>
    <!-- 加载/预览中 -->
    <view class="loading-state" wx:if="{{loading && !openFailed}}">
      <text class="loading-icon">📖</text>
      <text class="loading-text">正在加载{{bookFormat.toUpperCase()}}文档...</text>
      <text class="loading-hint">即将为您在线阅读</text>
    </view>

    <!-- 打开失败时的手动重试界面 -->
    <view class="file-fallback" wx:if="{{openFailed}}">
      <view class="fallback-info">
        <text class="file-icon">📄</text>
        <text class="file-name">{{bookTitle}}</text>
        <text class="file-format">{{bookFormat.toUpperCase()}} 格式</text>
        <text class="error-hint">⚠ 自动预览失败，请尝试手动打开</text>
      </view>
      <view class="file-actions">
        <view class="action-btn primary" bindtap="downloadBook">
          <text>📥 手动打开文档</text>
        </view>
        <view class="action-btn secondary" bindtap="toggleFavorite">
          <text>{{isFavorited ? '❤ 已收藏' : '♡ 收藏'}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
