.page { min-height: 100vh; background: #f5f6fa; }
.disclaimer-bar { display: flex; align-items: center; padding: 16rpx 24rpx; background: #fffbe6; border-bottom: 1rpx solid #ffe58f; font-size: 22rpx; color: #ad6800; }
.disclaimer-bar .icon { margin-right: 10rpx; }

.report-list { padding: 20rpx; display: flex; flex-direction: column; gap: 16rpx; }
.report-card {
  display: flex; align-items: center; background: #fff;
  border-radius: 18rpx; padding: 22rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03); border: 1rpx solid #f0f1f3;
}
.rc-thumb { width: 120rpx; height: 120rpx; border-radius: 14rpx; margin-right: 18rpx; flex-shrink: 0; }
.rc-body { flex: 1; display: flex; flex-direction: column; }
.rc-top { display: flex; align-items: center; gap: 12rpx; margin-bottom: 6rpx; }
.rc-type { font-size: 23rpx; color: #fff; padding: 4rpx 14rpx; border-radius: 10rpx; background: linear-gradient(135deg,#e94560,#c62d47); font-weight: 600; }
.rc-count { font-size: 22rpx; color: #9ca3af; }
.rc-time { font-size: 21rpx; color: #b0b3b8; margin-bottom: 8rpx; }
.rc-severity { display: flex; align-items: center; gap: 8rpx; }
.sev-label { font-size: 19rpx; color: #9ca3af; }
.sev-bar-bg { flex: 1; height: 10rpx; background: #f0f1f3; border-radius: 5rpx; overflow: hidden; }
.sev-bar-fill { height: 100%; background: linear-gradient(90deg,#e94560,#ff6b81); border-radius: 5rpx; transition: width 300ms; }
.sev-val { font-size: 20rpx; font-weight: 700; color: #e94560; }
.rc-arrow { font-size: 32rpx; color: #d1d5db; margin-left: 12rpx; }

.load-more, .no-more { text-align: center; padding: 24rpx; font-size: 24rpx; color: #c0c4cc; }
.empty { display: flex; flex-direction: column; align-items: center; justify-content: center; padding-top: 200rpx; }
.empty-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 30rpx; color: #555d66; font-weight: 500; }
.empty-hint { font-size: 24rpx; color: #b0b3b8; margin-top: 12rpx; }
.btn-go { margin-top: 32rpx; background: linear-gradient(135deg,#e94560,#c62d47); color: #fff; border-radius: 28rpx; }

/* 电子书快捷入口 */
.ebook-entry { padding: 20rpx; margin-top: 8rpx; }
.entry-card {
  display: flex; align-items: center; justify-content: space-between;
  background: linear-gradient(135deg, #f0f4ff, #e8f0fe);
  border-radius: 18rpx; padding: 24rpx;
  border: 1rpx solid #d4e2fc;
}
.entry-left { display: flex; align-items: center; gap: 16rpx; }
.entry-icon { font-size: 44rpx; }
.entry-info { display: flex; flex-direction: column; }
.entry-title { font-size: 26rpx; font-weight: 600; color: #333; }
.entry-desc { font-size: 22rpx; color: #888; margin-top: 4rpx; }
.entry-arrow { font-size: 24rpx; color: #6689d6; white-space: nowrap; }