/* 我的 v3.1 - 精致简洁版 */

.page {
  padding-bottom: env(safe-area-inset-bottom);
  background: #f5f6fa;
  min-height: 100vh;
}

/* ========== 头部 ========== */
.header {
  background: linear-gradient(160deg, #e94560 0%, #c62d47 50%, #a82338 100%);
  padding: 56rpx 32rpx 48rpx;
  position: relative;
}

.header-bg {
  position: absolute;
  width: 400rpx; height: 400rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.03);
  top: -200rpx; right: -100rpx;
  pointer-events: none;
}

.user-row {
  display: flex; align-items: center;
  position: relative; z-index: 1;
}

.avatar {
  width: 120rpx; height: 120rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255,255,255,0.3);
  margin-right: 24rpx;
  flex-shrink: 0;
}

.info-col { flex: 1; }

.name-line { display: flex; align-items: center; gap: 12rpx; }

.name {
  font-size: 36rpx; font-weight: 700;
  color: #fff; letter-spacing: 1rpx;
}

.level {
  font-size: 18rpx; color: #fff;
  padding: 5rpx 16rpx; border-radius: 20rpx;
  font-weight: 500; background: rgba(255,255,255,0.2) !important;
}

.uid {
  font-size: 22rpx; color: rgba(255,255,255,0.45);
  margin-top: 8rpx; display: block;
}

.edit-btn {
  font-size: 24rpx; color: rgba(255,255,255,0.7);
  border: 1rpx solid rgba(255,255,255,0.2);
  padding: 10rpx 28rpx; border-radius: 28rpx;
  background: rgba(255,255,255,0.08); flex-shrink: 0;
}

/* 邀请码 */
.invite-bar {
  margin-top: 28rpx;
  display: flex; align-items: center;
  padding: 22rpx 26rpx;
  background: rgba(255,255,255,0.13);
  border-radius: 16rpx; position: relative; z-index: 1;
}

.invite-icon { font-size: 36rpx; margin-right: 18rpx; }

.invite-middle { flex: 1; display: flex; flex-direction: column; }

.invite-label { font-size: 20rpx; color: rgba(255,255,255,0.5); margin-bottom: 4rpx; }

.invite-code {
  font-size: 30rpx; font-weight: 700; color: #ffd700;
  letter-spacing: 3rpx; font-family: 'SF Mono',monospace;
}

.invite-copy {
  padding: 10rpx 26rpx; background: linear-gradient(135deg,#ffd700,#ffb800);
  color: #8b6914; border-radius: 24rpx; font-size: 22rpx; font-weight: 600;
}

/* ========== 数据概览 ========== */
.stats-row {
  display: flex; align-items: stretch;
  margin: -32rpx 28rpx 20rpx;
  background: #fff; border-radius: 20rpx;
  padding: 30rpx 16rpx;
  box-shadow: 0 8rpx 28rpx rgba(0,0,0,0.06);
  position: relative; z-index: 10;
}

.stat { flex: 1; display: flex; flex-direction: column; align-items: center; }

.stat-n { font-size: 40rpx; font-weight: 800; color: #1a1a2e; }
.stat-n--red { color: #e94560; font-size: 34rpx; }
.stat-l { font-size: 21rpx; color: #b0b3b8; margin-top: 8rpx; }
.stat-split { width: 1rpx; background: #f0f1f3; margin: 12rpx 0; align-self: stretch; }

/* ========== 余额卡片 ========== */
.balance-card {
  display: flex; align-items: center; justify-content: space-between;
  margin: 0 28rpx 24rpx; padding: 28rpx 32rpx;
  background: linear-gradient(135deg, #1a1a2e, #16213e, #0f3460);
  border-radius: 20rpx; box-shadow: 0 8rpx 28rpx rgba(233,69,96,0.12);
}

.bal-left { display: flex; align-items: center; }

.bal-emoji {
  font-size: 36rpx; margin-right: 18rpx;
  width: 68rpx; height: 68rpx;
  display: flex; align-items: center; justify-content: center;
  background: linear-gradient(135deg, #e94560, #ff6b81);
  border-radius: 18rpx; box-shadow: 0 4rpx 14rpx rgba(233,69,96,0.3);
}

.bal-texts { display: flex; flex-direction: column; }

.bal-title { font-size: 25rpx; color: rgba(255,255,255,0.85); font-weight: 600; }
.bal-hint { font-size: 19rpx; color: rgba(255,255,255,0.35); margin-top: 4rpx; }

.bal-right { display: flex; align-items: baseline; }

.bal-amount { font-size: 24rpx; color: #ffd700; font-weight: 400; margin-right: 8rpx; }
.bal-num { font-size: 42rpx; font-weight: 800; text-shadow: 0 2rpx 8rpx rgba(255,215,0,0.2); }
.bal-arrow { font-size: 36rpx; color: rgba(255,255,255,0.2); }

/* ========== 菜单组 ========== */
.menu-group {
  margin: 0 28rpx 20rpx;
  background: #fff; border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.03);
}

.m-item {
  display: flex; align-items: center;
  padding: 28rpx 28rpx;
  border-bottom: 1rpx solid #f7f8fa;
  transition: background 150ms ease;
}

.m-item:last-child { border-bottom: none; }
.m-item:active { background: #fafbfd; }

.m-icon {
  width: 72rpx; height: 72rpx;
  border-radius: 18rpx;
  display: flex; align-items: center; justify-content: center;
  margin-right: 22rpx; flex-shrink: 0;
  font-size: 32rpx;
}

/* 图标配色 - 柔和低饱和度背景 */
.m-icon--orange { background: rgba(255,149,0,0.08); }
.m-icon--blue   { background: rgba(19,194,194,0.09); }
.m-icon--gold   { background: rgba(250,140,22,0.09); }
.m-icon--red    { background: rgba(233,69,96,0.07); }
.m-icon--pink   { background: rgba(233,69,96,0.08); }
.m-icon--rose   { background: rgba(255,107,157,0.10); }
.m-icon--amber  { background: rgba(250,140,22,0.10); }
.m-icon--purple { background: rgba(114,46,209,0.08); }
.m-icon--teal   { background: rgba(19,194,194,0.10); }
.m-icon--gray   { background: rgba(107,114,128,0.08); }
.m-icon--slate  { background: rgba(156,163,175,0.10); }

.m-text { flex: 1; font-size: 29rpx; font-weight: 500; color: #1a1a2e; letter-spacing: 0.5rpx; }
.m-desc { font-size: 21rpx; color: #c0c4cc; margin-left: 12rpx; }
.m-arrow { font-size: 30rpx; color: #d8dce3; font-weight: 300; margin-left: 8rpx; }

/* ========== 退出登录 ========== */
.logout-wrap { padding: 10rpx 28rpx 30rpx; }

.logout-btn {
  text-align: center; padding: 28rpx;
  background: #fff; border-radius: 20rpx;
  font-size: 28rpx; color: #e94560; font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.02);
  letter-spacing: 2rpx;
}

/* ========== 底部备案信息 ========== */
.icp-footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0 10rpx;
}
.icp-footer text {
  font-size: 22rpx;
  color: #ccc;
  line-height: 1.8;
}
