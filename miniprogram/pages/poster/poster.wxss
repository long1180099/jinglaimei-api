/* ==================== AI营销海报生成器 ==================== */

.poster-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  padding: 20rpx;
  padding-bottom: 180rpx;
}

/* 顶部提示 */
.header-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 20rpx;
  background: rgba(255, 215, 0, 0.1);
  border-radius: 40rpx;
  border: 1px solid rgba(255, 215, 0, 0.25);
}
.header-tip text:last-child {
  font-size: 24rpx;
  color: #FFD700;
}
.tip-icon { font-size: 28rpx; }

/* 区块通用 */
.section {
  background: rgba(255, 255, 255, 0.06);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.08);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 20rpx;
  letter-spacing: 2rpx;
}

/* ========== 风格选择 ========== */
.style-scroll { white-space: nowrap; }
.style-list {
  display: inline-flex;
  gap: 16rpx;
  padding: 4rpx 0;
}

.style-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 160rpx;
  padding: 20rpx 12rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 2px solid transparent;
  transition: all 0.3s ease;
}
.style-item.active {
  background: rgba(233, 69, 96, 0.15);
  border-color: #e94560;
  transform: scale(1.05);
  box-shadow: 0 4rpx 20rpx rgba(233, 69, 96, 0.3);
}
.style-preview {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  background: var(--preview);
  margin-bottom: 8rpx;
  box-shadow: inset 0 -2rpx 6rpx rgba(0,0,0,0.15);
}
.style-name {
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
}
.style-desc {
  font-size: 18rpx;
  color: rgba(255,255,255,0.5);
  margin-top: 4rpx;
}

/* ========== 文案选择 ========== */
.quote-tabs {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}
.tab {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  font-size: 26rpx;
  color: rgba(255,255,255,0.5);
  border-radius: 30rpx;
  background: rgba(255,255,255,0.05);
  transition: all 0.3s ease;
  font-weight: 500;
}
.tab.active {
  color: #e94560;
  background: rgba(233, 69, 96, 0.15);
  font-weight: 700;
}

.quote-list { }
.quote-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 18rpx 16rpx;
  margin-bottom: 8rpx;
  border-radius: 12rpx;
  background: rgba(255,255,255,0.03);
  border: 1px solid transparent;
  transition: all 0.2s ease;
}
.quote-item.selected {
  background: rgba(233, 69, 96, 0.1);
  border-color: rgba(233, 69, 96, 0.3);
}
.quote-text {
  font-size: 25rpx;
  color: rgba(255,255,255,0.85);
  line-height: 1.5;
  flex: 1;
  padding-right: 16rpx;
}
.check-icon {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e94560;
  color: #fff;
  border-radius: 50%;
  font-size: 22rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}
.empty-quote {
  text-align: center;
  color: rgba(255,255,255,0.3);
  padding: 40rpx;
  font-size: 26rpx;
}

/* 自定义输入 */
.custom-input-area {
  position: relative;
}
.custom-textarea {
  width: 100%;
  min-height: 160rpx;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 12rpx;
  padding: 20rpx;
  color: #fff;
  font-size: 28rpx;
  box-sizing: border-box;
  line-height: 1.6;
}
.char-count {
  position: absolute;
  bottom: 12rpx;
  right: 20rpx;
  font-size: 22rpx;
  color: rgba(255,255,255,0.35);
}

/* 当前预览卡片 */
.current-preview-card {
  background: linear-gradient(135deg, rgba(233, 69, 96, 0.12), rgba(255, 107, 107, 0.08));
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border: 1px solid rgba(233, 69, 96, 0.2);
}
.preview-label {
  font-size: 22rpx;
  color: #e94560;
  display: block;
  margin-bottom: 8rpx;
  font-weight: 500;
}
.preview-text {
  font-size: 28rpx;
  color: #fff;
  line-height: 1.7;
  display: block;
}

/* ========== 操作按钮 ========== */
.action-bar {
  display: flex;
  gap: 20rpx;
  position: fixed;
  bottom: 40rpx;
  left: 20rpx;
  right: 20rpx;
  z-index: 10;
}

.btn-random,
.btn-generate {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  letter-spacing: 2rpx;
}

.btn-random {
  background: rgba(135, 206, 235, 0.15);
  color: #87CEEB;
  border: 1px solid rgba(135, 206, 235, 0.3);
  flex: 0.85;
}
.btn-random[disabled] { opacity: 0.5; }

.btn-generate {
  background: linear-gradient(135deg, #e94560, #ff6b81);
  color: #fff;
  box-shadow: 0 8rpx 30rpx rgba(233, 69, 96, 0.4);
}
.btn-generate::after { border: none; }
.btn-generate[disabled] { opacity: 0.6; }

/* 按钮动画 */
.btn-generate:not([disabled]):active {
  transform: scale(0.97);
  opacity: 0.9;
}

/* ========== 预览弹窗 ========== */
.preview-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.85);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.preview-content {
  width: 90%;
  max-width: 650rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(60rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.preview-close {
  position: absolute;
  top: -48rpx;
  right: 0;
  width: 56rpx;
  height: 56rpx;
  background: rgba(255,255,255,0.15);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
}

.preview-image {
  width: 100%;
  border-radius: 20rpx;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.5);
}

.preview-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 32rpx;
  width: 100%;
}

.action-btn {
  flex: 1;
  height: 76rpx;
  border-radius: 38rpx;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}
.action-btn::after { border: none; }

.save-btn {
  background: linear-gradient(135deg, #52c41a, #73d13d);
  color: #fff;
}
.share-btn {
  background: linear-gradient(135deg, #1890ff, #40a9ff);
  color: #fff;
}
.retry-btn {
  background: rgba(255,255,255,0.1);
  color: rgba(255,255,255,0.7);
  border: 1px solid rgba(255,255,255,0.2) !important;
}

.preview-hint {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: rgba(255,255,255,0.35);
}
