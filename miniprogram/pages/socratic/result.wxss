/* 苏格拉底式提问训练 - 评分结果 */
.result-page {
  min-height: 100vh;
  background: #0f0f1a;
  padding-bottom: env(safe-area-inset-bottom);
}

.section-title {
  font-size: 30rpx; font-weight: 700; color: #fff; 
  display: block; margin-bottom: 20rpx; margin-top: 10rpx;
}

/* 总分卡片 */
.score-hero {
  text-align: center; padding: 50rpx 40rpx 40rpx;
  border-radius: 0 0 36rpx 36rpx;
}
.grade-badge {
  display: inline-block; padding: 8rpx 28rpx; border-radius: 20rpx;
  font-size: 32rpx; font-weight: 900; margin-bottom: 16rpx;
}
.grade-badge.S { background: linear-gradient(135deg, #ffd700, #ffaa00); color: #333; }
.grade-badge.A { background: linear-gradient(135deg, #667eea, #764ba2); color: #fff; }
.grade-badge.B { background: linear-gradient(135deg, #52c41a, #389e0d); color: #fff; }
.grade-badge.C { background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.7); }
.grade-badge.D { background: rgba(244,67,54,0.15); color: #e57373; }

.score-number {
  display: block; font-size: 96rpx; font-weight: 900;
  background: linear-gradient(135deg, #fff, rgba(255,255,255,0.7));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  line-height: 1.2;
}
.score-label { font-size: 26rpx; color: rgba(255,255,255,0.4); display: block; margin-bottom: 8rpx; }
.score-result { 
  font-size: 30rpx; font-weight: 600; display: block; margin-bottom: 6rpx;
}
.score-result[text*="成交"] { color: #52c41a; }
.score-result[text*="兴趣"] { color: #1890ff; }
.score-result[text*="跟进"] { color: #faad14; }

.score-duration { font-size: 23rpx; color: rgba(255,255,255,0.35); }

/* ====== XP奖励条（AI学院新增）====== */
.xp-reward-bar {
  display: inline-flex; align-items: center; gap: 8rpx;
  margin-top: 16rpx; padding: 10rpx 24rpx;
  background: linear-gradient(135deg, rgba(179,126,235,0.15), rgba(233,69,96,0.1));
  border: 1rpx solid rgba(179,126,235,0.25);
  border-radius: 20rpx;
}
.xp-icon { font-size: 26rpx; }
.xp-text { font-size: 24rpx; font-weight: 600; color: #b37feb; }

/* 升级横幅 */
.level-up-banner {
  position: relative; margin-top: 16rpx;
  padding: 18rpx 30rpx;
  background: linear-gradient(135deg, rgba(255,215,0,0.12), rgba(255,170,0,0.06));
  border-radius: 14rpx; overflow: hidden;
  text-align: center; animation: levelUpPulse 2s ease infinite;
}
.levelup-glow {
  position: absolute; top: -50%; left: -30%;
  width: 160%; height: 200%; background: radial-gradient(circle, rgba(255,215,0,0.08), transparent);
}
.levelup-content { position: relative; display: flex; align-items: center; justify-content: center; gap: 10rpx; }
.levelup-icon { font-size: 32rpx; }
.levelup-text { font-size: 27rpx; font-weight: 800; color: #ffd700; }
@keyframes levelUpPulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.02); }
}

/* 成就解锁弹窗 */
.achievement-popup-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.75); z-index: 2000;
  display: flex; align-items: center; justify-content: center;
}
.achievement-popup {
  width: 85%; max-height: 70vh; background: #1a1a2e;
  border-radius: 24rpx; overflow: hidden;
  display: flex; flex-direction: column;
  animation: popIn 0.4s ease;
}
@keyframes popIn {
  from { transform: scale(0.7); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}
.ap-header {
  padding: 28rpx 30rpx; text-align: center;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
  background: linear-gradient(135deg, rgba(255,215,0,0.05), rgba(179,126,235,0.03));
}
.ap-title { font-size: 32rpx; font-weight: 800; color: #ffd700; display: block; }
.ap-count { font-size: 22rpx; color: rgba(255,255,255,0.45); margin-top: 4rpx; display: block; }
.ap-list { max-height: 50vh; padding: 16rpx 24rpx; }
.ap-item {
  display: flex; align-items: center; gap: 16rpx;
  padding: 18rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.04);
}
.ap-icon-wrap {
  width: 64rpx; height: 64rpx; border-radius: 50%;
  border: 2rpx solid; display: flex; align-items: center; justify-content: center;
}
.ap-icon { font-size: 32rpx; }
.ap-info { flex: 1; }
.ap-name { font-size: 26rpx; font-weight: 700; color: #fff; display: block; margin-bottom: 2rpx; }
.ap-desc { font-size: 22rpx; color: rgba(255,255,255,0.45); display: block; line-height: 1.4; }
.ap-xp { font-size: 22rpx; font-weight: 600; color: #b37feb; white-space: nowrap; }
.ap-close-btn {
  padding: 24rpx; text-align: center;
  border-top: 1rpx solid rgba(255,255,255,0.04);
}
.ap-close-btn text {
  font-size: 28rpx; font-weight: 700; color: #e94560; 
}

/* 雷达图 */
.radar-section { padding: 30rpx 24rpx; }
.radar-canvas {
  width: 100%; height: 400rpx; margin: 0 auto; display: block;
}

/* 五维分数列表 */
.dimension-list { margin-top: 16rpx; }
.dim-item { margin-bottom: 18rpx; }
.dim-header { display: flex; align-items: center; gap: 12rpx; margin-bottom: 8rpx; }
.dim-icon-wrap {
  width: 48rpx; height: 48rpx; border-radius: 12rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 24rpx;
}
.dim-name { flex: 1; font-size: 26rpx; color: rgba(255,255,255,0.75); font-weight: 500; }
.dim-score { font-size: 27rpx; font-weight: 700; }
.dim-bar {
  height: 10rpx; background: rgba(255,255,255,0.06); border-radius: 5rpx; overflow: hidden;
}
.dim-fill { height: 100%; border-radius: 5rpx; transition: width 0.6s ease; }

/* 统计 */
.stats-section { padding: 0 24rpx 20rpx; }
.stats-grid {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 14rpx;
  background: #1a1a2e; border-radius: 18rpx; padding: 24rpx;
}
.stat-item { text-align: center; }
.stat-num { font-size: 40rpx; font-weight: 800; color: #fff; display: block; margin-bottom: 4rpx; }
.stat-label { font-size: 21rpx; color: rgba(255,255,255,0.4); display: block; }

.type-dist-section { margin-top: 20rpx; }
.dist-title { font-size: 25rpx; color: rgba(255,255,255,0.55); display: block; margin-bottom: 12rpx; }
.dist-tags { display: flex; flex-wrap: wrap; gap: 10rpx; }
.dist-tag {
  padding: 8rpx 18rpx; border-radius: 16rpx; font-size: 22rpx; border: 1rpx solid;
}
.dist-empty { font-size: 23rpx; color: rgba(255,255,255,0.3); padding: 10rpx 0; }

/* 最佳提问 */
.best-question-section { padding: 0 24rpx 16rpx; }
.bq-card {
  background: linear-gradient(135deg, rgba(250,173,20,0.08), rgba(114,46,209,0.06));
  border: 1rpx solid rgba(250,173,20,0.15);
  padding: 24rpx; border-radius: 16rpx;
}
.bq-text { 
  font-size: 28rpx; color: #faad14; font-weight: 600; line-height: 1.6;
  display: block; margin-bottom: 10rpx;
}
.bq-label { font-size: 23rpx; color: rgba(255,255,255,0.45); display: block; }

/* 反馈 */
.feedback-section { padding: 0 24rpx 24rpx; }
.feedback-card {
  background: #1a1a2e; padding: 24rpx; border-radius: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.04);
}
.feedback-text { font-size: 26rpx; color: rgba(255,255,255,0.7); line-height: 1.85; white-space: pre-line; }

/* 操作按钮 */
.action-buttons {
  padding: 20rpx 24rpx 30rpx; display: flex; gap: 16rpx; flex-wrap: wrap;
}
.btn-secondary, .btn-primary, .btn-back {
  flex: 1; min-width: 200rpx; text-align: center; padding: 24rpx 0;
  border-radius: 44rpx; font-size: 27rpx; font-weight: 600;
}
.btn-secondary {
  background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.65); border: 1rpx solid rgba(255,255,255,0.08);
}
.btn-primary {
  background: linear-gradient(135deg, #e94560, #c23152); color: #fff;
}
.btn-back {
  width: 100%; flex: none; background: transparent; color: rgba(255,255,255,0.35);
  border: 1rpx dashed rgba(255,255,255,0.1); margin-top: 8rpx;
}

.safe-bottom { height: 60rpx; }
