<!-- 购物车 v2.0 -->
<view class="page">
  <view wx:if="{{cart.length > 0}}">
    <!-- 收货地址 -->
    <view style="display:flex;align-items:center;padding:24rpx 20rpx 20rpx;margin:16rpx 20rpx 0;background:#fff;border-radius:20rpx;border:1rpx solid #f0f1f3;" bindtap="chooseAddress">
      <view style="flex:1;" wx:if="{{address.name}}">
        <view style="display:flex;align-items:center;gap:12rpx;">
          <text style="font-size:30rpx;font-weight:600;color:#1a1a2e;">{{address.name}}</text>
          <text style="font-size:28rpx;color:#97a0af;">{{address.phone}}</text>
        </view>
        <text style="font-size:24rpx;color:#9ca3af;margin-top:8rpx;display:block;line-height:1.4;">{{address.province}}{{address.city}}{{address.district}}{{address.detail}}</text>
      </view>
      <view style="flex:1;display:flex;align-items:center;gap:12rpx;" wx:else>
        <text style="font-size:36rpx;">📍</text>
        <text style="font-size:28rpx;color:#9ca3af;">请添加收货地址</text>
      </view>
      <text style="font-size:36rpx;color:#dfe1e6;margin-left:12rpx;">›</text>
    </view>

    <!-- 全选 -->
    <view class="select-all-bar">
      <view class="checkbox-group" bindtap="toggleSelectAll">
        <view class="checkbox {{allSelected ? 'checked' : ''}}">
          <view class="checkbox-tick" wx:if="{{allSelected}}">✓</view>
        </view>
        <text class="checkbox-label">全选</text>
      </view>
      <text class="edit-btn" bindtap="toggleEdit">{{editing ? '完成' : '管理'}}</text>
      <text class="clear-btn" wx:if="{{editing}}" bindtap="clearCart">清空</text>
    </view>

    <!-- 购物车列表 -->
    <scroll-view class="cart-list" scroll-y>
      <view class="cart-item" wx:for="{{cart}}" wx:key="product_id">
        <view class="checkbox-group" bindtap="toggleItem" data-index="{{index}}">
          <view class="checkbox {{item.selected ? 'checked' : ''}}">
            <view class="checkbox-tick" wx:if="{{item.selected}}">✓</view>
          </view>
        </view>
        <image class="item-img" src="{{item.main_image || '/images/default-product.png'}}" mode="aspectFill" bindtap="goDetail" data-id="{{item.product_id}}"></image>
        <view class="item-info">
          <text class="item-name line-2">{{item.product_name}}</text>
          <view class="item-label-wrap">
            <text class="item-label">{{priceLabel}}</text>
          </view>
          <view class="item-bottom">
            <view class="item-price">
              <text class="price-symbol">¥</text>
              <text class="price-num">{{item.price}}</text>
            </view>
            <view class="quantity-control">
              <view class="qty-btn {{item.quantity <= 1 ? 'disabled' : ''}}" bindtap="changeQty" data-index="{{index}}" data-delta="-1">
                <text>-</text>
              </view>
              <text class="qty-num">{{item.quantity}}</text>
              <view class="qty-btn plus" bindtap="changeQty" data-index="{{index}}" data-delta="1">
                <text>+</text>
              </view>
            </view>
          </view>
        </view>
        <!-- 滑动删除 -->
        <view class="btn-delete" wx:if="{{editing}}" bindtap="removeItem" data-index="{{index}}">
          <text>删除</text>
        </view>
      </view>
    </scroll-view>

    <!-- 底部结算栏 -->
    <view class="cart-bottom safe-bottom">
      <view class="bottom-left">
        <view class="checkbox-group" bindtap="toggleSelectAll">
          <view class="checkbox {{allSelected ? 'checked' : ''}}">
            <view class="checkbox-tick" wx:if="{{allSelected}}">✓</view>
          </view>
        </view>
        <view class="total-info">
          <text class="total-label">合计:</text>
          <text class="total-symbol">¥</text>
          <text class="total-price">{{totalPrice}}</text>
        </view>
      </view>
      <view class="btn-checkout" bindtap="goCheckout">
        <text>结算</text>
        <view class="checkout-badge" wx:if="{{selectedCount > 0}}">{{selectedCount}}</view>
      </view>
    </view>
  </view>

  <!-- 空购物车 -->
  <view class="empty-cart" wx:else>
    <view class="empty-cart-icon">
      <text>🛒</text>
    </view>
    <text class="empty-cart-title">购物车空空如也</text>
    <text class="empty-cart-desc">快去挑选心仪的商品吧</text>
    <view class="btn-go-shop" bindtap="goShopping">去逛逛</view>
  </view>
</view>
