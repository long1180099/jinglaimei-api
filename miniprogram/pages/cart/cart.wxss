/* 购物车 v2.0 */
.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg-page);
}

/* ==================== 收货地址 ==================== */
.address-card {
  display: flex;
  align-items: center;
  padding: var(--space-6);
  margin: var(--space-4) var(--space-5) 0;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-xs);
  border: 1rpx solid var(--border-light);
  position: relative;
}

.address-card:active {
  opacity: 0.8;
}

.address-content {
  flex: 1;
}

.address-header {
  display: flex;
  align-items: center;
  gap: var(--space-3);
}

.address-name {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
}

.address-phone {
  font-size: var(--font-base);
  color: var(--gray-500);
}

.address-detail {
  display: block;
  font-size: var(--font-sm);
  color: var(--text-muted);
  margin-top: var(--space-2);
  line-height: 1.4;
}

.address-empty {
  flex: 1;
  display: flex;
  align-items: center;
  gap: var(--space-3);
}

.empty-icon {
  font-size: 36rpx;
}

.empty-text {
  font-size: var(--font-base);
  color: var(--text-muted);
}

.address-arrow {
  font-size: var(--font-xl);
  color: var(--gray-300);
  margin-left: var(--space-3);
}

/* ==================== 全选栏 ==================== */
.select-all-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-6);
  background: var(--bg-card);
  border-bottom: 1rpx solid var(--border-light);
}

.checkbox-group {
  display: flex;
  align-items: center;
  gap: var(--space-3);
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 3rpx solid var(--gray-300);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--duration-fast) var(--ease-out);
}

.checkbox.checked {
  background: var(--primary);
  border-color: var(--primary);
  box-shadow: 0 2rpx 8rpx rgba(233, 69, 96, 0.25);
}

.checkbox-tick {
  font-size: 24rpx;
  color: #fff;
  font-weight: 700;
}

.checkbox-label {
  font-size: var(--font-base);
  color: var(--gray-700);
  font-weight: 500;
}

.edit-btn {
  font-size: var(--font-base);
  color: var(--primary);
  font-weight: 500;
  padding: var(--space-2) var(--space-4);
}

.clear-btn {
  font-size: var(--font-sm);
  color: var(--primary);
  margin-left: var(--space-4);
  padding: var(--space-2) var(--space-4);
}

/* ==================== 购物车列表 ==================== */
.cart-list {
  flex: 1;
  padding: var(--space-5);
}

.cart-item {
  display: flex;
  align-items: center;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: var(--space-5);
  margin-bottom: var(--space-4);
  position: relative;
  box-shadow: var(--shadow-xs);
  border: 1rpx solid var(--border-light);
  transition: box-shadow var(--duration-fast) var(--ease-out);
}

.cart-item:active {
  box-shadow: var(--shadow-sm);
}

.item-img {
  width: 176rpx;
  height: 176rpx;
  border-radius: var(--radius-sm);
  margin-left: var(--space-4);
  flex-shrink: 0;
  background: var(--gray-50);
}

.item-info {
  flex: 1;
  margin-left: var(--space-4);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 176rpx;
}

.item-name {
  font-size: var(--font-base);
  color: var(--text-primary);
  font-weight: 500;
  display: block;
  line-height: 1.5;
}

.item-label-wrap {
  margin-top: var(--space-2);
}

.item-label {
  font-size: var(--font-xs);
  color: var(--primary);
  background: var(--primary-bg);
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

.item-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: var(--space-3);
}

.item-price {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 22rpx;
  color: var(--primary);
  font-weight: 600;
}

.price-num {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--primary);
}

/* ==================== 数量控制 ==================== */
.quantity-control {
  display: flex;
  align-items: center;
  border: 1rpx solid var(--gray-200);
  border-radius: var(--radius-md);
  overflow: hidden;
  background: var(--gray-50);
}

.qty-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-lg);
  color: var(--gray-600);
  background: transparent;
  transition: all var(--duration-fast) var(--ease-out);
}

.qty-btn:active {
  background: var(--gray-100);
}

.qty-btn.plus {
  color: var(--primary);
  font-weight: 700;
  background: linear-gradient(135deg, rgba(233, 69, 96, 0.08), rgba(233, 69, 96, 0.04));
}

.qty-btn.plus:active {
  background: var(--primary-bg);
  transform: scale(0.9);
}

.qty-btn.disabled {
  color: var(--gray-300);
  pointer-events: none;
}

.qty-num {
  width: 64rpx;
  text-align: center;
  font-size: var(--font-base);
  color: var(--text-primary);
  font-weight: 600;
  border-left: 1rpx solid var(--gray-200);
  border-right: 1rpx solid var(--gray-200);
  height: 60rpx;
  line-height: 60rpx;
}

/* ==================== 删除按钮 ==================== */
.btn-delete {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 100rpx;
  background: linear-gradient(135deg, var(--danger), #ff6b6b);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 var(--radius-lg) var(--radius-lg) 0;
  color: #fff;
  font-size: var(--font-sm);
  font-weight: 500;
}

/* ==================== 底部结算 ==================== */
.cart-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-5) var(--space-6);
  padding-bottom: calc(var(--space-5) + env(safe-area-inset-bottom));
  background: var(--bg-card);
  border-top: 1rpx solid var(--border-light);
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.bottom-left {
  display: flex;
  align-items: center;
  gap: var(--space-4);
}

.total-info {
  display: flex;
  align-items: baseline;
}

.total-label {
  font-size: var(--font-base);
  color: var(--gray-700);
}

.total-symbol {
  font-size: 24rpx;
  color: var(--primary);
  font-weight: 600;
}

.total-price {
  font-size: var(--font-2xl);
  font-weight: 700;
  color: var(--primary);
}

.btn-checkout {
  position: relative;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: #fff;
  padding: 0 56rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: var(--radius-2xl);
  font-size: var(--font-md);
  font-weight: 600;
  box-shadow: var(--shadow-primary);
  letter-spacing: 1rpx;
}

.checkout-badge {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  min-width: 36rpx;
  height: 36rpx;
  background: var(--danger);
  color: #fff;
  font-size: var(--font-xs);
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  font-weight: 700;
}

/* ==================== 空购物车 ==================== */
.empty-cart {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-15) 60rpx;
}

.empty-cart-icon {
  width: 200rpx;
  height: 200rpx;
  background: var(--gray-100);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-8);
}

.empty-cart-icon text {
  font-size: 80rpx;
  opacity: 0.6;
}

.empty-cart-title {
  font-size: var(--font-lg);
  color: var(--gray-700);
  font-weight: 600;
  margin-bottom: var(--space-2);
}

.empty-cart-desc {
  font-size: var(--font-sm);
  color: var(--text-muted);
  margin-bottom: var(--space-10);
}

.btn-go-shop {
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: #fff;
  padding: 0 80rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: var(--radius-2xl);
  font-size: var(--font-md);
  font-weight: 600;
  box-shadow: var(--shadow-primary);
  letter-spacing: 1rpx;
}

.line-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
