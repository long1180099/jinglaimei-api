/* pages/ai-training/scripts.wxss */
.container { min-height: 100vh; background: #0f0f1a; padding-bottom: 40rpx; }

.category-scroll { white-space: nowrap; padding: 20rpx 0; }
.categories { display: inline-flex; padding: 0 20rpx; gap: 12rpx; }
.cat-item {
  display: inline-block; padding: 14rpx 28rpx; border-radius: 30rpx;
  background: #1a1a2e; font-size: 26rpx; color: rgba(255,255,255,0.5);
  white-space: nowrap;
}
.cat-item.active { background: #e94560; color: #fff; font-weight: 600; }

.personality-filter {
  display: flex; padding: 10rpx 30rpx 20rpx; gap: 12rpx; flex-wrap: wrap;
}
.pf-item {
  padding: 8rpx 20rpx; border-radius: 20rpx; font-size: 22rpx;
  background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.5);
}
.pf-item.active { background: rgba(233,69,96,0.2); color: #e94560; }

.script-list { padding: 0 30rpx; }
.script-card {
  background: #1a1a2e; border-radius: 16rpx; margin-bottom: 16rpx;
  overflow: hidden; border: 2rpx solid rgba(255,255,255,0.06);
}
.script-header {
  display: flex; justify-content: space-between; align-items: center;
  padding: 24rpx; cursor: pointer;
}
.script-scenario { font-size: 28rpx; color: #fff; font-weight: 500; }
.script-personality {
  font-size: 20rpx; padding: 4rpx 14rpx; border-radius: 20rpx;
}
.script-personality.red { background: rgba(233,69,96,0.2); color: #e94560; }
.script-personality.yellow { background: rgba(255,193,7,0.2); color: #ffc107; }
.script-personality.blue { background: rgba(59,130,246,0.2); color: #3b82f6; }
.script-personality.green { background: rgba(0,200,150,0.2); color: #00C896; }

.script-body { max-height: 0; overflow: hidden; transition: max-height 0.3s; }
.script-body.expanded { max-height: 1000rpx; }

.script-content {
  padding: 0 24rpx 24rpx; font-size: 26rpx; color: rgba(255,255,255,0.8);
  line-height: 1.8; border-top: 1rpx solid rgba(255,255,255,0.06); padding-top: 20rpx;
}
.script-tips {
  padding: 0 24rpx 20rpx; font-size: 24rpx; color: rgba(255,193,7,0.8);
  line-height: 1.6;
}
.empty { text-align: center; padding: 100rpx 0; color: rgba(255,255,255,0.3); font-size: 28rpx; }
