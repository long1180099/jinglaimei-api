/* pages/ai-training/rankings.wxss */
.container { min-height: 100vh; background: #0f0f1a; }

.tabs {
  display: flex; background: #1a1a2e; padding: 20rpx 30rpx; gap: 16rpx;
}
.tab {
  flex: 1; text-align: center; padding: 20rpx; border-radius: 16rpx;
  font-size: 28rpx; color: rgba(255,255,255,0.5); background: rgba(255,255,255,0.05);
}
.tab.active {
  background: linear-gradient(135deg, #e94560, #c23152); color: #fff; font-weight: 600;
}

.top-three {
  display: flex; justify-content: center; align-items: flex-end;
  padding: 60rpx 30rpx 40rpx; gap: 20rpx;
}

.top-item {
  display: flex; flex-direction: column; align-items: center;
  width: 200rpx;
}

.top-item.first { order: 2; }
.top-item.second { order: 1; }
.top-item.third { order: 3; }

.medal { font-size: 48rpx; margin-bottom: 10rpx; }

.top-avatar {
  width: 100rpx; height: 100rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 36rpx; font-weight: bold; color: #fff; margin-bottom: 10rpx;
}

.top-item.first .top-avatar {
  background: linear-gradient(135deg, #ffd700, #ffaa00);
  width: 120rpx; height: 120rpx; font-size: 44rpx;
}
.top-item.second .top-avatar { background: linear-gradient(135deg, #c0c0c0, #a0a0a0); }
.top-item.third .top-avatar { background: linear-gradient(135deg, #cd7f32, #a0622e); }

.top-name {
  font-size: 26rpx; color: #fff; margin-bottom: 6rpx;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 180rpx;
}
.top-score { font-size: 24rpx; color: rgba(255,255,255,0.5); }

.rank-list { padding: 0 30rpx; }

.rank-item {
  display: flex; align-items: center; padding: 24rpx;
  background: #1a1a2e; border-radius: 16rpx; margin-bottom: 12rpx;
}
.rank-num {
  width: 50rpx; text-align: center; font-size: 28rpx;
  color: rgba(255,255,255,0.4); font-weight: bold;
}
.rank-avatar {
  width: 72rpx; height: 72rpx; border-radius: 50%;
  background: rgba(255,255,255,0.08); display: flex;
  align-items: center; justify-content: center;
  font-size: 28rpx; color: rgba(255,255,255,0.6); margin-right: 20rpx;
}
.rank-info { flex: 1; }
.rank-name { font-size: 28rpx; color: #fff; margin-bottom: 4rpx; }
.rank-detail { font-size: 22rpx; color: rgba(255,255,255,0.35); }
.rank-score {
  font-size: 30rpx; color: #ffd700; font-weight: bold;
}

.empty-state {
  text-align: center; padding: 120rpx 0; color: rgba(255,255,255,0.3);
  font-size: 28rpx;
}
.empty-hint { display: block; font-size: 24rpx; margin-top: 10rpx; }
