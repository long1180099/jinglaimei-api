/* pages/ai-training/session-detail.wxss */
.container { min-height: 100vh; background: #0f0f1a; display: flex; flex-direction: column; }

.messages { flex: 1; padding: 30rpx; }
.message { display: flex; margin-bottom: 24rpx; align-items: flex-start; }
.ai-msg { flex-direction: row; }
.user-msg { flex-direction: row-reverse; }
.avatar {
  width: 64rpx; height: 64rpx; border-radius: 50%; display: flex;
  align-items: center; justify-content: center; font-size: 28rpx; flex-shrink: 0;
}
.ai-avatar { background: #1a1a2e; margin-right: 16rpx; }
.user-avatar {
  background: linear-gradient(135deg, #e94560, #c23152); color: #fff;
  font-size: 22rpx; margin-left: 16rpx;
}
.bubble { max-width: 75%; padding: 20rpx; border-radius: 16rpx; font-size: 26rpx; line-height: 1.7; word-break: break-all; }
.ai-bubble { background: #1a1a2e; color: rgba(255,255,255,0.85); border-top-left-radius: 4rpx; }
.user-bubble { background: linear-gradient(135deg, #e94560, #c23152); color: #fff; border-top-right-radius: 4rpx; }

.result-panel { padding: 30rpx; border-top: 2rpx solid rgba(255,255,255,0.06); }
.result-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.result-title { font-size: 30rpx; color: #fff; font-weight: 600; }
.result-score { font-size: 36rpx; color: #ffd700; font-weight: bold; }
.score-bars { display: flex; flex-direction: column; gap: 14rpx; margin-bottom: 24rpx; }
.score-bar-item { display: flex; align-items: center; gap: 12rpx; }
.bar-label { width: 140rpx; font-size: 22rpx; color: rgba(255,255,255,0.5); flex-shrink: 0; }
.bar-track { flex: 1; height: 10rpx; background: rgba(255,255,255,0.08); border-radius: 5rpx; overflow: hidden; }
.bar-fill { height: 100%; background: linear-gradient(90deg, #e94560, #ff6b81); border-radius: 5rpx; }
.bar-value { width: 50rpx; text-align: right; font-size: 24rpx; color: #fff; font-weight: 600; }
.feedback-summary {
  background: #1a1a2e; border-radius: 16rpx; padding: 24rpx;
  font-size: 26rpx; color: rgba(255,255,255,0.7); line-height: 1.8;
}
