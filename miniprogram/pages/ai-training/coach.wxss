/* pages/ai-training/coach.wxss */
.container {
  min-height: 100vh;
  background: #0f0f1a;
}

/* 场景列表 */
.section-header {
  padding: 40rpx 30rpx 20rpx;
}

.section-title {
  font-size: 38rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-bottom: 8rpx;
}

.section-subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.4);
}

.scenario-list {
  padding: 0 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.scenario-card {
  background: #1a1a2e;
  border-radius: 20rpx;
  padding: 30rpx;
  border: 2rpx solid rgba(255,255,255,0.06);
}

.scenario-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.personality-badge {
  font-size: 22rpx;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

.personality-badge.red { background: rgba(233, 69, 96, 0.2); color: #e94560; }
.personality-badge.yellow { background: rgba(255, 193, 7, 0.2); color: #ffc107; }
.personality-badge.blue { background: rgba(59, 130, 246, 0.2); color: #3b82f6; }
.personality-badge.green { background: rgba(0, 200, 150, 0.2); color: #00C896; }

.difficulty-badge {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  background: rgba(255,255,255,0.08);
  color: rgba(255,255,255,0.5);
}

.scenario-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 10rpx;
}

.scenario-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.5);
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.scenario-stats {
  display: flex;
  gap: 30rpx;
  font-size: 22rpx;
  color: rgba(255,255,255,0.35);
  margin-bottom: 16rpx;
}

.scenario-start {
  background: linear-gradient(135deg, rgba(233, 69, 96, 0.15), rgba(233, 69, 96, 0.05));
  border: 2rpx solid rgba(233, 69, 96, 0.3);
  color: #e94560;
  text-align: center;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.history-entry {
  margin: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: #1a1a2e;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: rgba(255,255,255,0.7);
}

.history-entry .arrow {
  color: rgba(255,255,255,0.3);
}

/* 对话界面 */
.chat-view {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.chat-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #1a1a2e;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}

.chat-scenario-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.chat-personality {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}

.chat-round {
  font-size: 24rpx;
  color: rgba(255,255,255,0.4);
}

.end-btn-small {
  background: rgba(255, 71, 87, 0.2);
  color: #ff4757;
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
}

/* 消息列表 */
.messages {
  flex: 1;
  padding: 20rpx 20rpx 10rpx;
  overflow-y: auto;
}

.message {
  display: flex;
  margin-bottom: 24rpx;
  align-items: flex-start;
}

.ai-message {
  flex-direction: row;
}

.user-message {
  flex-direction: row-reverse;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

.ai-avatar {
  background: #1a1a2e;
  border: 2rpx solid rgba(233, 69, 96, 0.3);
  margin-right: 16rpx;
}

.user-avatar {
  background: linear-gradient(135deg, #e94560, #c23152);
  color: #fff;
  font-size: 24rpx;
  margin-left: 16rpx;
}

.bubble {
  max-width: 75%;
  padding: 24rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.7;
  word-break: break-all;
}

.ai-bubble {
  background: #1a1a2e;
  color: rgba(255,255,255,0.9);
  border-top-left-radius: 4rpx;
}

.user-bubble {
  background: linear-gradient(135deg, #e94560, #c23152);
  color: #fff;
  border-top-right-radius: 4rpx;
}

.bubble-hint {
  margin-top: 16rpx;
  padding: 16rpx;
  background: rgba(255, 193, 7, 0.1);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: rgba(255, 193, 7, 0.9);
  line-height: 1.5;
}

.hint-toggle {
  text-align: center;
  padding: 10rpx;
  font-size: 24rpx;
  color: rgba(255,255,255,0.3);
}

/* 输入区域 */
.input-area {
  padding: 16rpx 20rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #1a1a2e;
  border-top: 1rpx solid rgba(255,255,255,0.06);
}

.input-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.voice-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.msg-input {
  flex: 1;
  height: 80rpx;
  background: rgba(255,255,255,0.06);
  border-radius: 40rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  color: #fff;
}

.send-btn {
  background: rgba(255,255,255,0.08);
  color: rgba(255,255,255,0.4);
  padding: 16rpx 28rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  flex-shrink: 0;
  font-weight: 600;
}

.send-btn.active {
  background: #e94560;
  color: #fff;
}
