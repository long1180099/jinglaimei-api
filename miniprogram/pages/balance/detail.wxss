/* 余额明细页样式 */
page {
  background-color: #f5f6fa;
}

.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* ========== 余额概览卡片 ========== */
.balance-header {
  margin: 20rpx;
  padding: 36rpx 30rpx;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  border-radius: 24rpx;
  color: #fff;
  box-shadow: 0 8rpx 32rpx rgba(26, 26, 46, 0.3);
}

.balance-label {
  font-size: 25rpx;
  opacity: 0.75;
  letter-spacing: 2rpx;
}

.balance-amount {
  font-size: 64rpx;
  font-weight: bold;
  margin-top: 12rpx;
  font-family: 'DIN Alternate', -apple-system, BlinkMacSystemFont, sans-serif;
  text-shadow: 0 4rpx 16rpx rgba(233, 69, 96, 0.3);
}

.balance-hint {
  font-size: 23rpx;
  opacity: 0.5;
  margin-top: 8rpx;
}

/* ========== 筛选Tab ========== */
.filter-tabs {
  display: flex;
  padding: 16rpx 20rpx;
  gap: 14rpx;
  overflow-x: auto;
  white-space: nowrap;
  -webkit-overflow-scrolling: touch;
}

.filter-tab {
  flex-shrink: 0;
  padding: 10rpx 28rpx;
  border-radius: 40rpx;
  font-size: 25rpx;
  color: #666;
  background: #fff;
  transition: all 0.2s;
}

.filter-tab.active {
  color: #fff;
  background: linear-gradient(135deg, #e94560, #c0392b);
  box-shadow: 0 4rpx 12rpx rgba(233, 69, 96, 0.35);
}

/* ========== 明细列表 ========== */
.log-list {
  flex: 1;
  height: calc(100vh - 380rpx);
}

.log-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 16rpx 20rpx;
  padding: 28rpx 24rpx;
  background: #fff;
  border-radius: 18rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.15s ease;
}

.log-item:active {
  transform: scale(0.98);
  background:fafafa;
}

.log-left {
  display: flex;
  align-items: center;
  flex: 1;
  overflow: hidden;
}

.log-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.icon-plus {
  background: rgba(46, 213, 115, 0.12);
}

.icon-minus {
  background: rgba(255, 107, 107, 0.12);
}

.log-info {
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.log-title {
  font-size: 29rpx;
  color: #1a1a2e;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.log-desc {
  font-size: 23rpx;
  color: #999;
  margin-top: 6rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.log-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.log-amount {
  font-size: 31rpx;
  font-weight: 600;
  font-family: 'DIN Alternate', -apple-system, sans-serif;
}

.amount-plus {
  color: #2ed573;
}

.amount-minus {
  color: #ff6b6b;
}

.log-after {
  font-size: 21rpx;
  color: #bbb;
  margin-top: 4rpx;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 120rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #666;
  font-weight: 500;
}

.empty-hint {
  font-size: 25rpx;
  color: #bbb;
  margin-top: 8rpx;
}

/* ========== 加载更多 ========== */
.load-more {
  text-align: center;
  padding: 24rpx 0 48rpx;
}

.load-text {
  font-size: 25rpx;
  color: #ccc;
}

.no-more {
  color: #ddd;
}

/* ========== 骨架屏 ========== */
.loading-skeleton {
  padding: 20rpx;
}

.skeleton-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #fff;
  border-radius: 18rpx;
  margin-bottom: 16rpx;
}

.sk-circle {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: linear-gradient(90deg, #f0f0f0 25%, #e8e8e8 37%, #f0f0f0 63%);
  background-size: 400% 100%;
  animation: shimmer 1.5s infinite;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.sk-lines {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.sk-line {
  height: 26rpx;
  border-radius: 8rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e8e8e8 37%, #f0f0f0 63%);
  background-size: 400% 100%;
  animation: shimmer 1.5s infinite;
}

.sk-line.short {
  width: 60%;
}

.sk-amount {
  width: 120rpx;
  height: 30rpx;
  border-radius: 8rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e8e8e8 37%, #f0f0f0 63%);
  background-size: 400% 100%;
  animation: shimmer 1.5s infinite;
  flex-shrink: 0;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}