/* 订单详情 v2.0 */
.page { background: var(--bg-page); min-height: 100vh; padding-bottom: 140rpx; }

.status-header {
  padding: var(--space-15) var(--space-8);
  color: #fff;
}

.status-text { font-size: var(--font-xl); font-weight: 700; display: block; letter-spacing: 1rpx; }
.status-desc { font-size: var(--font-sm); opacity: 0.75; margin-top: var(--space-3); display: block; }

.address-card {
  margin: -24rpx 28rpx var(--space-5);
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: var(--space-8);
  box-shadow: var(--shadow-md);
  border: 1rpx solid var(--border-light);
  position: relative;
  z-index: 10;
}

.address-name { font-size: var(--font-md); font-weight: 600; color: var(--text-primary); display: block; }
.address-detail { font-size: var(--font-sm); color: var(--gray-600); margin-top: var(--space-3); display: block; line-height: 1.6; }

.section-card {
  margin: 0 28rpx var(--space-5);
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: var(--space-8);
  box-shadow: var(--shadow-xs);
  border: 1rpx solid var(--border-light);
}

.card-title { font-size: var(--font-md); font-weight: 600; color: var(--text-primary); margin-bottom: var(--space-5); }

.goods-item {
  display: flex;
  align-items: flex-start;
  padding: var(--space-4) 0;
  border-bottom: 1rpx solid var(--border-light);
}

.goods-item:last-child { border-bottom: none; }
.goods-img { width: 140rpx; height: 140rpx; border-radius: var(--radius-sm); flex-shrink: 0; background: var(--gray-50); }
.goods-info { flex: 1; margin-left: var(--space-5); }
.goods-name { font-size: var(--font-base); color: var(--text-primary); display: block; line-height: 1.5; }
.goods-spec { font-size: var(--font-xs); color: var(--text-muted); margin-top: var(--space-2); display: block; }
.goods-bottom { display: flex; justify-content: space-between; margin-top: var(--space-3); }
.goods-price { font-size: var(--font-base); color: var(--text-primary); font-weight: 600; }
.goods-qty { font-size: var(--font-sm); color: var(--text-muted); }

.info-row {
  display: flex;
  justify-content: space-between;
  padding: var(--space-4) 0;
  border-bottom: 1rpx solid var(--border-light);
}

.info-row:last-child { border-bottom: none; }
.info-row.total { border-top: 2rpx solid var(--border-light); margin-top: var(--space-3); padding-top: var(--space-6); }
.info-label { font-size: var(--font-sm); color: var(--text-muted); }
.info-value { font-size: var(--font-sm); color: var(--text-primary); }
.info-value.copyable { color: var(--info); font-weight: 500; }
.total-amount { font-size: var(--font-xl); font-weight: 700; color: var(--primary); }

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: flex-end;
  gap: var(--space-4);
  padding: var(--space-5) var(--space-6);
  padding-bottom: calc(var(--space-5) + env(safe-area-inset-bottom));
  background: var(--bg-card);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.action-btn {
  padding: 18rpx 52rpx;
  border-radius: var(--radius-2xl);
  font-size: var(--font-base);
  font-weight: 500;
}

.action-btn.cancel { border: 1rpx solid var(--gray-300); color: var(--gray-600); background: var(--bg-card); }
.action-btn.confirm { background: linear-gradient(135deg, var(--primary), var(--primary-dark)); color: #fff; box-shadow: var(--shadow-primary); }

.line-2 { overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
.loading-state { text-align: center; padding: 200rpx 0; color: var(--text-muted); font-size: var(--font-base); display: flex; flex-direction: column; align-items: center; gap: var(--space-4); }

.loading-dots {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: var(--space-4);
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--gray-400);
  animation: dotPulse 1.2s infinite ease-in-out;
}

.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes dotPulse {
  0%, 80%, 100% { opacity: 0.3; transform: scale(0.8); }
  40% { opacity: 1; transform: scale(1); }
}

.loading-text { color: var(--text-muted); font-size: var(--font-sm); }

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-15) 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: var(--space-4);
  opacity: 0.4;
}

.empty-text {
  font-size: var(--font-base);
  color: var(--text-muted);
}

.empty-hint {
  font-size: var(--font-sm);
  color: var(--text-placeholder);
  margin-top: var(--space-2);
}
