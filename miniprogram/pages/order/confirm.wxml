<!-- 订单确认 -->
<view class="page">
  <!-- 配送方式 -->
  <view class="delivery-card">
    <view class="card-title">配送方式</view>
    <view class="delivery-tabs">
      <view class="delivery-tab {{deliveryType == 'express' ? 'active' : ''}}" bindtap="switchDelivery" data-type="express">
        <text class="tab-icon">🚚</text>
        <text>快递配送</text>
      </view>
      <view class="delivery-tab {{deliveryType == 'pickup' ? 'active' : ''}}" bindtap="switchDelivery" data-type="pickup">
        <text class="tab-icon">🏪</text>
        <text>到店自提</text>
      </view>
    </view>
    <!-- 自提提示 -->
    <view class="pickup-info" wx:if="{{deliveryType == 'pickup'}}">
      <text class="pickup-icon">📍</text>
      <text class="pickup-text">自提地址：广东省深圳市福田区静莱美运营中心（下单后客服会联系您确认具体取货时间）</text>
    </view>
  </view>

  <!-- 收货地址（快递时显示） -->
  <view class="address-card" bindtap="chooseAddress" wx:if="{{deliveryType == 'express'}}">
    <view class="address-content" wx:if="{{address.name}}">
      <view class="address-header">
        <text class="address-name">{{address.name}}</text>
        <text class="address-phone">{{address.phone}}</text>
      </view>
      <text class="address-detail">{{address.province}}{{address.city}}{{address.district}}{{address.detail}}</text>
    </view>
    <view class="address-empty" wx:else>
      <text class="empty-text">请填写收货地址</text>
    </view>
    <text class="address-arrow">›</text>
  </view>

  <!-- 商品列表 -->
  <view class="goods-card">
    <view class="card-title">商品清单</view>
    <view class="goods-item" wx:for="{{selectedItems}}" wx:key="product_id">
      <image class="goods-img" src="{{item.main_image || '/images/default-product.png'}}" mode="aspectFill"></image>
      <view class="goods-info">
        <text class="goods-name line-2">{{item.product_name}}</text>
        <text class="goods-label">{{priceLabel}}</text>
        <view class="goods-bottom">
          <text class="goods-price">¥{{item.price}}</text>
          <text class="goods-qty">×{{item.quantity}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 运费（仅快递） -->
  <view class="section-row" wx:if="{{deliveryType == 'express'}}">
    <text class="row-label">运费</text>
    <text class="row-value {{shippingFeeNum == 0 ? 'free' : ''}}">{{shippingFeeNum == 0 ? '免运费' : '¥' + shippingFee}}</text>
  </view>

  <!-- 备注 -->
  <view class="section-row">
    <text class="row-label">订单备注</text>
    <input class="remark-input" placeholder="选填" value="{{remark}}" bindinput="onRemarkInput" />
  </view>

  <!-- 支付方式 -->
  <view class="payment-card">
    <view class="card-title">支付方式</view>
    <view class="payment-option selected">
      <view class="payment-left">
        <text class="payment-icon">💰</text>
        <view class="payment-info">
          <text class="payment-name">余额支付</text>
          <text class="payment-desc">当前余额：¥{{userBalance}}</text>
        </view>
      </view>
      <view class="payment-check">✓</view>
    </view>
    <view class="payment-warn" wx:if="{{insufficientBalance}}">
      <text>⚠️ 余额不足，请联系客服充值</text>
    </view>
  </view>

  <!-- 价格汇总 -->
  <view class="summary-card">
    <view class="summary-row">
      <text>商品金额</text>
      <text>¥{{goodsTotal}}</text>
    </view>
    <view class="summary-row" wx:if="{{deliveryType == 'express'}}">
      <text>运费</text>
      <text>¥{{shippingFee}}</text>
    </view>
    <view class="summary-row total">
      <text>实付金额（余额）</text>
      <text class="total-amount">¥{{totalAmount}}</text>
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-bar">
    <view class="submit-info">
      <text class="submit-label">合计:</text>
      <text class="price-symbol">¥</text>
      <text class="total-price">{{totalAmount}}</text>
    </view>
    <view class="btn-submit {{submitting || insufficientBalance ? 'disabled' : ''}}" bindtap="submitOrder">
      {{insufficientBalance ? '余额不足' : '提交订单'}}
    </view>
  </view>
</view>
