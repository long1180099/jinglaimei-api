.container { padding: 24rpx; min-height: 100vh; background: #f5f5f5; padding-bottom: 120rpx; }
.steps { display: flex; align-items: center; justify-content: center; padding: 30rpx 0; margin-bottom: 20rpx; }
.step-item { display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.step-num { width: 48rpx; height: 48rpx; border-radius: 50%; background: #e0e0e0; color: #999; font-size: 24rpx; display: flex; align-items: center; justify-content: center; }
.step-item.active .step-num { background: #667eea; color: #fff; }
.step-text { font-size: 22rpx; color: #999; }
.step-item.active .step-text { color: #667eea; }
.step-line { width: 80rpx; height: 4rpx; background: #e0e0e0; margin: 0 20rpx; margin-bottom: 32rpx; }
.step-line.active { background: #667eea; }
.selected-agent { display: flex; justify-content: space-between; align-items: center; background: #e3f2fd; padding: 20rpx 24rpx; border-radius: 12rpx; margin-bottom: 20rpx; font-size: 28rpx; color: #1976d2; }
.change-text { font-size: 24rpx; color: #667eea; }
.section { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 20rpx; }
.section-title { font-size: 30rpx; font-weight: 500; color: #333; margin-bottom: 20rpx; }
.form-item { display: flex; align-items: center; border: 1rpx solid #eee; border-radius: 8rpx; padding: 16rpx 20rpx; margin-bottom: 16rpx; }
.label { font-size: 28rpx; color: #666; width: 140rpx; flex-shrink: 0; }
.input { flex: 1; font-size: 28rpx; color: #333; }
.picker-btn { display: flex; justify-content: space-between; align-items: center; padding: 20rpx; border: 1rpx solid #eee; border-radius: 8rpx; font-size: 28rpx; color: #333; }
.placeholder { color: #ccc; }
.arrow { color: #ccc; font-size: 28rpx; }
.picker-modal { position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 100; }
.picker-mask { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); }
.picker-content { position: absolute; bottom: 0; left: 0; right: 0; background: #fff; border-radius: 24rpx 24rpx 0 0; }
.picker-header { display: flex; justify-content: space-between; padding: 24rpx 32rpx; border-bottom: 1rpx solid #f0f0f0; font-size: 32rpx; font-weight: 500; }
.picker-close { color: #999; font-size: 28rpx; }
.picker-list { padding: 0 24rpx; }
.picker-item { display: flex; align-items: center; gap: 16rpx; padding: 20rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.picker-img { width: 64rpx; height: 64rpx; border-radius: 8rpx; }
.picker-info { flex: 1; font-size: 28rpx; }
.search-results { background: #fff; border: 1rpx solid #eee; border-radius: 8rpx; margin-bottom: 16rpx; }
.search-item { display: flex; align-items: center; gap: 12rpx; padding: 16rpx 20rpx; border-bottom: 1rpx solid #f5f5f5; font-size: 26rpx; }
.search-tag { font-size: 20rpx; padding: 2rpx 10rpx; border-radius: 6rpx; }
.user-tag { background: #e3f2fd; color: #1976d2; }
.customer-tag { background: #e8f5e9; color: #43a047; }
.search-phone { color: #999; font-size: 24rpx; margin-left: auto; }
.usage-options { display: flex; flex-wrap: wrap; gap: 12rpx; }
.usage-option { padding: 12rpx 24rpx; background: #f5f5f5; border-radius: 24rpx; font-size: 26rpx; color: #666; border: 2rpx solid transparent; }
.usage-option.active { background: #e3f2fd; color: #1976d2; border-color: #1976d2; }
.subordinate-list { display: flex; flex-direction: column; gap: 12rpx; }
.subordinate-item { display: flex; align-items: center; gap: 16rpx; padding: 20rpx; border: 1rpx solid #eee; border-radius: 12rpx; }
.sub-name { flex: 1; font-size: 28rpx; color: #333; }
.sub-phone { font-size: 26rpx; color: #999; }
.sub-level { font-size: 22rpx; padding: 4rpx 12rpx; border-radius: 8rpx; background: #e3f2fd; color: #1976d2; }
.empty { text-align: center; padding: 40rpx 0; }
.empty-text { font-size: 28rpx; color: #999; }
.submit-section { position: fixed; bottom: 0; left: 0; right: 0; padding: 20rpx 24rpx; background: #fff; box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06); }
.btn-submit { background: linear-gradient(135deg, #667eea, #764ba2); color: #fff; border: none; border-radius: 44rpx; font-size: 30rpx; padding: 20rpx 0; }
.btn-submit[disabled] { opacity: 0.6; }
