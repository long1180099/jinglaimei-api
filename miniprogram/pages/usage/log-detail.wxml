<view class="container" wx:if="{{log}}">
  <view class="section">
    <view class="section-title">顾客信息</view>
    <view class="detail-row">
      <text class="detail-label">顾客姓名</text>
      <text class="detail-value">{{log.customer_name || '-'}}</text>
    </view>
    <view class="detail-row" wx:if="{{log.customer_phone}}">
      <text class="detail-label">手机号</text>
      <text class="detail-value">{{log.customer_phone}}</text>
    </view>
  </view>

  <view class="section">
    <view class="section-title">产品信息</view>
    <view class="detail-row">
      <text class="detail-label">产品名称</text>
      <text class="detail-value">{{log.product_name || '-'}}</text>
    </view>
    <view class="detail-row" wx:if="{{log.trace_code}}">
      <text class="detail-label">溯源码</text>
      <text class="detail-value trace-code-text">{{log.trace_code}}</text>
    </view>
  </view>

  <view class="section">
    <view class="section-title">使用信息</view>
    <view class="detail-row">
      <text class="detail-label">开始使用日期</text>
      <text class="detail-value">{{log.start_date || '-'}}</text>
    </view>
    <view class="detail-row" wx:if="{{log.usage_instructions}}">
      <text class="detail-label">使用说明</text>
      <text class="detail-value">{{log.usage_instructions}}</text>
    </view>
  </view>

  <view class="section">
    <view class="section-title">代理信息</view>
    <view class="detail-row">
      <text class="detail-label">负责代理商</text>
      <text class="detail-value">{{log.agent_name || '-'}}</text>
    </view>
    <view class="detail-row" wx:if="{{log.agent_phone}}">
      <text class="detail-label">代理商手机</text>
      <text class="detail-value">{{log.agent_phone}}</text>
    </view>
    <view class="detail-row">
      <text class="detail-label">录入人</text>
      <text class="detail-value">{{log.created_by_name || '-'}}</text>
    </view>
    <view class="detail-row">
      <text class="detail-label">录入来源</text>
      <view class="source-tag {{log.source_type === 'superior' ? 'superior' : 'self'}}">
        {{log.source_type === 'superior' ? '上级代填' : '自己录入'}}
      </view>
    </view>
    <view class="detail-row">
      <text class="detail-label">录入时间</text>
      <text class="detail-value">{{log.created_at || '-'}}</text>
    </view>
  </view>
</view>

<view class="loading" wx:if="{{!log}}">
  <text>加载中...</text>
</view>
