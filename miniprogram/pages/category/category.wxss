/* 分类页 v2.0 */
.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg-page);
}

/* ==================== 分类Tab ==================== */
.category-tabs {
  background: var(--bg-card);
  white-space: nowrap;
  padding: var(--space-4) 0;
  border-bottom: 1rpx solid var(--border-light);
}

.tabs-inner {
  display: inline-flex;
  padding: 0 var(--space-6);
  gap: var(--space-3);
}

.tab-pill {
  display: inline-flex;
  align-items: center;
  padding: 14rpx 32rpx;
  border-radius: var(--radius-xl);
  font-size: var(--font-sm);
  color: var(--gray-600);
  background: var(--gray-100);
  font-weight: 500;
  transition: all var(--duration-fast) var(--ease-out);
}

.tab-pill.active {
  color: #fff;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(233, 69, 96, 0.2);
}

/* ==================== 搜索排序 ==================== */
.search-sort-wrap {
  background: var(--bg-card);
}

.search-box {
  display: flex;
  align-items: center;
  padding: var(--space-4) var(--space-6);
  gap: var(--space-3);
}

.search-icon {
  font-size: 28rpx;
  color: var(--text-muted);
  font-weight: 300;
}

.search-input {
  flex: 1;
  height: 68rpx;
  background: var(--gray-100);
  border-radius: var(--radius-2xl);
  padding: 0 var(--space-8);
  font-size: var(--font-base);
}

.search-clear {
  width: 40rpx;
  height: 40rpx;
  background: var(--gray-300);
  border-radius: 50%;
  color: #fff;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ==================== 排序栏 ==================== */
.sort-bar {
  display: flex;
  align-items: center;
  padding: 0 var(--space-6);
  border-top: 1rpx solid var(--border-light);
}

.sort-item {
  flex: 1;
  text-align: center;
  padding: var(--space-5) 0;
  font-size: var(--font-sm);
  color: var(--gray-600);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  transition: color var(--duration-fast);
}

.sort-item.active {
  color: var(--primary);
  font-weight: 600;
}

.sort-arrow {
  font-size: 22rpx;
}

.sort-arrows {
  display: flex;
  flex-direction: column;
  line-height: 1;
  gap: 0;
}

.sort-up, .sort-down {
  font-size: 16rpx;
  color: var(--gray-400);
}

.sort-up.active, .sort-down.active {
  color: var(--primary);
}

/* ==================== 商品列表 ==================== */
.product-list {
  flex: 1;
  padding: var(--space-5) var(--space-6);
}

.product-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-5);
}

.product-card {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  overflow: hidden;
  border: 1rpx solid var(--border-light);
  transition: box-shadow var(--duration-normal) var(--ease-out),
              transform var(--duration-fast) var(--ease-out);
}

.product-card:active {
  box-shadow: var(--shadow-md);
  transform: scale(0.98);
}

.product-img-wrap {
  position: relative;
  overflow: hidden;
}

.product-card .product-img {
  width: 100%;
  height: 300rpx;
}

.product-info {
  padding: var(--space-4);
}

.product-name {
  font-size: var(--font-base);
  color: var(--text-primary);
  font-weight: 500;
  display: block;
  line-height: 1.5;
}

.product-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: var(--space-2);
}

.tag {
  font-size: var(--font-xs);
  color: var(--primary);
  background: var(--primary-bg);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

.product-bottom {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-top: var(--space-4);
}

.price-row {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 22rpx;
  color: var(--primary);
  font-weight: 600;
}

.price-num {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--primary);
}

.sales-text {
  font-size: var(--font-xs);
  color: var(--text-muted);
  margin-top: 4rpx;
  display: block;
}

.btn-add-cart {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 300;
  box-shadow: 0 4rpx 12rpx rgba(233, 69, 96, 0.25);
  transition: transform var(--duration-fast) var(--ease-out);
}

.btn-add-cart:active {
  transform: scale(0.85);
}

/* ==================== 列表模式 ==================== */
.list-mode {
  grid-template-columns: 1fr;
}

.product-list-mode {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.product-list-card {
  display: flex;
  background: var(--bg-card);
  border-radius: var(--radius-md);
  overflow: hidden;
  border: 1rpx solid var(--border-light);
  transition: box-shadow var(--duration-fast) var(--ease-out);
}

.product-list-card:active {
  box-shadow: var(--shadow-md);
}

.list-img {
  width: 220rpx;
  height: 220rpx;
  flex-shrink: 0;
}

.list-info {
  flex: 1;
  padding: var(--space-4);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 220rpx;
}

.list-name {
  font-size: var(--font-base);
  color: var(--text-primary);
  font-weight: 500;
}

.list-desc {
  font-size: var(--font-xs);
  color: var(--text-muted);
  margin-top: var(--space-2);
  display: block;
}

.list-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* ==================== 加载 ==================== */
.load-more {
  text-align: center;
  padding: var(--space-8);
  font-size: var(--font-sm);
  color: var(--text-muted);
}

.loading-dots {
  display: flex;
  justify-content: center;
  gap: 12rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--gray-400);
  animation: dotPulse 1.2s infinite ease-in-out;
}

.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes dotPulse {
  0%, 80%, 100% { opacity: 0.3; transform: scale(0.8); }
  40% { opacity: 1; transform: scale(1); }
}

.no-more {
  color: var(--gray-400);
  letter-spacing: 2rpx;
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
  color: var(--gray-400);
  font-size: var(--font-base);
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: var(--space-4);
  opacity: 0.4;
}

.empty-text {
  font-size: var(--font-base);
  color: var(--text-muted);
}

.empty-hint {
  font-size: var(--font-sm);
  color: var(--text-placeholder);
  margin-top: var(--space-2);
}

.line-1 {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.line-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
