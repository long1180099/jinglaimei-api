/* 商品页 - 分类+购物车合并 */
.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg-page);
}

/* ==================== 顶部Tab ==================== */
.top-tabs {
  display: flex;
  background: var(--bg-card);
  border-bottom: 1rpx solid var(--border-light);
  position: relative;
}

.top-tab {
  flex: 1;
  text-align: center;
  padding: var(--space-7) 0;
  font-size: var(--font-md);
  color: var(--gray-500);
  font-weight: 500;
  position: relative;
  transition: color var(--duration-fast);
}

.top-tab.active {
  color: var(--primary);
  font-weight: 600;
}

.top-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: var(--primary);
}

.cart-badge {
  position: absolute;
  top: 10rpx;
  right: calc(50% - 60rpx);
  min-width: 32rpx;
  height: 32rpx;
  background: var(--primary);
  color: #fff;
  font-size: 20rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  font-weight: 700;
}

/* ==================== 分类Tab ==================== */
.category-tabs {
  background: var(--bg-card);
  white-space: nowrap;
  padding: var(--space-4) 0;
  border-bottom: 1rpx solid var(--border-light);
}

.tabs-inner {
  display: inline-flex;
  padding: 0 var(--space-6);
  gap: var(--space-3);
}

.tab-pill {
  display: inline-flex;
  align-items: center;
  padding: 14rpx 32rpx;
  border-radius: var(--radius-xl);
  font-size: var(--font-sm);
  color: var(--gray-600);
  background: var(--gray-100);
  font-weight: 500;
  transition: all var(--duration-fast) var(--ease-out);
}

.tab-pill.active {
  color: #fff;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(233, 69, 96, 0.2);
}

/* ==================== 搜索排序 ==================== */
.search-sort-wrap {
  background: var(--bg-card);
}

.search-box {
  display: flex;
  align-items: center;
  padding: var(--space-4) var(--space-6);
  gap: var(--space-3);
}

.search-icon {
  font-size: 28rpx;
  color: var(--text-muted);
}

.search-input {
  flex: 1;
  height: 68rpx;
  background: var(--gray-100);
  border-radius: var(--radius-2xl);
  padding: 0 var(--space-8);
  font-size: var(--font-base);
}

.search-clear {
  width: 40rpx;
  height: 40rpx;
  background: var(--gray-300);
  border-radius: 50%;
  color: #fff;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.sort-bar {
  display: flex;
  align-items: center;
  padding: 0 var(--space-6);
  border-top: 1rpx solid var(--border-light);
}

.sort-item {
  flex: 1;
  text-align: center;
  padding: var(--space-5) 0;
  font-size: var(--font-sm);
  color: var(--gray-600);
  transition: color var(--duration-fast);
}

.sort-item.active {
  color: var(--primary);
  font-weight: 600;
}

/* ==================== 商品列表 ==================== */
.product-scroll {
  flex: 1;
  padding: var(--space-5) var(--space-6);
}

.product-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-5);
}

.product-card {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  overflow: hidden;
  border: 1rpx solid var(--border-light);
  transition: transform var(--duration-fast) var(--ease-out);
}

.product-card:active {
  transform: scale(0.98);
}

.product-img-wrap {
  position: relative;
  overflow: hidden;
}

.product-card .product-img {
  width: 100%;
  height: 300rpx;
}

.product-info {
  padding: var(--space-4);
}

.product-name {
  font-size: var(--font-base);
  color: var(--text-primary);
  font-weight: 500;
  display: block;
  line-height: 1.5;
}

.product-bottom {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-top: var(--space-4);
}

.price-row {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 22rpx;
  color: var(--primary);
  font-weight: 600;
}

.price-num {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--primary);
}

.sales-text {
  font-size: var(--font-xs);
  color: var(--text-muted);
  margin-top: 4rpx;
  display: block;
}

.btn-add-cart {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 300;
  box-shadow: 0 4rpx 12rpx rgba(233, 69, 96, 0.25);
}

.btn-add-cart:active {
  transform: scale(0.85);
}

/* ==================== 列表模式 ==================== */
.product-list-mode {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.product-list-card {
  display: flex;
  background: var(--bg-card);
  border-radius: var(--radius-md);
  overflow: hidden;
  border: 1rpx solid var(--border-light);
}

.list-img {
  width: 220rpx;
  height: 220rpx;
  flex-shrink: 0;
}

.list-info {
  flex: 1;
  padding: var(--space-4);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 220rpx;
}

.list-name {
  font-size: var(--font-base);
  color: var(--text-primary);
  font-weight: 500;
}

.list-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* ==================== 加载/空 ==================== */
.load-more {
  text-align: center;
  padding: var(--space-8);
  font-size: var(--font-sm);
  color: var(--text-muted);
}

.loading-dots {
  display: flex;
  justify-content: center;
  gap: 12rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--gray-400);
  animation: dotPulse 1.2s infinite ease-in-out;
}

.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes dotPulse {
  0%, 80%, 100% { opacity: 0.3; transform: scale(0.8); }
  40% { opacity: 1; transform: scale(1); }
}

.no-more { color: var(--gray-400); letter-spacing: 2rpx; }

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
  color: var(--gray-400);
}

.empty-icon { font-size: 80rpx; margin-bottom: var(--space-4); opacity: 0.4; }
.empty-text { font-size: var(--font-base); color: var(--text-muted); }

.line-1 { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.line-2 { overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }

/* ==================== 购物车 ==================== */
.select-all-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-6);
  background: var(--bg-card);
  border-bottom: 1rpx solid var(--border-light);
}

.checkbox-group { display: flex; align-items: center; gap: var(--space-3); }

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 3rpx solid var(--gray-300);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--duration-fast);
}

.checkbox.checked {
  background: var(--primary);
  border-color: var(--primary);
}

.checkbox-tick { font-size: 24rpx; color: #fff; font-weight: 700; }
.checkbox-label { font-size: var(--font-base); color: var(--gray-700); font-weight: 500; }
.edit-btn { font-size: var(--font-base); color: var(--primary); font-weight: 500; padding: var(--space-2) var(--space-4); }
.clear-btn { font-size: var(--font-sm); color: var(--primary); margin-left: var(--space-4); }

.cart-list { flex: 1; padding: var(--space-5); }

.cart-item {
  display: flex;
  align-items: center;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: var(--space-5);
  margin-bottom: var(--space-4);
  position: relative;
  box-shadow: var(--shadow-xs);
  border: 1rpx solid var(--border-light);
}

.item-img {
  width: 176rpx;
  height: 176rpx;
  border-radius: var(--radius-sm);
  margin-left: var(--space-4);
  flex-shrink: 0;
  background: var(--gray-50);
}

.item-info {
  flex: 1;
  margin-left: var(--space-4);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 176rpx;
}

.item-name { font-size: var(--font-base); color: var(--text-primary); font-weight: 500; display: block; line-height: 1.5; }

.item-label {
  font-size: var(--font-xs);
  color: var(--primary);
  background: var(--primary-bg);
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  font-weight: 500;
  margin-top: var(--space-2);
}

.item-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: var(--space-3);
}

.item-price { display: flex; align-items: baseline; }

.quantity-control {
  display: flex;
  align-items: center;
  border: 1rpx solid var(--gray-200);
  border-radius: var(--radius-md);
  overflow: hidden;
  background: var(--gray-50);
}

.qty-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-lg);
  color: var(--gray-600);
}

.qty-btn.plus {
  color: var(--primary);
  font-weight: 700;
  background: linear-gradient(135deg, rgba(233, 69, 96, 0.08), rgba(233, 69, 96, 0.04));
}

.qty-btn.disabled { color: var(--gray-300); pointer-events: none; }

.qty-num {
  width: 64rpx;
  text-align: center;
  font-size: var(--font-base);
  color: var(--text-primary);
  font-weight: 600;
  border-left: 1rpx solid var(--gray-200);
  border-right: 1rpx solid var(--gray-200);
  height: 60rpx;
  line-height: 60rpx;
}

.btn-delete {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 100rpx;
  background: linear-gradient(135deg, var(--danger), #ff6b6b);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 var(--radius-lg) var(--radius-lg) 0;
  color: #fff;
  font-size: var(--font-sm);
  font-weight: 500;
}

/* ==================== 底部结算 ==================== */
.cart-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-5) var(--space-6);
  padding-bottom: calc(var(--space-5) + env(safe-area-inset-bottom));
  background: var(--bg-card);
  border-top: 1rpx solid var(--border-light);
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.bottom-left { display: flex; align-items: center; gap: var(--space-4); }
.total-info { display: flex; align-items: baseline; }
.total-label { font-size: var(--font-base); color: var(--gray-700); }
.total-symbol { font-size: 24rpx; color: var(--primary); font-weight: 600; }
.total-price { font-size: var(--font-2xl); font-weight: 700; color: var(--primary); }

.btn-checkout {
  position: relative;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: #fff;
  padding: 0 56rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: var(--radius-2xl);
  font-size: var(--font-md);
  font-weight: 600;
  box-shadow: var(--shadow-primary);
}

.checkout-badge {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  min-width: 36rpx;
  height: 36rpx;
  background: var(--danger);
  color: #fff;
  font-size: var(--font-xs);
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  font-weight: 700;
}

/* ==================== 空购物车 ==================== */
.empty-cart {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-15) 60rpx;
}

.empty-cart-icon {
  width: 200rpx;
  height: 200rpx;
  background: var(--gray-100);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-8);
}

.empty-cart-icon text { font-size: 80rpx; opacity: 0.6; }
.empty-cart-title { font-size: var(--font-lg); color: var(--gray-700); font-weight: 600; margin-bottom: var(--space-2); }
.empty-cart-desc { font-size: var(--font-sm); color: var(--text-muted); margin-bottom: var(--space-10); }

.btn-go-shop {
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: #fff;
  padding: 0 80rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: var(--radius-2xl);
  font-size: var(--font-md);
  font-weight: 600;
  box-shadow: var(--shadow-primary);
}

.safe-bottom {
  padding-bottom: calc(var(--space-5) + env(safe-area-inset-bottom));
}
