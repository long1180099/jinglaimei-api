<!-- 商品页 - 分类+购物车合并 -->
<view class="page">
  <!-- 顶部Tab切换 -->
  <view class="top-tabs">
    <view class="top-tab {{activeTab == 'products' ? 'active' : ''}}" bindtap="switchTab" data-tab="products">
      <text>商品</text>
    </view>
    <view class="top-tab {{activeTab == 'cart' ? 'active' : ''}}" bindtap="switchTab" data-tab="cart">
      <text>购物车</text>
      <view class="cart-badge" wx:if="{{cartCount > 0}}">{{cartCount > 99 ? '99+' : cartCount}}</view>
    </view>
  </view>

  <!-- ======= 商品列表 ======= -->
  <block wx:if="{{activeTab == 'products'}}">
    <!-- 分类Tab -->
    <scroll-view class="category-tabs" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="tabs-inner">
        <view class="tab-pill {{activeCategory == -1 ? 'active' : ''}}" bindtap="switchCategory" data-id="{{-1}}">
          <text>全部</text>
        </view>
        <view class="tab-pill {{activeCategory == item.id ? 'active' : ''}}" wx:for="{{categories}}" wx:key="id" bindtap="switchCategory" data-id="{{item.id}}">
          <text>{{item.name}}</text>
        </view>
      </view>
    </scroll-view>

    <!-- 搜索 + 排序 -->
    <view class="search-sort-wrap">
      <view class="search-box">
        <text class="search-icon">⌕</text>
        <input class="search-input" placeholder="搜索商品名称" value="{{keyword}}" bindinput="onSearchInput" bindconfirm="doSearch" confirm-type="search" />
        <text class="search-clear" wx:if="{{keyword}}" bindtap="clearSearch">✕</text>
      </view>
      <view class="sort-bar">
        <view class="sort-item {{sort == 'default' ? 'active' : ''}}" bindtap="setSort" data-sort="default">综合</view>
        <view class="sort-item {{sort == 'sales' ? 'active' : ''}}" bindtap="setSort" data-sort="sales">销量</view>
        <view class="sort-item {{sort == 'price_asc' || sort == 'price_desc' ? 'active' : ''}}" bindtap="togglePriceSort">价格</view>
        <view class="sort-item" bindtap="toggleView">
          <text>{{viewMode == 'grid' ? '▦' : '☰'}}</text>
        </view>
      </view>
    </view>

    <!-- 商品网格 -->
    <scroll-view class="product-scroll" scroll-y enhanced show-scrollbar="{{false}}" refresher-enabled refresher-triggered="{{refreshing}}" bindrefresherrefresh="onRefresh" type="list">
      <view class="product-grid" wx:if="{{viewMode == 'grid'}}">
        <view class="product-card" wx:for="{{products}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
          <view class="product-img-wrap">
            <image class="product-img" src="{{item.main_image || '/images/default-product.png'}}" mode="aspectFill" lazy-load decode="async"></image>
          </view>
          <view class="product-info">
            <text class="product-name line-2">{{item.product_name}}</text>
            <view class="product-bottom">
              <view>
                <view class="price-row">
                  <text class="price-symbol">¥</text>
                  <text class="price-num">{{item.retail_price}}</text>
                </view>
                <text class="sales-text">已售{{item.sales_count || 0}}</text>
              </view>
              <view class="btn-add-cart" catchtap="addToCart" data-item="{{item}}">
                <text>+</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- 列表模式 -->
      <view class="product-list-mode" wx:if="{{viewMode == 'list'}}">
        <view class="product-list-card" wx:for="{{products}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
          <image class="list-img" src="{{item.main_image || '/images/default-product.png'}}" mode="aspectFill" lazy-load decode="async"></image>
          <view class="list-info">
            <text class="list-name line-2">{{item.product_name}}</text>
            <view class="list-bottom">
              <view class="price-row">
                <text class="price-symbol">¥</text>
                <text class="price-num">{{item.retail_price}}</text>
                <text class="sales-text">已售{{item.sales_count || 0}}</text>
              </view>
              <view class="btn-add-cart" catchtap="addToCart" data-item="{{item}}">
                <text>+</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- 加载更多 -->
      <view class="load-more" wx:if="{{products.length > 0}}">
        <view class="loading-dots" wx:if="{{hasMore}}">
          <view class="dot"></view><view class="dot"></view><view class="dot"></view>
        </view>
        <text wx:else class="no-more">— 已经到底了 —</text>
      </view>

      <view class="empty-state" wx:if="{{products.length == 0 && !loading}}">
        <text class="empty-icon">🔍</text>
        <text class="empty-text">暂无相关商品</text>
      </view>
    </scroll-view>
  </block>

  <!-- ======= 购物车 ======= -->
  <block wx:if="{{activeTab == 'cart'}}">
    <view wx:if="{{cart.length > 0}}">
      <!-- 全选 -->
      <view class="select-all-bar">
        <view class="checkbox-group" bindtap="toggleSelectAll">
          <view class="checkbox {{allSelected ? 'checked' : ''}}">
            <view class="checkbox-tick" wx:if="{{allSelected}}">✓</view>
          </view>
          <text class="checkbox-label">全选</text>
        </view>
        <text class="edit-btn" bindtap="toggleEdit">{{editing ? '完成' : '管理'}}</text>
        <text class="clear-btn" wx:if="{{editing}}" bindtap="clearCart">清空</text>
      </view>

      <!-- 购物车列表 -->
      <scroll-view class="cart-list" scroll-y>
        <view class="cart-item" wx:for="{{cart}}" wx:key="product_id">
          <view class="checkbox-group" bindtap="toggleItem" data-index="{{index}}">
            <view class="checkbox {{item.selected ? 'checked' : ''}}">
              <view class="checkbox-tick" wx:if="{{item.selected}}">✓</view>
            </view>
          </view>
          <image class="item-img" src="{{item.main_image || '/images/default-product.png'}}" mode="aspectFill" bindtap="goDetail" data-id="{{item.product_id}}"></image>
          <view class="item-info">
            <text class="item-name line-2">{{item.product_name}}</text>
            <text class="item-label">{{priceLabel}}</text>
            <view class="item-bottom">
              <view class="item-price">
                <text class="price-symbol">¥</text>
                <text class="price-num">{{item.price}}</text>
              </view>
              <view class="quantity-control">
                <view class="qty-btn {{item.quantity <= 1 ? 'disabled' : ''}}" bindtap="changeQty" data-index="{{index}}" data-delta="-1"><text>-</text></view>
                <text class="qty-num">{{item.quantity}}</text>
                <view class="qty-btn plus" bindtap="changeQty" data-index="{{index}}" data-delta="1"><text>+</text></view>
              </view>
            </view>
          </view>
          <view class="btn-delete" wx:if="{{editing}}" bindtap="removeItem" data-index="{{index}}">
            <text>删除</text>
          </view>
        </view>
      </scroll-view>

      <!-- 底部结算 -->
      <view class="cart-bottom safe-bottom">
        <view class="bottom-left">
          <view class="checkbox-group" bindtap="toggleSelectAll">
            <view class="checkbox {{allSelected ? 'checked' : ''}}">
              <view class="checkbox-tick" wx:if="{{allSelected}}">✓</view>
            </view>
          </view>
          <view class="total-info">
            <text class="total-label">合计:</text>
            <text class="total-symbol">¥</text>
            <text class="total-price">{{totalPrice}}</text>
          </view>
        </view>
        <view class="btn-checkout" bindtap="goCheckout">
          <text>结算</text>
          <view class="checkout-badge" wx:if="{{selectedCount > 0}}">{{selectedCount}}</view>
        </view>
      </view>
    </view>

    <!-- 空购物车 -->
    <view class="empty-cart" wx:else>
      <view class="empty-cart-icon"><text>🛒</text></view>
      <text class="empty-cart-title">购物车空空如也</text>
      <text class="empty-cart-desc">快去挑选心仪的商品吧</text>
      <view class="btn-go-shop" bindtap="switchTab" data-tab="products">去逛逛</view>
    </view>
  </block>
</view>
