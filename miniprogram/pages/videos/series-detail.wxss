/* 系列课详情页 · 玫小可商学院 · Premium */

.sdp { min-height: 100vh; background: #f4f5f9; padding-bottom: 36rpx; }

/* ====== 头部 ====== */
.sd-header { position: relative; }
.sd-cover { width: 100%; height: 400rpx; }
.sd-cover-ph {
  width: 100%; height: 400rpx;
  background: linear-gradient(135deg,#1a1a2e,#2d1b4e 40%,#e94560 220%);
  display: flex; flex-direction: column; align-items: center; justify-content: center;
}
.sd-cover-ph text:first-child { font-size: 76rpx; }
.sd-ph-sub { font-size: 23rpx; color: rgba(255,255,255,.36); margin-top: 10rpx; letter-spacing: 5rpx; }

.sd-overlay {
  position: absolute; left:0; right:0; bottom:0;
  padding: 30rpx 28rpx;
  background: linear-gradient(transparent, rgba(0,0,0,.82));
}
.sd-price-badge {
  display: inline-block; align-self: flex-start;
  background: linear-gradient(135deg,#e94560,#ff6a6b);
  color: #fff; font-size: 24rpx; font-weight: bold;
  padding: 7rpx 20rpx; border-radius: 10rpx;
  margin-bottom: 15rpx; letter-spacing: .5rpx;
  box-shadow: 0 4rpx 14rpx rgba(233,69,96,.32);
}
.sd-price-badge.owned { 
  background: linear-gradient(135deg,#52c41a,#73d13d);
  box-shadow: 0 4rpx 14rpx rgba(82,196,26,.26);
}

.sd-title { color: #fff; font-size: 37rpx; font-weight: bold; line-height: 1.35; margin-bottom: 10rpx; }
.sd-desc { color: rgba(255,255,255,.62); font-size: 24rpx; display: -webkit-box; -webkit-line-clamp: 2; overflow: hidden; margin-bottom: 16rpx; line-height: 1.52; }

.sd-metas { display: flex; gap: 8rpx; flex-wrap: wrap; }
.sd-chip {
  background: rgba(255,255,255,.08);
  padding: 6rpx 15rpx; border-radius: 18rpx;
  border: 1rpx solid rgba(255,255,255,.07);
}
.sd-chip text { color: rgba(255,255,255,.65); font-size: 20rpx; }

/* ====== 购买按钮区 ====== */
.buy-sec { padding: 26rpx 26rpx 18rpx; background: #fff; border-bottom: 1rpx solid #f2f2f2; }
.buy-btn {
  background: linear-gradient(135deg,#e94560,#ff7088) !important;
  color: #fff !important; height: 86rpx !important; line-height: 86rpx !important;
  border-radius: 44rpx !important; font-size: 30rpx !important; font-weight: bold !important;
  box-shadow: 0 8rpx 28rpx rgba(233,69,96,.33) !important; letter-spacing: 1.5rpx !important;
}
.buy-note { display: block; text-align: center; color: #aaa; font-size: 22rpx; margin-top: 12rpx; }

/* ====== 剧集列表 ====== */
.epi-sec { padding: 26rpx 22rpx; }
.epi-hd-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 18rpx; }
.epi-hd-tt { font-size: 32rpx; font-weight: bold; color: #222; }
.epi-hd-cnt { font-size: 25rpx; color: #aaa; }

.ep-item {
  display: flex; align-items: center; background: #fff; padding: 21rpx 18rpx;
  border-radius: 16rpx; margin-bottom: 12rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,.028);
  transition: transform .18s ease;
}
.ep-item:active { transform: scale(.98); }
.ep-item.ep-done {
  background: linear-gradient(135deg,#fafff5,#f6ffed);
  border-left: 4rpx solid #52c41a;
}

/* 集数编号圆圈 */
.ep-num-wrap {
  width: 56rpx; height: 56rpx; border-radius: 50%;
  background: linear-gradient(135deg,#fef0f0,#fff7f7);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; margin-right: 18rpx;
  border: 2rpx solid #ffe4e4;
}
.ep-num-wrap.ep-num-done {
  background: linear-gradient(135deg,#52c41a,#73d13d); border-color: transparent;
}
.ep-idx { font-size: 26rpx; color: #e94560; font-weight: bold; }
.ep-check { color: #fff; font-size: 28rpx; font-weight: bold; }

/* 剧集信息 */
.ep-info-col { flex: 1; overflow: hidden; min-width: 0; }
.ep-name {
  display: block; font-size: 28rpx; color: #222; white-space: nowrap;
  overflow: hidden; text-overflow: ellipsis; font-weight: 500; line-height: 1.35;
}
.ep-bot-row { display: flex; align-items: center; gap: 10rpx; margin-top: 9rpx; flex-wrap: wrap; }
.ep-dur { font-size: 21rpx; color: #aaa; }

.ep-pb { flex: 1; max-width: 124rpx; height: 6rpx; background: #f0f0f0; border-radius: 3rpx; overflow: hidden; }
.ep-pf { height: 100%; background: linear-gradient(90deg,#52c41a,#95de64); border-radius: 3rpx; transition: width .3s; }

.ep-price-txt { font-size: 22rpx; color: #e94560; font-weight: bold; }
.ep-free-txt { font-size: 19rpx; color: #52c41a; background: #f6ffed; padding: 2rpx 11rpx; border-radius: 6rpx; font-weight: 500; }
.ep-pct-txt { font-size: 20rpx; color: #52c41a; font-weight: 600; }
.ep-done-txt { font-size: 20rpx; color: #52c41a; font-weight: 500; }

/* 操作按钮（播放/锁定）*/
.ep-action { margin-left: 12rpx; flex-shrink: 0; }
.ep-play-icon {
  width: 54rpx; height: 54rpx; line-height: 52rpx; text-align: center;
  background: linear-gradient(135deg,#e94560,#ff7088);
  color: #fff; border-radius: 50%; font-size: 23rpx;
  display: block; box-shadow: 0 4rpx 13rpx rgba(233,69,96,.28);
}
.ep-lock { margin-left: 12rpx; flex-shrink: 0; }
.ep-lock-ico { font-size: 29rpx; opacity: .35; }

/* ====== 课程详情卡片 ====== */
.info-sec { margin: 0 22rpx 20rpx; }
.info-sec-tt { font-size: 30rpx; font-weight: bold; color: #222; margin-bottom: 16rpx; padding-left: 6rpx; }

.inf-blk {
  background: #fff; margin-bottom: 12rpx; padding: 20rpx 22rpx;
  border-radius: 15rpx; border-left: 4rpx solid #e94560;
}
.inf-blk:last-child { margin-bottom: 0; border-left-color: #e5e5e5; }
.inf-blk-hd { margin-bottom: 6rpx; }
.inf-lbl { display: block; font-size: 22rpx; color: #999; font-weight: 500; }
.inf-val { font-size: 28rpx; color: #333; font-weight: 500; }
.inf-desc { line-height: 1.68; color: #555; font-size: 26rpx; }
.inf-highlight { color: #e94560; font-weight: bold; font-size: 30rpx !important; }

.diff-row { display: flex; align-items: center; gap: 12rpx; }
.diff-dot {
  width: 16rpx; height: 16rpx; border-radius: 50%; flex-shrink: 0;
}
.diff-beginner { background: #52c41a; }
.diff-elementary { background: #1890ff; }
.diff-intermediate { background: #faad14; }
.diff-advanced { background: #fa8c16; }
.diff-expert { background: #e94560; }

/* ====== 加载状态 ====== */
.load-box {
  display: flex; flex-direction: column; align-items: center;
  padding: 130rpx 0; color: #999; font-size: 27rpx; gap: 14rpx;
}
.lds-ring {
  width: 44rpx; height: 44rpx; border: 4rpx solid #f0f0f0;
  border-top-color: #e94560; border-radius: 50%; animation: spin .75s linear infinite;
}
@keyframes spin { to{transform:rotate(360deg)} }
