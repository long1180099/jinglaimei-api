/* 学习中心页 · 玫小可商学院 · Premium */

.lp { min-height: 100vh; background: #f4f5f9; padding-bottom: 36rpx; }

/* ====== 统计头部 ====== */
.stat-header { padding: 22rpx; }
.stat-card {
  background: linear-gradient(135deg,#e94560 0%,#c0392b 55%,#a92d26 100%);
  border-radius: 26rpx; padding: 32rpx 28rpx 28rpx;
  box-shadow: 0 10rpx 36rpx rgba(233,69,96,.32);
}
.sc-top {
  display: flex; justify-content: space-between; align-items: center; margin-bottom: 26rpx;
}
.sc-greeting {
  color: rgba(255,255,255,.9); font-size: 33rpx; font-weight: bold; letter-spacing: .5rpx;
}
.sc-avatar {
  width: 60rpx; height: 60rpx; border-radius: 50%;
  background: rgba(255,255,255,.18);
  display: flex; align-items: center; justify-content: center;
}
.sc-avatar text { color: #fff; font-size: 25rpx; font-weight: bold; }

.sc-row { display: flex; align-items: center; justify-content: space-around; }
.sc-item { text-align: center; position: relative; padding: 8rpx 14rpx; }
.sc-num {
  display: block; font-size: 50rpx; font-weight: bold; color: #fff; line-height: 1.1;
}
.sc-num-green { color: #a8ff78; }
.sc-num-yellow { color: #ffd93d; }
.sc-lbl { display: block; font-size: 21rpx; color: rgba(255,255,255,.62); margin-top: 4rpx; }
.sc-ico-bg {
  position: absolute; top:-6rpx; right:-2rpx; width: 30rpx; height: 30rpx;
  border-radius: 50%; display: flex; align-items: center; justify-content: center;
  font-size: 16rpx; opacity: .55;
}
.sc-ico-blue { background: rgba(24,144,255,.22); }
.sc-ico-green { background: rgba(82,196,26,.22); }
.sc-ico-yellow { background: rgba(250,173,20,.22); }
.sc-divider { width: 1rpx; height: 52rpx; background: rgba(255,255,255,.16); }

.streak {
  text-align: center; margin-top: 20rpx; padding: 12rpx 18rpx;
  background: rgba(255,255,255,.1); border-radius: 22rpx;
}
.streak text { color: #ffd93d; font-size: 25rpx; }

.avg-prog { margin-top: 18rpx; }
.ap-head {
  display: flex; justify-content: space-between; margin-bottom: 8rpx;
  font-size: 21rpx; color: rgba(255,255,255,.6);
}
.ap-pct { color: #fff; font-weight: bold; }
.ap-bar { height: 9rpx; background: rgba(255,255,255,.16); border-radius: 5rpx; overflow: hidden; }
.ap-fill {
  height: 100%; background: linear-gradient(to right,#52c41a,#95de64,#ffd93d);
  border-radius: 5rpx; transition: width .45s ease;
}

/* ====== 加载状态 ====== */
.loading-box {
  display: flex; flex-direction: column; align-items: center;
  padding: 90rpx 0; color: #999; font-size: 27rpx; gap: 14rpx;
}
.lds-ring {
  width: 44rpx; height: 44rpx; border: 4rpx solid #f0f0f0;
  border-top-color: #e94560; border-radius: 50%; animation: spin .75s linear infinite;
}
@keyframes spin { to{transform:rotate(360deg)} }

/* ====== 区块通用 ====== */
.sec { margin-top: 24rpx; padding: 0 22rpx; }
.sec-hd { display: flex; align-items: center; justify-content: space-between; margin-bottom: 17rpx; }
.sec-tt { font-size: 31rpx; font-weight: bold; color: #222; }
.sec-more { font-size: 23rpx; color: #e94560; font-weight: 500; }
.sec-count { font-size: 23rpx; color: #aaa; }

/* ====== 继续学习横滑 ====== */
.h-scroll { white-space: nowrap; }
.cc-card {
  display: inline-block; width: 280rpx; vertical-align: top; margin-right: 18rpx;
  background: #fff; border-radius: 18rpx; overflow: hidden;
  box-shadow: 0 3rpx 14rpx rgba(0,0,0,.05);
}
.cc-cover { width: 280rpx; height: 160rpx; }
.cc-ph {
  width: 280rpx; height: 160rpx;
  background: linear-gradient(135deg,#2c3e50,#34495e);
  display: flex; align-items: center; justify-content: center;
  color: rgba(255,255,255,.33); font-size: 42rpx;
}
.cc-prog { height: 4rpx; background: #f0f0f0; }
.cc-pf { height: 100%; background: linear-gradient(90deg,#e94560,#ff7a8a); transition: width .3s; }
.cc-info { padding: 13rpx 15rpx; }
.cc-title {
  font-size: 26rpx; font-weight: 600; color: #333;
  display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; line-height: 1.3;
}
.cc-bot { display: flex; justify-content: space-between; align-items: center; margin-top: 8rpx; }
.cc-tip { font-size: 20rpx; color: #e94560; font-weight: 500; }
.cc-pct {
  font-size: 20rpx; color: #e94560; font-weight: bold;
  background: #fff0f0; padding: 1rpx 10rpx; border-radius: 7rpx;
}

/* ====== 正在学习列表 ====== */
.course-list { display: flex; flex-direction: column; gap: 13rpx; }
.ci-item {
  display: flex; align-items: center; background: #fff; padding: 19rpx;
  border-radius: 16rpx; box-shadow: 0 2rpx 10rpx rgba(0,0,0,.035);
}
.ci-thumb-wrap { position: relative; width: 142rpx; height: 92rpx; flex-shrink: 0; }
.ci-thumb { width: 142rpx; height: 92rpx; border-radius: 12rpx; }
.ci-thumb-ph {
  width: 142rpx; height: 92rpx; border-radius: 12rpx;
  background: linear-gradient(135deg,#e8eaed,#f0f2f5);
  display: flex; align-items: center; justify-content: center; font-size: 30rpx;
}
.ci-corner {
  position: absolute; bottom:5rpx; right:5rpx;
  background: rgba(233,69,96,.88); color: #fff;
  font-size: 16rpx; padding: 2rpx 9rpx; border-radius: 7rpx; font-weight: 600;
}
.ci-detail { flex: 1; margin-left: 18rpx; overflow: hidden; }
.ci-name {
  font-size: 28rpx; color: #222; font-weight: 500;
  display: block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.ci-meta { display: flex; gap: 6rpx; margin-top: 7rpx; flex-wrap: wrap; }
.ci-meta text { font-size: 21rpx; color: #bbb; }
.ci-prog { display: flex; align-items: center; margin-top: 10rpx; gap: 8rpx; }
.ci-pb { flex: 1; max-width: 190rpx; height: 6rpx; background: #f0f0f0; border-radius: 3rpx; overflow: hidden; }
.ci-pf { height: 100%; background: linear-gradient(90deg,#e94560,#ff7a8a); border-radius: 3rpx; transition: width .3s; }
.ci-pct { font-size: 20rpx; color: #e94560; font-weight: 600; min-width: 44rpx; text-align: right; }
.ci-arrow { color: #ccc; font-size: 34rpx; margin-left: 10rpx; flex-shrink: 0; }

/* ====== 已完成列表 ====== */
.done-list { display: flex; flex-direction: column; gap: 11rpx; }
.di-item {
  display: flex; align-items: center; background: #fff; padding: 18rpx;
  border-radius: 16rpx; box-shadow: 0 2rpx 10rpx rgba(82,196,26,.05);
  border-left: 4rpx solid #52c41a;
}
.di-icon {
  width: 48rpx; height: 48rpx; border-radius: 50%;
  background: linear-gradient(135deg,#52c41a,#73d13d);
  color: #fff; display: flex; align-items: center; justify-content: center;
  font-size: 26rpx; font-weight: bold; flex-shrink: 0; margin-right: 16rpx;
}
.di-detail { flex: 1; overflow: hidden; }
.di-name {
  font-size: 27rpx; color: #333; display: block;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-weight: 500;
}
.di-meta { display: flex; gap: 12rpx; margin-top: 6rpx; flex-wrap: wrap; }
.di-done-txt { font-size: 21rpx; color: #52c41a; font-weight: 500; }
.di-date { font-size: 20rpx; color: #bbb; }
.di-arrow { color: #ccc; font-size: 34rpx; margin-left: 10rpx; flex-shrink: 0; }

/* ====== 空状态 ====== */
.empty-box { text-align: center; padding: 100rpx 36rpx 70rpx; }
.eb-art {
  width: 200rpx; height: 200rpx; border-radius: 50%;
  background: linear-gradient(135deg,#fef3f3,#fff7f7);
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 28rpx;
  animation: floatY 3s ease-in-out infinite;
}
@keyframes floatY { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-12rpx)} }
.eb-emo { font-size: 84rpx; }
.eb-title { display: block; font-size: 33rpx; color: #333; font-weight: bold; margin-bottom: 10rpx; }
.eb-desc { display: block; font-size: 25rpx; color: #bbb; margin-bottom: 40rpx; line-height: 1.48; }
.eb-btn {
  background: linear-gradient(135deg,#e94560,#ff7088) !important;
  color: #fff !important; border-radius: 46rpx !important;
  font-size: 28rpx !important; font-weight: bold !important;
  padding: 0 64rpx !important; height: 76rpx !important; line-height: 76rpx !important;
  letter-spacing: 1.5rpx !important;
  box-shadow: 0 8rpx 28rpx rgba(233,69,96,.33) !important;
}
