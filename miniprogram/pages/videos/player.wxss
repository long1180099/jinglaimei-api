/* 视频播放器页 · 玫小可商学院 · Premium */

.pp { min-height: 100vh; background: #f4f5f9; }

/* ====== 付费墙 ====== */
.pw {
  min-height: 100vh;
  background: linear-gradient(180deg, #0c1018 0%, #141a26 45%, #1a2030 100%);
  display: flex; align-items: center; justify-content: center;
  padding: 36rpx;
}
.pw-bg {
  position: absolute; top:0; left:0; right:0; bottom:0;
  background: radial-gradient(circle at 50% 25%, rgba(233,69,96,.07) 0%, transparent 60%);
}
.pw-card { width: 100%; position: relative; z-index: 1; }
.pw-cover-wrap { margin-bottom: 28rpx; }
.pw-cover {
  width: 100%; height: 360rpx;
  border-radius: 22rpx;
  box-shadow: 0 16rpx 44rpx rgba(0,0,0,.42);
}
.pw-cover-ph {
  width: 100%; height: 360rpx;
  border-radius: 22rpx;
  background: linear-gradient(145deg, #1a2436, #283448);
  display: flex;
  flex-direction: column;
  align-items: center; justify-content: center;
}
.pw-cover-ph text:first-child { font-size: 68rpx; opacity: .45; }
.pw-ph-sub { font-size: 22rpx; color: rgba(255,255,255,.28); margin-top: 10rpx; }

.pw-body { text-align: center; }
.pw-badge {
  display: inline-block;
  padding: 7rpx 26rpx;
  background: rgba(233,69,96,.11);
  border-radius: 28rpx;
  margin-bottom: 18rpx;
}
.pw-badge text { color: #ff7a8a; font-size: 21rpx; font-weight: 600; }

.pw-title {
  color: #fff;
  font-size: 37rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 12rpx;
  line-height: 1.38;
}
.pw-desc {
  color: rgba(255,255,255,.42);
  font-size: 25rpx;
  display: block;
  margin-bottom: 22rpx;
  line-height: 1.58;
}

.pw-metas {
  display: flex; justify-content: center; gap: 10rpx; flex-wrap: wrap; margin-bottom: 30rpx;
}
.pw-pill {
  background: rgba(255,255,255,.05);
  padding: 7rpx 17rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(255,255,255,.06);
}
.pw-pill text { color: rgba(255,255,255,.46); font-size: 21rpx; }

.pw-price-area { margin-bottom: 32rpx; }
.pw-price-lbl {
  color: rgba(255,255,255,.32); font-size: 21rpx; display: block; margin-bottom: 8rpx;
}
.pw-price-val { display: flex; align-items: baseline; justify-content: center; gap: 2rpx; }
.pw-p-sym { color: #ffd700; font-size: 31rpx; font-weight: bold; }
.pw-p-num { color: #ffd700; font-size: 76rpx; font-weight: bold; }

.pw-buy-btn {
  background: linear-gradient(135deg,#e94560,#ff6a6a) !important;
  color: #fff !important;
  border-radius: 52rpx !important;
  height: 88rpx !important;
  line-height: 88rpx !important;
  font-size: 31rpx !important;
  font-weight: bold !important;
  box-shadow: 0 12rpx 38rpx rgba(233,69,96,.42) !important;
  margin: 0 auto !important;
  width: 82% !important;
  letter-spacing: 2rpx !important;
}
.pw-hint {
  display: block; margin-top: 18rpx;
  color: rgba(255,255,255,.22); font-size: 21rpx;
}

/* ====== 视频容器 ====== */
.pv-wrap { width: 100%; }
.pv-player { width: 100%; height: 420rpx; background: #000; }

/* ====== 信息栏 ====== */
.pi-bar {
  background: #fff;
  padding: 24rpx 26rpx;
  display: flex; justify-content: space-between; align-items: flex-start;
}
.pi-main { flex: 1; }
.pi-title {
  font-size: 32rpx; font-weight: bold; color: #1a1a2e;
  line-height: 1.4;
  display: -webkit-box; -webkit-line-clamp: 2; overflow: hidden;
}
.pi-tags { display: flex; gap: 10rpx; margin-top: 14rpx; flex-wrap: wrap; }
.pi-tg {
  font-size: 20rpx; padding: 3rpx 14rpx; border-radius: 7rpx; font-weight: 500;
}
.pi-tg-cat { background: linear-gradient(135deg,#f0f5ff,#e6f7ff); color: #1890ff; }
.pi-tg-diff { background: linear-gradient(135deg,#fff7e6,#fffbe6); color: #d48806; }

/* 进度环 */
.pi-ring {
  position: relative;
  width: 70rpx; height: 70rpx;
  margin-left: 18rpx; flex-shrink: 0;
}
.pr-outer { width: 70rpx; height: 70rpx; border-radius: 50%; }
.pr-inner {
  width: 100%; height: 100%;
  border-radius: 50%;
  mask: radial-gradient(transparent 55%, black 56%);
  -webkit-mask: radial-gradient(transparent 55%, black 56%);
}
.pr-txt {
  position: absolute; top:50%; left:50%;
  transform: translate(-50%,-50%);
  font-size: 18rpx; color: #e94560; font-weight: bold;
}
.pi-done-tag {
  background: linear-gradient(135deg,#52c41a,#73d13d);
  color: #fff; font-size: 20rpx; font-weight: 600;
  padding: 5rpx 16rpx; border-radius: 18rpx;
  margin-left: 18rpx; white-space: nowrap;
}

/* ====== 操作栏 ====== */
.act-bar {
  display: flex; justify-content: space-around; padding: 26rpx 0;
  background: #fff; border-top: 1rpx solid #f2f2f2;
}
.act-item {
  display: flex; flex-direction: column; align-items: center; gap: 8rpx;
  transition: opacity .2s;
}
.act-item:active { opacity: .65; }
.act-circle {
  width: 76rpx; height: 76rpx; border-radius: 50%;
  background: #f7f8fc;
  display: flex; align-items: center; justify-content: center;
  transition: all .25s ease;
}
.act-circle.ac-active {
  background: linear-gradient(135deg,#e94560,#ff7088);
}
.act-circle text { font-size: 31rpx; }
.act-circle.ac-active text { color: #fff; }
.act-lbl { font-size: 21rpx; color: #888; font-weight: 500; }
.act-on .act-lbl { color: #e94560; }

/* ====== 笔记 ====== */
.note-box {
  background: #fafbfd; margin: 0 22rpx 18rpx; padding: 22rpx;
  border-radius: 18rpx; border: 1rpx solid #f0f0f0;
  max-height: 0; overflow: hidden;
  transition: max-height .35s ease, padding .35s ease, opacity .3s ease;
  opacity: 0;
}
.note-box.nb-open { max-height: 480rpx; opacity: 1; }
.nb-head {
  display: flex; justify-content: space-between; align-items: center; margin-bottom: 14rpx;
}
.nb-title { font-size: 27rpx; font-weight: 600; color: #333; }
.nb-count { font-size: 21rpx; color: #bbb; }
.nb-input {
  width: 100%; min-height: 130rpx; background: #fff;
  border: 1rpx solid #eee; border-radius: 12rpx;
  padding: 16rpx; font-size: 26rpx; box-sizing: border-box; color: #333; line-height: 1.58;
}
.nb-save {
  margin-top: 16rpx; float: right;
  background: linear-gradient(135deg,#e94560,#ff7088) !important;
  color: #fff !important; border-radius: 28rpx !important;
  font-size: 23rpx !important; padding: 0 30rpx !important;
  height: 56rpx !important; line-height: 56rpx !important;
}

/* ====== 剧集列表 ====== */
.epi-section {
  background: #fff; margin: 0 0 20rpx; padding: 26rpx;
}
.epi-header {
  display: flex; justify-content: space-between; align-items: center; margin-bottom: 18rpx;
}
.epi-h-title { font-size: 30rpx; font-weight: bold; color: #222; }
.epi-h-count { font-size: 23rpx; color: #aaa; }

.epi-scroll { white-space: nowrap; }
.epi-card {
  display: inline-block; width: 224rpx; margin-right: 18rpx; vertical-align: top;
}
.ec-cover {
  position: relative; width: 224rpx; height: 130rpx; border-radius: 15rpx; overflow: hidden; background: #2a2a3e;
}
.ec-cover image { width: 100%; height: 100%; }
.ec-ph {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  color: rgba(255,255,255,.33); font-size: 31rpx;
  background: linear-gradient(135deg,#2c3e50,#34495e);
}
.epi-cur .ec-cover {
  border: 3rpx solid #e94560;
  box-shadow: 0 5rpx 18rpx rgba(233,69,96,.28);
}
.ec-prog {
  position: absolute; left:0; right:0; bottom:0; height: 4rpx; background: rgba(255,255,255,.13);
}
.ec-prog-fill { height: 100%; background: #52c41a; }
.ec-done-mark {
  position: absolute; right:8rpx; bottom:8rpx;
  font-size: 17rpx; background: rgba(82,196,26,.9);
  color: #fff; padding: 2rpx 9rpx; border-radius: 6rpx; font-weight: bold;
}
.ec-now-tag {
  position: absolute; left:8rpx; top:8rpx;
  background: rgba(233,69,96,.9);
  color: #fff; font-size: 16rpx;
  padding: 2rpx 11rpx; border-radius: 7rpx; font-weight: 500;
}

.ec-info { padding: 10rpx 2rpx 0; }
.ec-title {
  display: block; font-size: 24rpx; color: #333; font-weight: 500;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap; line-height: 1.3;
}
.epi-cur .ec-title { color: #e94560; font-weight: bold; }
.ec-bottom { display: flex; align-items: center; gap: 8rpx; margin-top: 6rpx; }
.ec-dur { font-size: 19rpx; color: #aaa; }
.ec-done-txt { font-size: 18rpx; color: #52c41a; font-weight: 500; }
.ec-pct-txt { font-size: 18rpx; color: #e94560; font-weight: 500; }

/* ====== 讲师信息 ====== */
.ins-section {
  display: flex; align-items: center; padding: 26rpx 26rpx;
  background: #fff; border-top: 1rpx solid #f2f2f2;
}
.ins-avatar {
  width: 72rpx; height: 72rpx; border-radius: 50%;
  background: linear-gradient(135deg,#e94560,#ff7088);
  display: flex; align-items: center; justify-content: center;
  margin-right: 18rpx; flex-shrink: 0;
}
.ins-avatar-txt { color: #fff; font-size: 29rpx; font-weight: bold; }
.ins-detail { flex: 1; }
.ins-name { display: block; font-size: 28rpx; font-weight: 600; color: #222; }
.ins-role { display: block; font-size: 21rpx; color: #aaa; margin-top: 4rpx; }
.ins-arrow { font-size: 31rpx; color: #ccc; margin-left: 10rpx; }
