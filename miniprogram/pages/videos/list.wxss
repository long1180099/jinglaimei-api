/* 视频列表页 · 玫小可商学院 · Premium */

.vp {
  min-height: 100vh;
  background: #f5f6fb;
  padding-bottom: 110rpx;
}

/* ========== 头部 ========== */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 28rpx 16rpx;
  background: linear-gradient(135deg, #e94560 0%, #d63250 40%, #c02842 100%);
}
.header-left { display: flex; align-items: center; }
.brand-icon {
  width: 56rpx; height: 56rpx;
  background: rgba(255,255,255,0.18);
  border-radius: 14rpx;
  display: flex; align-items: center; justify-content: center;
  margin-right: 14rpx;
}
.brand-icon text {
  color: #fff;
  font-size: 24rpx;
  letter-spacing: -2rpx;
}
.header-texts { display: flex; flex-direction: column; }
.ht-title {
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  letter-spacing: 1rpx;
}
.ht-sub {
  color: rgba(255,255,255,0.6);
  font-size: 18rpx;
  margin-top: 2rpx;
}
.search-btn {
  width: 58rpx; height: 58rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.15);
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx;
  color: rgba(255,255,255,0.85);
}

/* ========== 搜索栏 ========== */
.search-bar {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
  transform: translateY(-100%);
  transition: transform .25s ease;
}
.search-bar.sb-show { transform: translateY(0); }
.sb-box {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f5f6fa;
  border-radius: 36rpx;
  padding: 0 24rpx;
  height: 68rpx;
}
.sb-icon { font-size: 26rpx; opacity: 0.45; margin-right: 12rpx; }
.sb-input { flex: 1; height: 68rpx; font-size: 28rpx; color: #333; }
.sb-cancel {
  color: #e94560;
  margin-left: 20rpx;
  white-space: nowrap;
  font-size: 28rpx;
  font-weight: 500;
}

/* ========== 主Tab ========== */
.tabs {
  display: flex;
  padding: 0 16rpx;
  background: #fff;
  white-space: nowrap;
}
.tab-item {
  padding: 16rpx 28rpx;
  font-size: 27rpx;
  color: #8a8a8a;
  position: relative;
  transition: all .25s ease;
  font-weight: 500;
}
.tab-item.tab-on {
  color: #e94560;
  font-weight: 700;
  font-size: 28rpx;
}
.tab-item.tab-on::after {
  content: '';
  position: absolute;
  bottom: 8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 36rpx;
  height: 4rpx;
  background: linear-gradient(90deg, #e94560, #ff7a8a);
  border-radius: 2rpx;
}

/* ========== 分类横滑 ========== */
.cats {
  display: flex;
  padding: 10rpx 18rpx 8rpx;
  background: #fff;
  white-space: nowrap;
}
.cat-chip {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: 32rpx;
  margin-right: 12rpx;
  background: #f7f8fc;
  border: 2rpx solid transparent;
  transition: all .25s ease;
}
.cat-chip.cat-on {
  background: linear-gradient(135deg, #e94560, #ff7088);
  box-shadow: 0 6rpx 20rpx rgba(233,69,96,.3);
  border-color: rgba(233,69,96,.12);
}
.cat-emoji { font-size: 30rpx; }
.cat-txt {
  font-size: 21rpx;
  margin-top: 5rpx;
  color: #666;
  font-weight: 500;
}
.cat-on .cat-txt { color: #fff; }

/* ========== 内容滚动区 ========== */
.content-scroll { height: calc(100vh - 300rpx); }

/* ========== 骨架屏 ========== */
.skeleton-wrap { padding: 20rpx; }
.sk-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}
.sk-cover {
  width: 100%;
  height: 360rpx;
  background: linear-gradient(110deg, #eee 30%, #f5f5f5 50%, #eee 70%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}
.sk-body { padding: 20rpx 24rpx; }
.sk-line {
  background: linear-gradient(110deg, #f0f0f0 30%, #f5f5f5 50%, #f0f0f0 70%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 6rpx;
  margin-bottom: 12rpx;
}
.sk-line-lg { width: 75%; height: 32rpx; }
.sk-line-sm { width: 55%; height: 24rpx; }
.sk-line-xs { width: 35%; height: 22rpx; }
@keyframes shimmer { 0%{background-position:-200% 0} 100%{background-position:200% 0} }

/* ========== 空状态 ========== */
.empty {
  text-align: center;
  padding: 80rpx 36rpx 60rpx;
}
.empty-art {
  width: 200rpx; height: 200rpx;
  background: linear-gradient(135deg, #fef3f3, #fff7f7);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 28rpx;
  animation: floatY 3s ease-in-out infinite;
}
@keyframes floatY { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-12rpx)} }
.empty-emo { font-size: 84rpx; }
.empty-tt {
  display: block;
  font-size: 33rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 10rpx;
}
.empty-dd {
  display: block;
  font-size: 25rpx;
  color: #bbb;
  margin-bottom: 36rpx;
}
.empty-preview {
  max-width: 420rpx;
  margin: 0 auto;
  text-align: left;
}
.ep-item {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx dashed #eee;
}
.ep-item:last-child { border-bottom: none; }
.ep-no {
  font-size: 23rpx;
  color: #e94560;
  font-weight: 700;
  min-width: 44rpx;
}
.ep-item text:last-child { font-size: 25rpx; color: #777; }

/* ========== 错误状态 ========== */
.error { text-align: center; padding: 130rpx 36rpx; }
.err-emo { font-size: 76rpx; display: block; margin-bottom: 18rpx; }
.err-tt { display: block; font-size: 29rpx; color: #888; margin-bottom: 28rpx; }
.retry-btn {
  background: linear-gradient(135deg,#e94560,#ff7088) !important;
  color: #fff !important;
  border-radius: 44rpx !important;
  font-size: 28rpx !important;
  padding: 0 64rpx !important;
  height: 76rpx !important;
  line-height: 76rpx !important;
}

/* ========== 视频卡片 ========== */
.card-list { padding: 16rpx 16rpx 0; }
.v-card {
  background: #fff;
  border-radius: 22rpx;
  margin-bottom: 18rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 14rpx rgba(0,0,0,.04);
  transition: transform .2s ease, box-shadow .2s ease;
}
.v-card:active {
  transform: scale(.98);
  box-shadow: 0 1rpx 8rpx rgba(0,0,0,.08);
}

/* 卡片封面 */
.vc-cover {
  position: relative;
  width: 100%;
  height: 384rpx;
  overflow: hidden;
}
.vc-img { width: 100%; height: 100%; }
.vc-ph {
  width: 100%; height: 100%;
  background: linear-gradient(145deg, #1a1a2e 0%, #1d2646 35%, #e94560 220%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.vc-play-ico {
  font-size: 68rpx;
  color: rgba(255,255,255,.32);
  margin-bottom: 6rpx;
}
.vc-ph-hint {
  font-size: 21rpx;
  color: rgba(255,255,255,.22);
  letter-spacing: 2rpx;
}

/* 封面标签 */
.vc-dur {
  position: absolute;
  right: 14rpx; bottom: 14rpx;
  background: rgba(0,0,0,.72);
  backdrop-filter: blur(6rpx);
  color: #fff;
  font-size: 21rpx;
  font-weight: 500;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  letter-spacing: .5rpx;
}
.vc-tag {
  position: absolute;
  left: 14rpx; top: 14rpx;
  font-size: 21rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
  letter-spacing: .5rpx;
}
.vc-price {
  background: linear-gradient(135deg, #e94560, #ff6a6a);
  box-shadow: 0 4rpx 12rpx rgba(233,69,96,.32);
  color: #fff;
}
.vc-bought {
  background: linear-gradient(135deg, #52c41a, #73d13d);
  box-shadow: 0 4rpx 12rpx rgba(82,196,26,.28);
  color: #fff;
}

/* 进度条 & 已完成 */
.vc-prog {
  position: absolute;
  left: 0; right: 0; bottom: 0;
  height: 5rpx;
  background: rgba(255,255,255,.22);
}
.vc-prog-fill {
  height: 100%;
  background: linear-gradient(90deg, #52c41a, #95de64);
  border-radius: 0 3rpx 3rpx 0;
  transition: width .3s;
}
.vc-done {
  position: absolute;
  right: 14rpx; bottom: 14rpx;
  background: linear-gradient(135deg, #52c41a, #73d13d);
  color: #fff;
  font-size: 19rpx;
  font-weight: 600;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
}

/* 卡片信息 */
.vc-body { padding: 20rpx 22rpx 22rpx; }
.vc-title {
  font-size: 29rpx;
  font-weight: 600;
  color: #1a1a2e;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.48;
}
.vc-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-top: 12rpx;
  gap: 4rpx 14rpx;
}
.vc-mi { font-size: 22rpx; color: #aaa; }
.vc-mi-last { margin-left: auto; }

.vc-tags { margin-top: 12rpx; }
.vc-diff-badge {
  font-size: 19rpx;
  padding: 2rpx 13rpx;
  border-radius: 6rpx;
  background: linear-gradient(135deg, #fff7e6, #fffbe6);
  color: #d48806;
  font-weight: 500;
}
.vc-series {
  display: inline-block;
  margin-top: 8rpx;
  background: linear-gradient(135deg, #fef0f0, #fff6f6);
  color: #e94560;
  font-size: 20rpx;
  padding: 4rpx 15rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

/* ========== 加载更多 / 到底 ========== */
.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 32rpx;
  color: #bbb;
  font-size: 25rpx;
}
.lm-spinner {
  width: 28rpx; height: 28rpx;
  border: 3rpx solid #eee;
  border-top-color: #e94560;
  border-radius: 50%;
  animation: spin .75s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.load-end {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 32rpx 0 16rpx;
  color: #ddd;
  font-size: 23rpx;
}
.le-line { width: 40rpx; height: 1rpx; background: #ddd; }

/* ========== 底部入口 ========== */
.bottom-bar {
  position: fixed;
  left: 24rpx; right: 24rpx; bottom: 24rpx;
  background: linear-gradient(135deg, #e94560, #ff7088);
  color: #fff;
  padding: 24rpx 30rpx;
  border-radius: 52rpx;
  display: flex;
  align-items: center;
  font-size: 27rpx;
  font-weight: 600;
  box-shadow: 0 10rpx 36rpx rgba(233,69,96,.38);
  z-index: 10;
  letter-spacing: 1rpx;
}
.bb-ico { font-size: 30rpx; margin-right: 10rpx; }
.bb-lbl { flex: 1; }
.bb-arrow { font-size: 38rpx; font-weight: 300; opacity: .8; }
