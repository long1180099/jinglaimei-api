/* 地址管理页面 */
.page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 140rpx;
}

/* ==================== 地址列表 ==================== */
.address-list {
  padding: 20rpx;
}

.address-item {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  border: 2rpx solid transparent;
}

.address-item.default {
  border-color: #e94560;
}

.address-item.default .item-main {
  background: linear-gradient(135deg, #fff5f7 0%, #ffffff 100%);
}

.item-main {
  padding: 28rpx 24rpx;
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.item-tag-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.default-tag {
  font-size: 20rpx;
  color: #fff;
  background: #e94560;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

.name-tag {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.item-phone {
  font-size: 26rpx;
  color: #666;
  margin-left: 4rpx;
}

.item-detail {
  font-size: 26rpx;
  color: #888;
  line-height: 1.5;
  margin-top: 4rpx;
  padding-left: 4rpx;
}

/* 选择模式勾选 */
.item-check {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
}

.check-circle {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 2rpx solid #dcdfe6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
}

.check-circle.checked {
  background: #e94560;
  border-color: #e94560;
}

/* 操作按钮栏 */
.item-actions {
  display: flex;
  justify-content: flex-end;
  gap: 24rpx;
  padding: 16rpx 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 24rpx;
  color: #666;
  padding: 8rpx 16rpx;
}

.action-icon {
  font-size: 26rpx;
}

.action-btn.delete {
  color: #e94560;
}

.action-btn.default-btn {
  color: #e94560;
  font-weight: 500;
}

/* ==================== 空状态 ==================== */
.empty-address {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}

/* ==================== 底部按钮 ==================== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 24rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  display: flex;
  gap: 20rpx;
}

.btn-add {
  flex: 1;
  height: 88rpx;
  background: linear-gradient(135deg, #e94560 0%, #c0392b 100%);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
}

.btn-add:active {
  opacity: 0.85;
}

.btn-plus {
  font-size: 36rpx;
  font-weight: 300;
}

.btn-confirm {
  width: 240rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
}

.btn-confirm.disabled {
  opacity: 0.4;
}
