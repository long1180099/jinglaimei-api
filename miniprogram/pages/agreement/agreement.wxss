/* 用户服务协议页面样式 */
page {
  background-color: #f5f6fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'PingFang SC', 'Hiragino Sans GB', sans-serif;
}

.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 头部 */
.header {
  background: linear-gradient(135deg, #e94560 0%, #c0392b 100%);
  padding: 80rpx 40rpx 50rpx;
  text-align: center;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 4rpx;
  display: block;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
}

/* 更新日期 */
.update-info {
  text-align: center;
  color: #999;
  font-size: 24rpx;
  padding: 30rpx 40rpx 20rpx;
}

/* 内容区 */
.content {
  flex: 1;
  height: calc(100vh - 300rpx);
}

.doc-body {
  padding: 0 36rpx 40rpx;
}

/* 章节样式 */
.section {
  margin-bottom: 40rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 24rpx;
  padding-left: 20rpx;
  border-left: 8rpx solid #e94560;
  line-height: 1.3;
}

.section-text {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.text-p {
  font-size: 27rpx;
  color: #444;
  line-height: 1.8;
  text-align: justify;
}

.text-p .bold {
  font-weight: 600;
  color: #222;
}

.text-p.highlight {
  color: #e94560;
  font-weight: 500;
  padding: 16rpx 20rpx;
  background: rgba(233, 69, 96, 0.06);
  border-radius: 10rpx;
}

.text-p.contact {
  color: #e94560;
  font-weight: 500;
}

/* 底部 */
.footer {
  text-align: center;
  padding: 30rpx 0 40rpx;
}

.footer-text {
  font-size: 24rpx;
  color: #bbb;
}

.footer-icp {
  font-size: 22rpx;
  color: #ccc;
  display: block;
  margin-top: 8rpx;
}
