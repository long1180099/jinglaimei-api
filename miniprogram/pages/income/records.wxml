<!-- 收益记录 -->
<view class="page">
  <!-- Tab切换 -->
  <view class="tabs">
    <view class="tab {{activeTab == 'income' ? 'active' : ''}}" bindtap="switchTab" data-tab="income">收益记录</view>
    <view class="tab {{activeTab == 'withdrawals' ? 'active' : ''}}" bindtap="switchTab" data-tab="withdrawals">提现记录</view>
  </view>

  <!-- 收益记录 -->
  <scroll-view class="record-list" scroll-y wx:if="{{activeTab == 'income'}}">
    <view class="record-item" wx:for="{{records}}" wx:key="id">
      <view class="record-left">
        <view class="record-icon">{{item.type == 1 ? '🎁' : '🎯'}}</view>
        <view class="record-info">
          <text class="record-title">{{item.type == 1 ? '直接收益' : '团队收益'}}</text>
          <text class="record-desc">{{item.order_no || ''}} · {{item.created_at || ''}}</text>
        </view>
      </view>
      <text class="record-amount">+¥{{item.amount}}</text>
    </view>
    <view class="empty-state" wx:if="{{records.length == 0 && !loading}}">
      <text class="empty-icon">💰</text>
      <text class="empty-text">暂无收益记录</text>
      <text class="empty-hint">推广商品产生销售后即可获得收益</text>
    </view>
    <view class="load-more" wx:if="{{records.length > 0 && hasMore}}">
      <view class="loading-dots">
        <view class="dot"></view>
        <view class="dot"></view>
        <view class="dot"></view>
      </view>
    </view>
  </scroll-view>

  <!-- 提现记录 -->
  <scroll-view class="record-list" scroll-y wx:if="{{activeTab == 'withdrawals'}}">
    <view class="record-item" wx:for="{{withdrawals}}" wx:key="id">
      <view class="record-left">
        <view class="record-icon">💸</view>
        <view class="record-info">
          <text class="record-title">提现</text>
          <text class="record-desc">{{item.method == 1 ? '微信' : '银行卡'}} · {{item.created_at || ''}}</text>
        </view>
      </view>
      <view class="record-right">
        <text class="record-amount negative">-¥{{item.amount}}</text>
        <text class="record-status" style="color:{{item.statusColor}}">{{item.statusText}}</text>
      </view>
    </view>
    <view class="empty-state" wx:if="{{withdrawals.length == 0 && !loading}}">
      <text class="empty-icon">📦</text>
      <text class="empty-text">暂无提现记录</text>
      <text class="empty-hint">收益满100元即可提现</text>
    </view>
  </scroll-view>
</view>
