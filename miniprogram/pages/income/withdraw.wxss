/* 提现 v2.0 */
.page { background: var(--bg-page); min-height: 100vh; padding-bottom: 60rpx; }

.balance-card {
  background: linear-gradient(160deg, var(--primary) 0%, var(--primary-dark) 50%, #b82e45 100%);
  padding: var(--space-15) var(--space-8);
  color: #fff;
  position: relative;
  overflow: hidden;
}

.balance-deco {
  position: absolute;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.03);
  top: -100rpx;
  right: -80rpx;
  pointer-events: none;
}

.balance-label { font-size: var(--font-sm); opacity: 0.65; display: block; letter-spacing: 1rpx; position: relative; z-index: 1; }
.balance-amount { font-size: var(--font-4xl); font-weight: 700; margin: var(--space-5) 0 var(--space-8); display: block; position: relative; z-index: 1; letter-spacing: 2rpx; }

.balance-stats {
  display: flex;
  background: rgba(255, 255, 255, 0.1);
  border-radius: var(--radius-lg);
  padding: var(--space-5) var(--space-6);
  backdrop-filter: blur(10px);
  position: relative;
  z-index: 1;
}

.balance-stat { flex: 1; }
.stat-label { font-size: var(--font-xs); opacity: 0.55; display: block; }
.stat-value { font-size: var(--font-md); font-weight: 600; margin-top: var(--space-2); display: block; }
.stat-divider { width: 1rpx; background: rgba(255, 255, 255, 0.12); margin: 0 var(--space-6); }

.form-card {
  background: var(--bg-card);
  margin: var(--space-5) 28rpx;
  border-radius: var(--radius-lg);
  padding: var(--space-8);
  box-shadow: var(--shadow-xs);
  border: 1rpx solid var(--border-light);
}
.form-title { font-size: var(--font-md); font-weight: 600; color: var(--text-primary); margin-bottom: var(--space-6); }
.form-group { margin-bottom: var(--space-8); }
.form-label { font-size: var(--font-base); color: var(--gray-700); margin-bottom: var(--space-4); display: block; font-weight: 500; }

.method-tabs { display: flex; gap: var(--space-5); }
.method-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-2);
  padding: var(--space-5);
  border: 2rpx solid var(--gray-200);
  border-radius: var(--radius-md);
  font-size: var(--font-base);
  color: var(--gray-600);
  transition: all var(--duration-fast);
  background: var(--bg-card);
}
.method-tab.active {
  border-color: var(--primary);
  color: var(--primary);
  background: var(--primary-bg);
}

.form-input {
  width: 100%;
  height: 92rpx;
  background: var(--gray-50);
  border-radius: var(--radius-md);
  padding: 0 var(--space-6);
  font-size: var(--font-base);
  color: var(--text-primary);
  border: 2rpx solid var(--gray-200);
  transition: border-color var(--duration-fast), box-shadow var(--duration-fast);
}

.form-input:focus {
  border-color: var(--primary);
  box-shadow: 0 0 0 4rpx rgba(233, 69, 96, 0.08);
}

.amount-input-wrap {
  display: flex;
  align-items: center;
  background: var(--gray-50);
  border-radius: var(--radius-md);
  padding: 0 var(--space-6);
  height: 92rpx;
  border: 2rpx solid var(--gray-200);
  transition: border-color var(--duration-fast), box-shadow var(--duration-fast);
}

.amount-input-wrap:focus-within {
  border-color: var(--primary);
  box-shadow: 0 0 0 4rpx rgba(233, 69, 96, 0.08);
}
.amount-prefix { font-size: var(--font-xl); color: var(--text-primary); margin-right: var(--space-3); font-weight: 600; }
.amount-input { flex: 1; font-size: var(--font-xl); font-weight: 600; color: var(--text-primary); }
.quick-amount {
  font-size: var(--font-sm);
  color: var(--primary);
  margin-top: var(--space-3);
  display: inline-block;
  font-weight: 500;
  background: var(--primary-bg);
  padding: 6rpx 20rpx;
  border-radius: var(--radius-xl);
}

.notice-card {
  background: var(--bg-card);
  margin: var(--space-5) 28rpx;
  border-radius: var(--radius-lg);
  padding: var(--space-8);
  box-shadow: var(--shadow-xs);
  border: 1rpx solid var(--border-light);
}
.notice-title { font-size: var(--font-base); font-weight: 600; color: var(--text-primary); margin-bottom: var(--space-5); }
.notice-item { font-size: var(--font-sm); color: var(--text-muted); display: block; margin-bottom: var(--space-3); line-height: 1.6; }

.btn-submit {
  margin: var(--space-10) 28rpx;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: #fff;
  text-align: center;
  padding: var(--space-7);
  border-radius: var(--radius-2xl);
  font-size: var(--font-md);
  font-weight: 600;
  box-shadow: var(--shadow-primary);
  letter-spacing: 2rpx;
}
