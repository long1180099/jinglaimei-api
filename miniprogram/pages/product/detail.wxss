/* 商品详情 v2.0 */
.page {
  background: var(--bg-page);
  padding-bottom: 120rpx;
}

/* ==================== 图片轮播 ==================== */
.product-swiper {
  width: 100%;
  height: 750rpx;
}

.swiper-img {
  width: 100%;
  height: 100%;
}

.swiper-default {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, var(--gray-50), var(--gray-100));
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ==================== 价格区域 ==================== */
.price-section {
  background: linear-gradient(160deg, var(--primary) 0%, var(--primary-dark) 60%, #b82e45 100%);
  padding: var(--space-8);
  color: #fff;
}

.price-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.price-main {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: var(--font-base);
  font-weight: 600;
  margin-right: 4rpx;
}

.price-amount {
  font-size: var(--font-4xl);
  font-weight: 700;
  letter-spacing: 1rpx;
}

.price-label {
  font-size: var(--font-xs);
  background: rgba(255, 255, 255, 0.2);
  padding: 6rpx 18rpx;
  border-radius: var(--radius-xl);
  backdrop-filter: blur(10px);
  font-weight: 500;
}

.price-extra {
  display: flex;
  align-items: center;
  gap: var(--space-8);
  margin-top: var(--space-5);
}

.original-price {
  font-size: var(--font-sm);
  color: rgba(255, 255, 255, 0.5);
  text-decoration: line-through;
}

.sales-info {
  font-size: var(--font-sm);
  color: rgba(255, 255, 255, 0.6);
}

/* ==================== 商品信息 ==================== */
.info-section {
  background: var(--bg-card);
  padding: var(--space-8);
  margin-bottom: var(--space-4);
  border-bottom: 1rpx solid var(--border-light);
}

.product-name {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  line-height: 1.6;
  letter-spacing: 1rpx;
}

.product-desc {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  margin-top: var(--space-4);
  display: block;
  line-height: 1.6;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
  margin-top: var(--space-5);
}

.tag {
  font-size: var(--font-xs);
  color: var(--primary);
  background: var(--primary-bg);
  padding: 8rpx 18rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

/* ==================== 数量选择 ==================== */
.qty-section {
  display: flex;
  align-items: center;
  padding: var(--space-5) var(--space-6);
  background: #fff;
  margin-bottom: var(--space-3);
}

.qty-label {
  font-size: var(--font-base);
  color: var(--text-primary);
  font-weight: 500;
}

.qty-control {
  display: flex;
  align-items: center;
  margin-left: auto;
  background: var(--gray-50);
  border-radius: var(--radius-md);
  overflow: hidden;
}

.qty-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-lg);
  color: var(--text-primary);
  transition: all var(--duration-fast);
}

.qty-btn.minus:active,
.qty-btn.plus:active {
  background: var(--primary-bg);
}

.qty-btn.minus.disabled {
  color: var(--gray-300);
}

.qty-btn.plus {
  color: var(--primary);
  font-weight: 700;
}

.qty-num {
  width: 80rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--text-primary);
  border-left: 1rpx solid var(--gray-200);
  border-right: 1rpx solid var(--gray-200);
  background: #fff;
}

.qty-stock {
  font-size: var(--font-sm);
  color: var(--text-muted);
  margin-left: var(--space-4);
}

.stock-info {
  color: var(--primary);
  font-weight: 600;
  margin-left: var(--space-3);
}

/* ==================== 专属价格卡片 ==================== */
.price-card {
  padding: 0 var(--space-6);
  margin-bottom: var(--space-4);
}

.price-card-inner {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  border-radius: var(--radius-xl);
  padding: var(--space-8) var(--space-6);
  position: relative;
  overflow: hidden;
}

.price-card-inner::before {
  content: '';
  position: absolute;
  top: -40rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(233,69,96,0.15) 0%, transparent 70%);
  border-radius: 50%;
}

.price-card-inner::after {
  content: '';
  position: absolute;
  bottom: -30rpx;
  left: -20rpx;
  width: 150rpx;
  height: 150rpx;
  background: radial-gradient(circle, rgba(114,46,209,0.10) 0%, transparent 70%);
  border-radius: 50%;
}

.price-card-header {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  margin-bottom: var(--space-5);
  position: relative;
  z-index: 1;
}

.price-card-icon {
  font-size: 36rpx;
}

.price-card-title {
  font-size: var(--font-base);
  color: rgba(255,255,255,0.85);
  font-weight: 500;
}

.price-card-level {
  font-size: var(--font-xs);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-xl);
  font-weight: 600;
  letter-spacing: 2rpx;
}

.price-card-body {
  display: flex;
  align-items: baseline;
  gap: var(--space-4);
  position: relative;
  z-index: 1;
}

.my-price-main {
  display: flex;
  align-items: baseline;
}

.my-price-symbol {
  font-size: var(--font-lg);
  color: #fff;
  font-weight: 600;
  margin-right: 4rpx;
}

.my-price-amount {
  font-size: 56rpx;
  color: #fff;
  font-weight: 700;
  letter-spacing: 1rpx;
  text-shadow: 0 4rpx 16rpx rgba(233,69,96,0.25);
}

.price-save-hint {
  background: rgba(82,196,26,0.12);
  border-radius: var(--radius-md);
  padding: 6rpx 18rpx;
}

.price-save-hint text {
  font-size: var(--font-sm);
  color: #52c41a;
  font-weight: 500;
}

/* ==================== 详情 ==================== */
.detail-section {
  background: var(--bg-card);
  padding: var(--space-8);
  margin-bottom: var(--space-4);
}

.section-title-wrap {
  display: flex;
  align-items: center;
  margin-bottom: var(--space-6);
}

.title-accent {
  width: 6rpx;
  height: 28rpx;
  background: linear-gradient(180deg, var(--primary), var(--primary-light));
  border-radius: 3rpx;
  margin-right: var(--space-3);
}

.section-title {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
}

.detail-content {
  font-size: var(--font-base);
  color: var(--gray-700);
  line-height: 1.8;
}

/* ==================== 底部栏 ==================== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  background: var(--bg-card);
  padding: var(--space-4) var(--space-6);
  padding-bottom: calc(var(--space-4) + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.bar-icons {
  display: flex;
  gap: var(--space-8);
  margin-right: var(--space-6);
}

.bar-icon {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.bar-icon-text {
  font-size: 36rpx;
  color: var(--gray-600);
  line-height: 1;
}

.bar-icon-label {
  font-size: var(--font-xs);
  color: var(--gray-500);
  margin-top: 4rpx;
}

.cart-badge {
  position: absolute;
  top: -10rpx;
  right: -16rpx;
  min-width: 32rpx;
  height: 32rpx;
  background: var(--danger);
  color: #fff;
  font-size: var(--font-xs);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  font-weight: 700;
}

.bar-buttons {
  display: flex;
  flex: 1;
  gap: var(--space-3);
}

.btn-add {
  flex: 1;
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #ff9f43, #ee8520);
  color: #fff;
  font-size: var(--font-base);
  font-weight: 600;
  border-radius: var(--radius-2xl);
  letter-spacing: 1rpx;
  box-shadow: 0 6rpx 16rpx rgba(255, 159, 67, 0.25);
}

.btn-buy {
  flex: 1;
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: #fff;
  font-size: var(--font-base);
  font-weight: 600;
  border-radius: var(--radius-2xl);
  letter-spacing: 1rpx;
  box-shadow: var(--shadow-primary);
}
