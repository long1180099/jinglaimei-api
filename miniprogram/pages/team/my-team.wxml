<!-- 团队管理 v3.0 - Premium UI -->
<view class="page">
  <!-- ====== 全局排行榜模式（从首页"完整榜单"进入） ====== -->
  <view wx:if="{{showGlobalRanking}}" style="min-height:100vh;background:#f5f6fa;">
    <!-- 头部导航栏 -->
    <view style="background:linear-gradient(135deg,#faad14,#ffd666);padding:40rpx 30rpx;padding-top:calc(60rpx + env(safe-area-inset-top));">
      <view style="display:flex;align-items:center;margin-bottom:20rpx;">
        <text bindtap="backToMyTeam" style="font-size:36rpx;color:#fff;opacity:.8;">‹ 返回</text>
        <text style="flex:1;text-align:center;font-size:36rpx;font-weight:700;color:#fff;letter-spacing:2rpx;">🏆 系统业绩排行</text>
        <text style="width:80rpx;"></text>
      </view>
      <text style="font-size:24rpx;color:rgba(255,255,255,.8);display:block;text-align:center;">全系统业绩排名 · 共{{globalRanking.length}}人</text>
    </view>

    <!-- 前三名领奖台 -->
    <view style="margin:-20rpx 20rpx 0;border-radius:20rpx;background:#fff;overflow:hidden;box-shadow:0 4rpx 24rpx rgba(250,173,20,.15);position:relative;z-index:10;" wx:if="{{globalRanking.length >= 3}}">
      <view style="display:flex;justify-content:center;padding:50rpx 20rpx 30rpx;">
        <!-- 第二名 -->
        <view style="width:160rpx;display:flex;flex-direction:column;align-items:center;margin-top:20rpx;">
          <text style="font-size:44rpx;">🥈</text>
          <image src="{{globalRanking[1].avatar_url || '/images/default-avatar.png'}}" mode="aspectFill" style="width:100rpx;height:100rpx;border-radius:50%;border:4rpx solid #c0c0c0;margin-top:-10rpx;"></image>
          <text style="font-size:26rpx;font-weight:600;margin-top:8rpx;color:#333;">{{globalRanking[1].nickname}}</text>
          <text style="font-size:22rpx;color:#999;margin-top:4rpx;">¥{{globalRanking[1].total_income}}</text>
          <view style="width:90rpx;height:50rpx;background:linear-gradient(#c0c0c0,#e0e0e0);border-radius:6rpx 6rpx 0 0;margin-top:16rpx;"></view>
        </view>
        <!-- 第一名 -->
        <view style="width:180rpx;display:flex;flex-direction:column;align-items:center;margin-top:0;">
          <text style="font-size:48rpx;">👑</text>
          <image src="{{globalRanking[0].avatar_url || '/images/default-avatar.png'}}" mode="aspectFill" style="width:120rpx;height:120rpx;border-radius:50%;border:4rpx solid #FFD700;margin-top:-12rpx;"></image>
          <text style="font-size:28rpx;font-weight:700;margin-top:8rpx;color:#333;">{{globalRanking[0].nickname}}</text>
          <text style="font-size:24rpx;color:#e94560;font-weight:700;margin-top:4rpx;">¥{{globalRanking[0].total_income}}</text>
          <view style="width:110rpx;height:70rpx;background:linear-gradient(#FFD700,#FFE55C);border-radius:6rpx 6rpx 0 0;margin-top:16rpx;"></view>
        </view>
        <!-- 第三名 -->
        <view style="width:160rpx;display:flex;flex-direction:column;align-items:center;margin-top:20rpx;">
          <text style="font-size:44rpx;">🥉</text>
          <image src="{{globalRanking[2].avatar_url || '/images/default-avatar.png'}}" mode="aspectFill" style="width:100rpx;height:100rpx;border-radius:50%;border:4rpx solid #CD7F32;margin-top:-10rpx;"></image>
          <text style="font-size:26rpx;font-weight:600;margin-top:8rpx;color:#333;">{{globalRanking[2].nickname}}</text>
          <text style="font-size:22rpx;color:#999;margin-top:4rpx;">¥{{globalRanking[2].total_income}}</text>
          <view style="width:90rpx;height:35rpx;background:linear-gradient(#CD7F32,#E5A86A);border-radius:6rpx 6rpx 0 0;margin-top:16rpx;"></view>
        </view>
      </view>
    </view>

    <!-- 排行列表 -->
    <view style="margin:20rpx;border-radius:20rpx;background:#fff;overflow:hidden;box-shadow:0 4rpx 24rpx rgba(0,0,0,.06);">
      <view style="display:flex;align-items:center;padding:28rpx 30rpx;border-bottom:1rpx solid #f0f0f0;" wx:for="{{globalRanking}}" wx:key="id" wx:if="{{index >= 3 || globalRanking.length < 3}}">
        <text style="width:56rpx;font-size:30rpx;font-weight:700;color:{{index<3?'#faad14':'#999'}};text-align:center;">{{index + 1}}</text>
        <image src="{{item.avatar_url || '/images/default-avatar.png'}}" mode="aspectFill" style="width:72rpx;height:72rpx;border-radius:50%;margin-left:16rpx;"></image>
        <view style="flex:1;margin-left:18rpx;">
          <text style="font-size:28rpx;font-weight:600;color:#333;display:block;">{{item.nickname}}</text>
          <text style="font-size:22rpx;color:#999;margin-top:4rpx;display:block;">团队 {{item.team_count || 0}}人 · {{item.levelText}}</text>
        </view>
        <text style="font-size:30rpx;font-weight:700;color:#e94560;">¥{{item.total_income}}</text>
      </view>

      <view style="padding:60rpx 0;text-align:center;" wx:if="{{globalRanking.length == 0 && !loading}}">
        <text style="font-size:64rpx;">🏆</text>
        <text style="font-size:28rpx;color:#999;display:block;margin-top:16rpx;">暂无排行数据</text>
      </view>
      <view style="padding:40rpx;text-align:center;" wx:if="{{loading && globalRanking.length == 0}}">
        <text style="font-size:28rpx;color:#999;">加载中...</text>
      </view>
    </view>
  </view>

  <!-- ====== 正常团队视图（默认） ====== -->
  <block wx:else>
  <!-- 渐变头部 + 统计 -->
  <view class="team-header">
    <view class="header-bg-circle c1"></view>
    <view class="header-bg-circle c2"></view>
    <view class="header-bg-circle c3"></view>
    <view class="header-content">
      <text class="header-title">我的团队</text>
      <text class="header-sub">共 {{team.total || 0}} 名成员</text>
    </view>

    <!-- 统计卡片组 -->
    <view class="stat-row">
      <view class="stat-card">
        <text class="stat-num">{{team.total || 0}}</text>
        <text class="stat-label">总人数</text>
      </view>
      <view class="stat-card">
        <text class="stat-num highlight">{{team.direct || 0}}</text>
        <text class="stat-label">直推</text>
      </view>
      <view class="stat-card">
        <text class="stat-num">{{team.indirect || 0}}</text>
        <text class="stat-label">间推</text>
      </view>
    </view>
  </view>

  <!-- 邀请码卡片（悬浮） -->
  <view class="invite-card">
    <view class="invite-top">
      <view class="invite-code-wrap">
        <text class="invite-code-label">邀请码</text>
        <text class="invite-code-val">{{inviteCode}}</text>
      </view>
      <view class="copy-btn" bindtap="copyCode" hover-class="copy-btn-hover">
        <text>复制</text>
      </view>
    </view>
    <view class="invite-bottom">
      <view class="invite-action" bindtap="sharePoster" hover-class="action-hover">
        <text class="ia-icon">📤</text>
        <text>分享邀请</text>
      </view>
      <view class="invite-divider"></view>
      <view class="invite-action" bindtap="goTree" hover-class="action-hover">
        <text class="ia-icon">🌳</text>
        <text>团队树</text>
      </view>
    </view>
  </view>

  <!-- Tab栏 -->
  <view class="tab-bar">
    <view class="tab-item {{activeTab == 'direct' ? 'active' : ''}}" bindtap="switchTab" data-tab="direct">
      <text>直推成员</text>
      <view class="tab-line" wx:if="{{activeTab == 'direct'}}"></view>
    </view>
    <view class="tab-item {{activeTab == 'ranking' ? 'active' : ''}}" bindtap="switchTab" data-tab="ranking">
      <text>业绩排行</text>
      <view class="tab-line" wx:if="{{activeTab == 'ranking'}}"></view>
    </view>
    <view class="tab-item {{activeTab == 'income' ? 'active' : ''}}" bindtap="switchTab" data-tab="income">
      <text>我的收益</text>
      <view class="tab-line" wx:if="{{activeTab == 'income'}}"></view>
    </view>
  </view>

  <!-- === Tab1: 直推成员 === -->
  <scroll-view class="tab-content" scroll-y wx:if="{{activeTab == 'direct'}}" enhanced show-scrollbar="{{false}}">
    <view class="member-list">
      <!-- 成员卡片 -->
      <view class="member-card" wx:for="{{members}}" wx:key="id">
        <view class="mc-left">
          <image class="mc-avatar" src="{{item.avatar_url || '/images/default-avatar.png'}}" mode="aspectFill"></image>
          <view class="mc-rank-badge" wx:if="{{index < 3}}">{{index + 1}}</view>
        </view>
        <view class="mc-body">
          <view class="mc-name-row">
            <text class="mc-name">{{item.nickname || '微信用户'}}</text>
            <text class="mc-level" style="background:{{item.levelColor}}">{{item.levelText}}</text>
          </view>
          <text class="mc-time">加入 {{item.timeText || item.created_at}}</text>
          <view class="mc-sub-row" wx:if="{{item.sub_count}}">
            <text class="mc-sub-icon">👥</text>
            <text class="mc-sub-text">下级 {{item.sub_count}} 人</text>
          </view>
        </view>
        <view class="mc-arrow">
          <text>›</text>
        </view>
      </view>

      <!-- 空状态 -->
      <view class="empty-box" wx:if="{{members.length == 0 && !loading}}">
        <text class="empty-emoji">🤝</text>
        <text class="empty-text">还没有直推成员</text>
        <text class="empty-hint">分享邀请码邀请好友加入团队吧</text>
      </view>

      <!-- 加载中 -->
      <view class="loading-box" wx:if="{{loading}}">
        <text class="loading-dot"></text>
        <text class="loading-text">加载中...</text>
      </view>
    </view>
  </scroll-view>

  <!-- === Tab2: 业绩排行 === -->
  <scroll-view class="tab-content" scroll-y wx:if="{{activeTab == 'ranking'}}" enhanced show-scrollbar="{{false}}">
    <!-- 前三名领奖台 -->
    <view class="podium" wx:if="{{ranking.length >= 3}}">
      <!-- 第二名 -->
      <view class="podium-item p2">
        <view class="podium-medal m2">🥈</view>
        <image class="podium-avatar" src="{{ranking[1].avatar_url || '/images/default-avatar.png'}}" mode="aspectFill"></image>
        <text class="podium-name">{{ranking[1].nickname}}</text>
        <text class="podium-income">¥{{ranking[1].total_income || '0.00'}}</text>
        <view class="podium-base b2"></view>
      </view>
      <!-- 第一名 -->
      <view class="podium-item p1">
        <view class="podium-crown">👑</view>
        <view class="podium-medal m1">🥇</view>
        <image class="podium-avatar top" src="{{ranking[0].avatar_url || '/images/default-avatar.png'}}" mode="aspectFill"></image>
        <text class="podium-name top-name">{{ranking[0].nickname}}</text>
        <text class="podium-income top-income">¥{{ranking[0].total_income || '0.00'}}</text>
        <view class="podium-base b1"></view>
      </view>
      <!-- 第三名 -->
      <view class="podium-item p3">
        <view class="podium-medal m3">🥉</view>
        <image class="podium-avatar" src="{{ranking[2].avatar_url || '/images/default-avatar.png'}}" mode="aspectFill"></image>
        <text class="podium-name">{{ranking[2].nickname}}</text>
        <text class="podium-income">¥{{ranking[2].total_income || '0.00'}}</text>
        <view class="podium-base b3"></view>
      </view>
    </view>

    <!-- 排行列表 -->
    <view class="rank-list">
      <view class="rank-card" wx:for="{{ranking}}" wx:key="id" wx:if="{{index >= 3 || ranking.length < 3}}">
        <view class="rank-pos-wrap">
          <text class="rank-pos {{index < 3 ? 'top' : ''}}">{{index < 3 ? ['🥇','🥈','🥉'][index] : (index + 1)}}</text>
        </view>
        <image class="rank-avatar-sm" src="{{item.avatar_url || '/images/default-avatar.png'}}" mode="aspectFill"></image>
        <view class="rank-info">
          <text class="rank-nickname">{{item.nickname}}</text>
          <view class="rank-meta">
            <text class="rank-level-tag" style="color:{{item.levelColor}};border-color:{{item.levelColor}}">{{item.levelText}}</text>
            <text class="rank-team-count">团队 {{item.team_count || 0}}人</text>
          </view>
        </view>
        <text class="rank-money">¥{{item.total_income || '0.00'}}</text>
      </view>
    </view>

    <view class="empty-box" wx:if="{{ranking.length == 0}}">
      <text class="empty-emoji">🏆</text>
      <text class="empty-text">暂无排行数据</text>
    </view>
  </scroll-view>

  <!-- === Tab3: 我的收益 === -->
  <scroll-view class="tab-content income-scroll" scroll-y wx:if="{{activeTab == 'income'}}" enhanced show-scrollbar="{{false}}">
    <!-- 收益主卡片 -->
    <view class="income-hero">
      <view class="income-hero-inner">
        <view class="ih-top">
          <text class="ih-label">累计收益（元）</text>
          <view class="eye-btn" bindtap="toggleAmount">
            <text>{{showAmount ? '🙈' : '👁️'}}</text>
          </view>
        </view>
        <text class="ih-amount">{{showAmount ? (overview.totalIncome || '0.00') : '****'}}</text>
        <view class="ih-bars">
          <view class="ih-bar-item">
            <text class="ih-bar-val">{{showAmount ? (overview.pendingIncome || '0.00') : '**'}}</text>
            <text class="ih-bar-lbl">待结算</text>
          </view>
          <view class="ih-bar-sep"></view>
          <view class="ih-bar-item">
            <text class="ih-bar-val">{{showAmount ? (overview.withdrawnAmount || '0.00') : '**'}}</text>
            <text class="ih-bar-lbl">已提现</text>
          </view>
          <view class="ih-bar-sep"></view>
          <view class="ih-bar-item">
            <text class="ih-bar-val">{{showAmount ? (overview.todayIncome || '0.00') : '**'}}</text>
            <text class="ih-bar-lbl">今日</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 等级进度 -->
    <view class="level-progress-card">
      <view class="lpc-top">
        <view class="lpc-left">
          <text class="lpc-label">当前等级</text>
          <text class="lpc-badge" style="background:{{levelColor}}">{{levelText}}</text>
        </view>
        <text class="lpc-hint">距下一级 ¥{{nextLevelNeed}}</text>
      </view>
      <view class="lpc-bar-track">
        <view class="lpc-bar-fill" style="width: {{level >= 5 ? 100 : ((overview.totalIncome || 0) / ( [0,0,5000,50000,200000][level||1] || 1)) * 100}}%"></view>
      </view>
    </view>

    <!-- 快捷操作 -->
    <view class="quick-actions">
      <view class="qa-btn" bindtap="goWithdraw" hover-class="qa-hover">
        <text class="qa-icon">💰</text>
        <text class="qa-label">提现</text>
      </view>
      <view class="qa-btn" bindtap="goRecords" hover-class="qa-hover">
        <text class="qa-icon">📊</text>
        <text class="qa-label">明细</text>
      </view>
      <view class="qa-btn" bindtap="goWithdrawals" hover-class="qa-hover">
        <text class="qa-icon">📦</text>
        <text class="qa-label">记录</text>
      </view>
    </view>

    <!-- 最近收益 -->
    <view class="recent-card">
      <view class="rc-header">
        <text class="rc-title">最近收益</text>
        <text class="rc-more" bindtap="goRecords">全部 ›</text>
      </view>
      <view class="rc-item" wx:for="{{recentRecords}}" wx:key="id">
        <view class="rc-left">
          <view class="rc-type-icon {{item._typeClass}}">
            <text>{{item._typeIcon}}</text>
          </view>
          <view class="rc-info">
            <text class="rc-type-name">{{item._typeName}}</text>
            <text class="rc-time">{{item.created_at}}</text>
          </view>
        </view>
        <text class="rc-amount {{item._amountClass}}">+{{item.amount}}</text>
      </view>
      <view class="rc-empty" wx:if="{{recentRecords.length == 0}}">
        <text class="empty-emoji-sm">💰</text>
        <text class="empty-text-sm">暂无收益记录</text>
        <text class="empty-hint-sm">推广商品产生销售后即可获得收益</text>
      </view>
    </view>
  </scroll-view>
  </block>
</view>
