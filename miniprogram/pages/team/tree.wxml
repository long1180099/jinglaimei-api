<!-- 团队关系树 -->
<view class="page">
  <view class="tree-header">
    <text class="tree-title">团队关系树</text>
    <text class="tree-desc">共 {{totalMembers}} 人</text>
  </view>

  <!-- 树形结构 -->
  <scroll-view class="tree-container" scroll-y>
    <!-- 一级节点 -->
    <view class="tree-node level-0" wx:for="{{treeData}}" wx:key="id" bindtap="toggleNode" data-id="{{item.id}}">
      <view class="node-content">
        <view class="node-avatar-wrap">
          <image class="node-avatar" src="{{item.avatar_url || '/images/default-avatar.png'}}" mode="aspectFill"></image>
        </view>
        <view class="node-info">
          <text class="node-name">{{item.nickname || '微信用户'}}</text>
          <view class="node-meta">
            <text class="level-badge" style="background:{{item.levelColor}}">{{item.levelText}}</text>
            <text class="node-count" wx:if="{{item.children && item.children.length > 0}}">{{item.children.length}}人</text>
          </view>
        </view>
        <text class="expand-icon {{expandedIds[item.id] ? 'expanded' : ''}}">›</text>
      </view>

      <!-- 二级子节点 -->
      <view class="children" wx:if="{{expandedIds[item.id] && item.children}}">
        <view class="tree-node level-1" wx:for="{{item.children}}" wx:for-item="child" wx:key="id" bindtap="toggleNode" data-id="{{child.id}}">
          <view class="node-content">
            <view class="node-avatar-wrap small">
              <image class="node-avatar" src="{{child.avatar_url || '/images/default-avatar.png'}}" mode="aspectFill"></image>
            </view>
            <view class="node-info">
              <text class="node-name">{{child.nickname || '微信用户'}}</text>
              <view class="node-meta">
                <text class="level-badge" style="background:{{child.levelColor}}">{{child.levelText}}</text>
                <text class="node-count" wx:if="{{child.children && child.children.length > 0}}">{{child.children.length}}人</text>
              </view>
            </view>
            <text class="expand-icon {{expandedIds[child.id] ? 'expanded' : ''}}">›</text>
          </view>

          <!-- 三级子节点 -->
          <view class="children" wx:if="{{expandedIds[child.id] && child.children}}">
            <view class="tree-node level-2" wx:for="{{child.children}}" wx:for-item="grand" wx:key="id">
              <view class="node-content">
                <view class="node-avatar-wrap small">
                  <image class="node-avatar" src="{{grand.avatar_url || '/images/default-avatar.png'}}" mode="aspectFill"></image>
                </view>
                <view class="node-info">
                  <text class="node-name">{{grand.nickname || '微信用户'}}</text>
                  <text class="level-badge" style="background:{{grand.levelColor}}">{{grand.levelText}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:if="{{treeData.length == 0 && !loading}}">
      <text class="empty-icon">🌳</text>
      <text>暂无团队数据</text>
    </view>
  </scroll-view>
</view>
