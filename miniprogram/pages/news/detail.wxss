/* 公告详情页样式 */
.page {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: calc(env(safe-area-inset-bottom) + 40rpx);
}

.article-card {
  margin: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: visible;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

/* 标题区 */
.article-header {
  padding: 40rpx 36rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.article-meta {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  gap: 16rpx;
}

.article-category-tag {
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.article-date {
  font-size: 22rpx;
  color: #999;
}

.article-views {
  font-size: 22rpx;
  color: #bbb;
  margin-left: auto;
}

.article-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a2e;
  line-height: 1.5;
  display: block;
  margin-bottom: 20rpx;
  letter-spacing: 1rpx;
}

.article-author {
  font-size: 24rpx;
  color: #888;
}

/* 正文 */
.article-body {
  padding: 36rpx;
  font-size: 30rpx;
  color: #333;
  line-height: 2;
  letter-spacing: 0.5rpx;
  overflow: visible;
}

.article-body rich-text {
  word-break: break-all;
  overflow-wrap: break-word;
}

/* 底部 */
.article-footer {
  padding: 24rpx 36rpx;
  border-top: 1rpx solid #f0f0f0;
}

.footer-info {
  display: flex;
  justify-content: center;
}

.footer-updated {
  font-size: 22rpx;
  color: #bbb;
}

/* 加载/空状态 */
.loading-state, .empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
