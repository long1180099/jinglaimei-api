<view class="page">
  <view class="article-card" wx:if="{{detail}}">
    <!-- 标题区 -->
    <view class="article-header">
      <view class="article-meta">
        <view class="article-category-tag" style="background:{{categoryColor}}">{{categoryLabel}}</view>
        <text class="article-date">{{detail.published_at || detail.created_at}}</text>
        <text class="article-views">{{detail.view_count || 0}}次阅读</text>
      </view>
      <text class="article-title">{{detail.title}}</text>
      <text class="article-author">{{detail.author || '管理员'}}</text>
    </view>
    <!-- 正文 -->
    <view class="article-body">
      <rich-text nodes="{{htmlContent}}"></rich-text>
    </view>
    <!-- 底部操作 -->
    <view class="article-footer">
      <view class="footer-info">
        <text class="footer-updated">发布于 {{detail.published_at || detail.created_at}}</text>
      </view>
    </view>
  </view>
  <!-- 加载状态 -->
  <view class="loading-state" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>
  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && !detail}}">
    <text class="empty-icon">📄</text>
    <text class="empty-text">公告不存在或已删除</text>
  </view>
</view>
