/* 公告列表页样式 */
.page {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 分类Tab */
.tab-bar {
  display: flex;
  background: #fff;
  padding: 0 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 100;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
  transition: color 0.2s;
}

.tab-item.active {
  color: #e94560;
  font-weight: 700;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #e94560, #ff6b81);
  border-radius: 3rpx;
}

/* 卡片列表 */
.news-card {
  display: flex;
  align-items: center;
  margin: 16rpx 24rpx;
  padding: 28rpx 32rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.news-card:active {
  background: #fafafa;
}

.card-left {
  flex: 1;
  min-width: 0;
}

.card-top {
  margin-bottom: 8rpx;
}

.top-tag {
  font-size: 20rpx;
  color: #e94560;
  background: #fff0f2;
  padding: 2rpx 12rpx;
  border-radius: 4rpx;
  font-weight: 600;
}

.card-title {
  font-size: 30rpx;
  color: #1a1a2e;
  font-weight: 600;
  line-height: 1.5;
  display: block;
  margin-bottom: 12rpx;
}

.card-meta {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.card-category {
  font-size: 22rpx;
  font-weight: 600;
}

.card-date {
  font-size: 22rpx;
  color: #aaa;
}

.card-views {
  font-size: 22rpx;
  color: #ccc;
  margin-left: auto;
}

.card-arrow-wrap {
  flex-shrink: 0;
  margin-left: 16rpx;
}

.card-arrow {
  font-size: 40rpx;
  color: #ccc;
  font-weight: 300;
}

/* 加载更多 */
.load-more {
  display: flex;
  justify-content: center;
  padding: 32rpx 0 48rpx;
}

.load-more-text {
  font-size: 24rpx;
  color: #bbb;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 工具类 */
.line-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
